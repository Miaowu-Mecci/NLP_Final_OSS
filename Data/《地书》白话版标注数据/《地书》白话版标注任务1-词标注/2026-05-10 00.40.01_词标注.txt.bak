      "target_id": "word_006",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "指带有求婚意图、希望促成结婚的礼物，是主人公进一步的幻想。",
      "confidence": 0.90,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "从生日礼物升级到求婚礼物，体现心理递进。"
