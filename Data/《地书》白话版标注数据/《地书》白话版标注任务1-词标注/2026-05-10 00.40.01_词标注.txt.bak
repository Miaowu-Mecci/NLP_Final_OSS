      "task_label_en": "Pragmatic Meaning",
      "value": "指主人公正在过马路的场景，是他思考礼物问题的当下空间环境。",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "点明空间背景，为内心盘算提供场景支撑。"
    },
    {
      "annotation_id": "ann_002",
      "target_id": "word_002",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "指主人公在心里反复思考、筹划要送什么礼物给女方。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "体现主人公犹豫、反复斟酌的心理活动。"
    },
    {
      "annotation_id": "ann_003",
      "target_id": "word_003",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "指为女方三十岁生日准备的礼品，是主人公当前思考的核心对象。",
      "confidence": 0.94,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "礼物是整个段落思考的出发点。"
    },
    {
      "annotation_id": "ann_004",
      "target_id": "word_004",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "指女方即将到来的年龄节点，是主人公准备生日礼物的直接原因。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "年龄触发了送礼、求婚等一系列想法。"
    },
    {
      "annotation_id": "ann_005",
      "target_id": "word_005",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "指主人公喜欢、想要求婚的对象，是所有思考围绕的人物核心。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "全文心理活动都围绕该女性展开。"
