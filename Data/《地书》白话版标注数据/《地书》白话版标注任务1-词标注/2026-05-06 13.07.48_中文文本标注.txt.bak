      "target_id": "word_353",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个奇幻语境中，“掉下来”并非指物理上的坠落，而是暗示一种超现实的情节转折或角色状态的突变，用于推动荒诞叙事并强化惊讶的情感体验。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_354",
