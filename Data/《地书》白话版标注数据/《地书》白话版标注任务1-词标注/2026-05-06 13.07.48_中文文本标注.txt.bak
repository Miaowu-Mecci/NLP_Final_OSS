  "annotations": [
    {
      "annotation_id": "ann_001",
      "target_id": "word_001",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "会议在这里指代一次公开的发言或汇报活动，实际含义是“我”在众人面前完成讲话或展示后获得认可的场景。语用功能是暗示“我”在会议中的表现成功，从而引出后续受到掌声鼓励的积极情感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_002",
      "target_id": "word_002",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "结束在这里指会议流程的完成，语用上暗示发言或活动告一段落，为后续获得掌声和积极情绪做铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_003",
      "target_id": "word_003",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“后”在句中表示会议这一事件的时间终点，语用功能是明确事件结束的节点，为后续“受到掌声鼓励”提供时间背景，使叙述逻辑连贯。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_004",
      "target_id": "word_004",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“我”在句中指代说话者本人，强调其作为被鼓励对象的身份，语用功能是表达说话者因受到认可而产生的积极情绪，并推动叙述从事件转向主观感受。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_005",
      "target_id": "word_005",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“受到”在此语境中实际含义是“得到、获得”，指主语被动接受了大家给予的掌声鼓励。其语用功能是表达主语因被认可而产生的积极情感，并暗示主语在会议中的表现获得了正面反馈。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_006",
      "target_id": "word_006",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“了”在句中表示动作“结束”已经完成，强调事件已成为过去，同时与“受到”“心情不错”共同构成一种叙述完成的状态，语用功能是标记时间节点，使叙述自然收束，并暗示后续情感是建立在事件完成的基础之上。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_007",
      "target_id": "word_007",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“大家”实际指代在场的所有与会者，强调发言获得集体认可，语用功能是表达被广泛接纳的愉悦感，并暗示发言效果成功。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_008",
      "target_id": "word_008",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“的”在此语境中用于连接定语“大家”和中心语“掌声鼓励”，表示领属关系，强调掌声来自大家，同时使句子结构完整自然，语气平稳陈述事实。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_009",
      "target_id": "word_009",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "掌声在此语境中实际指大家对我表示认可和赞许的集体行为，语用功能是传递正面情感反馈，暗示我的表现或发言获得了听众的积极评价。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_010",
      "target_id": "word_010",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“鼓励”的实际含义是大家通过掌声表达对我的认可和赞许，而非单纯的激励或劝勉。其语用功能是传递正向情感反馈，烘托出我受到肯定后的愉悦心情。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_011",
      "target_id": "word_011",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "心情在此语境中指受到掌声鼓励后产生的愉悦、满足的主观感受，承担表达积极情绪和强化正面体验的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_012",
      "target_id": "word_012",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句中，“非常”表示程度很高，用于强化“不错”所表达的积极情绪，语用功能是强调说话人受到掌声鼓励后心情的强烈愉悦感，传递出满足和自豪的情感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_013",
      "target_id": "word_013",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“不错”在句中表示心情愉悦、感到满意，语用功能是表达积极情感，强调受到鼓励后的正面心理状态。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_014",
      "target_id": "word_014",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“我”在语境中实际指代一个受到认可和欢迎的社交活跃者，承担了串联积极情绪与后续社交行为的主体功能，暗示了主人公因被肯定而产生的满足感和融入感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_015",
      "target_id": "word_015",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句中，“拿出”的实际含义是“掏出并开始使用手机”，语用功能是引出后续查看社交媒体的动作，推动情节发展，展现主人公在会议成功后的轻松愉悦心情。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_016",
      "target_id": "word_016",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“手机”在此语境中实际指代一个能够连接互联网、安装并运行多种社交应用程序的智能设备，用于查看社交互动和接收消息。其语用功能是推动情节发展，通过展示手机上的社交活动来具体体现“心情非常不错”的原因，并暗示主人公在社交平台上受到关注和认可。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_017",
      "target_id": "word_017",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“翻看”在句中实际指快速浏览手机社交软件上的新消息和互动内容，而非仔细阅读。它承担了表现主人公轻松愉悦心情和社交满足感的语用功能，暗示其受到关注后的积极情绪。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_018",
      "target_id": "word_018",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“了”在此处表示动作的完成或新情况的出现，语用功能是强调“翻看”这一行为已经发生，并自然引出后续的社交动态，推动情节发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_019",
      "target_id": "word_019",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“一下”在句中表示短暂、随意的动作，语用功能是弱化“翻看”的刻意性，暗示主人公心情轻松、动作不耗时，配合上下文烘托愉悦闲适的氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_020",
      "target_id": "word_020",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "社交软件在句中实际指代Twitter、Facebook、MSN等具体平台，功能是借查看这些应用来表现主人公心情愉悦、渴望分享与互动，推动情节从会议成功过渡到社交生活。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_021",
      "target_id": "word_021",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“看到”在语境中实际含义是“注意到”或“发现”，强调通过社交软件感知到他人对自己的积极反馈。其语用功能是承接前文“心情不错”，具体展现外界认可带来的愉悦感，同时推动情节从会议场景自然过渡到社交互动。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_022",
      "target_id": "word_022",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“有人”在这里并非特指某个具体的人，而是泛指多个社交平台上的不同用户，强调来自不同渠道的积极互动，语用功能是烘托主人公受到广泛关注和认可的愉悦心情。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_023",
      "target_id": "word_023",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“在”表示动作正在进行或状态持续，强调“有人正在Twitter上为我点赞”这一即时发生的动作，语用功能是增强场景的生动性和代入感，推动情节展现“我”心情愉悦的细节。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_024",
      "target_id": "word_024",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "Twitter在句中指代一个具体的社交媒体平台，用于接收点赞通知，体现社交互动和认可，推动情节展现主人公受到多方关注和积极反馈的愉悦心情。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_025",
      "target_id": "word_025",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中，“上”表示在某个网络平台或社交软件内部，指代具体的虚拟空间或服务环境，语用功能是明确动作发生的媒介位置，推动叙述具体化。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_026",
      "target_id": "word_026",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“为”在句中表示“给、替”，指别人对我进行点赞这一行为，语用功能是表达社交互动中的受益关系，暗示我受到关注和认可。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_027",
      "target_id": "word_027",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“我”指代一个刚刚在会议上获得掌声鼓励、心情愉悦的叙述者，通过展示社交互动来强化自我满足感，承担了表达个人情感体验和推动叙事发展的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_028",
      "target_id": "word_028",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“点赞”在句中实际指社交媒体上用户对发言内容的认可或支持行为，语用功能是表现主人公在社交平台上获得积极反馈，与会议掌声呼应，强化其心情愉悦的语境氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_029",
      "target_id": "word_029",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“还有”在此语境中表示列举的递进，语用功能是推动情节发展，暗示作者陆续收到来自不同社交平台的积极反馈，从而烘托出心情愉悦的延续和社交互动的丰富性。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_030",
      "target_id": "word_030",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“人”在句中实际指代社交平台上的互动用户，并非特指具体个体，而是泛指网络社交中的参与者。其语用功能是强调社交互动的广泛性和多样性，烘托主人公受到关注和欢迎的愉悦心情。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_031",
      "target_id": "word_031",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“在”表示动作或状态正在进行，强调点赞、发消息、约酒这些行为在说话时已经发生并持续存在，起到推进叙述、营造现场感的作用。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_032",
      "target_id": "word_032",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“Facebook”实际指的是一个社交媒体平台，用于接收朋友互动（如表情回复），其语用功能是具体展示“社交软件”的多样性，并暗示主人公在多个平台上受到关注，从而烘托其心情愉悦、社交活跃的状态。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_033",
      "target_id": "word_033",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中，“上”表示在某个网络平台或社交软件内部，指代虚拟空间中的互动行为，语用功能是具体化社交媒体的使用场景，暗示用户通过平台进行点赞、发消息等线上活动。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_034",
      "target_id": "word_034",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在“给我发了大笑的表情”中，“给”表示动作的接受者指向“我”，强调表情的发送对象；在“约我晚上一起喝酒”中，“给”隐含了邀请行为的受益方。整体上，“给”承担了传递社交互动中动作指向的功能，推动情节展现他人对“我”的积极反馈，烘托愉悦心情。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_035",
      "target_id": "word_035",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”不仅指叙述者本人，更承载着被认可后的愉悦与满足感，通过列举社交平台上的互动，强化了自我价值得到肯定的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_036",
      "target_id": "word_036",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“发”在此语境中实际指通过社交平台发送消息或表情，承担了描述社交互动行为的语用功能，暗示了他人对“我”的友好回应与情感交流。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_037",
      "target_id": "word_037",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“了”在句中表示动作的完成或变化已经发生，强调“翻看”这个动作已经结束，同时暗示后续信息是这一动作带来的新发现，推动情节自然过渡到作者看到社交动态的内容。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_038",
      "target_id": "word_038",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“大笑”实际指社交平台上表示开心或赞同的表情符号，语用功能是传达对方对用户内容的积极反馈，烘托用户受到认可和欢迎的愉悦心情。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_039",
      "target_id": "word_039",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“的”是结构助词，用于连接定语“大笑”和中心语“表情”，表示修饰关系，强调表情的具体类型。在语境中，它帮助具体化社交互动中的细节，推动情节展现“我”受到多种积极反馈的愉悦心情。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_040",
      "target_id": "word_040",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "该语境中“表情”指社交平台上的图形化情感符号（如Emoji），具体是“大笑”的表情，用于表达赞许或愉悦的互动。其语用功能是通过网络社交符号传递对方对“我”的友好回应，烘托“我”受到认可后的愉快心情。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_041",
      "target_id": "word_041",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“更”在此处表示递进关系，强调后续事件（MSN上约酒）比前两个互动（点赞、发表情）在社交亲密度或行动力上更进一步，推动情节从被动回应转向主动邀约，暗示作者心情愉悦并期待后续社交活动。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_042",
      "target_id": "word_042",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“有”在句中表示存在，具体指社交平台上存在某些用户行为（点赞、发表情、约酒），语用功能是列举和强调多种社交互动，烘托出“我”受到广泛关注和欢迎的愉悦心情。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_043",
      "target_id": "word_043",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“人”在语境中实际指代社交平台上的其他用户或联系人，承担了暗示社交互动活跃、体现主人公受到关注和认可的功能，从而烘托其愉悦心情。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_044",
      "target_id": "word_044",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“在”表示动作正在进行或状态持续存在，强调“有人正在Twitter上为我点赞”这一即时发生的社交互动，语用功能是推动情节发展，暗示作者心情愉悦并沉浸于被关注和认可的当下体验。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_045",
      "target_id": "word_045",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "MSN在此处指代微软旗下的即时通讯软件MSN Messenger，用于朋友间私下约酒，体现社交互动从公开平台转向私密对话，推动情节从公开赞美转向私下邀约，暗示关系亲近。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_046",
      "target_id": "word_046",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中，“上”表示在某个网络平台或社交软件内部，指代具体的数字空间或服务界面，语用功能是明确动作发生的虚拟场所，推动对社交互动场景的具体描述。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_047",
      "target_id": "word_047",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“约”在此语境中实际含义是“邀请”，指通过MSN联系并提议晚上一起喝酒。其语用功能是推动情节发展，暗示社交活动的安排，并呼应前文“心情不错”的愉悦状态。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_048",
      "target_id": "word_048",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“我”在语境中实际指代一个在会议中受到认可、心情愉悦的叙述者，承担了串联事件、表达个人情感体验和推动情节发展的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_049",
      "target_id": "word_049",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "晚上在句中指当天会议结束后的晚间时段，具体暗示了庆祝或社交聚会的邀约时间。该词承担了推动情节发展的语用功能，为后续可能的社交活动埋下伏笔。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_050",
      "target_id": "word_050",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“一起”在语境中表示“共同、结伴”的意思，指对方邀请“我”晚上共同参与喝酒这一社交活动。其语用功能是暗示社交邀约的亲密性和互动性，推动情节从线上互动转向线下实际接触，并烘托出“我”心情愉快、乐于接受社交的氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_051",
      "target_id": "word_051",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“喝酒”在语境中实际含义是社交聚会或庆祝活动，语用功能是暗示通过共同饮酒来延续会议成功带来的愉悦心情，并加强人际联系。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_052",
      "target_id": "word_052",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "该词语在语境中实际指代叙述者本人，即一个在社交软件上与人互动的普通用户。其语用功能是确立叙述主体，通过“我”的视角推动情节发展，暗示叙述者正处于轻松、愉悦的社交状态中。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_053",
      "target_id": "word_053",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“心情”在此语境中实际指“情绪状态”，强调因社交互动（如被点赞、收到表情、被邀约）而产生的愉悦感，语用功能是表达情感并推动情节，暗示网络社交带来的积极心理体验。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_054",
      "target_id": "word_054",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“愉快地”在语境中实际表达的是主人公因社交互动获得积极反馈（点赞、大笑表情、约酒）而产生的满足与轻松感，语用功能是强化情绪状态，为后续聊天行为铺垫愉悦的心理基调。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_055",
      "target_id": "word_055",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中，“在”表示动作发生的具体平台或媒介，语用功能是明确交流场景，推动情节发展，暗示聊天是通过MSN这一即时通讯工具进行的。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_056",
      "target_id": "word_056",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "MSN在此语境中指代微软旗下的即时通讯软件MSN Messenger，是社交聊天工具的一种，用于线上交流与邀约。该词语承担了交代社交场景、暗示人物关系亲近以及推动情节（约酒）的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_057",
      "target_id": "word_057",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中，“上”表示在某个网络平台或社交软件中，具体指MSN这个即时通讯工具。它的语用功能是明确交流发生的虚拟空间，帮助读者理解对话的媒介环境。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_058",
      "target_id": "word_058",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“和”表示“与、跟”，在语境中起连接作用，引出交流对象，暗示通过MSN这一即时通讯工具进行互动，推动情节中社交活动的展开。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_059",
      "target_id": "word_059",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“一位”在这里并非单纯表示数量，而是暗示说话人与该女士关系不熟或带有礼貌性的距离感，同时为后文可能发生的互动铺垫了社交场合的正式感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_060",
      "target_id": "word_060",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句中，“女士”并非强调性别或礼貌称谓，而是暗示对方是网络社交中一位身份不明、可能带有浪漫或暧昧意味的异性聊天对象，推动情节向轻松、私密的社交互动发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_061",
      "target_id": "word_061",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“聊了”实际指通过MSN即时通讯软件进行文字交流，带有轻松、愉快的社交互动意味。该词语推动情节发展，暗示“我”与那位女士的对话是主动开启且氛围良好，为后续可能发生的线下邀约（如喝酒）做铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_062",
      "target_id": "word_062",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“起来”表示动作的开始并持续，这里指“我”与那位女士开始聊天并进入交谈状态，语用功能是推动情节，暗示对话的顺利展开。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_063",
      "target_id": "word_063",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“很快”实际表达的是说话者因心情愉快、聊天投入而对时间流逝产生的轻松感，暗示下班时间在不知不觉中到来。其语用功能是烘托愉悦放松的情绪，并自然衔接后续动作。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_064",
      "target_id": "word_064",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "就：在句中表示时间短、接近，强调下班时间即将到来，带有一种轻松、期待的情绪，推动情节向愉快交谈过渡。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_065",
      "target_id": "word_065",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“到”在这里表示时间接近或达到某个节点，语用功能是推动叙事进程，暗示下班时刻即将来临，为后续对话场景做铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_066",
      "target_id": "word_066",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "了表示动作或状态的完成，在句中强调打印文件这一动作已经结束，为后续离开公司做好铺垫，同时暗示时间节点的自然过渡。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_067",
      "target_id": "word_067",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“下班时间”在此语境中实际指工作日的结束时刻，暗示一种从工作状态向个人生活转换的节点，语用功能是推动情节从工作场景过渡到放松交流，为后续与女士聊天营造轻松氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_068",
      "target_id": "word_068",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“我”在语境中实际指代叙述者本人，承担了叙述视角的定位功能，通过第一人称叙述推动情节发展，并暗示叙述者与那位女士的聊天带有个人情感色彩。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_069",
      "target_id": "word_069",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“打印”在句中指完成工作收尾的常规操作，语用功能是暗示主人公即将结束工作状态、为后续与女士聊天腾出时间，推动情节从工作场景过渡到私人社交。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_070",
      "target_id": "word_070",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“完”在这里表示动作的结束和任务的完成，语用功能是强调下班前最后一项工作的收尾，为接下来轻松聊天的心情做铺垫，暗示一种解脱和放松。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_071",
      "target_id": "word_071",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "最后在这里的实际含义是“当天工作收尾阶段剩余的部分”，语用功能是暗示工作即将结束、为下班离开做铺垫，同时自然过渡到后续与女士聊天的轻松情境。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_072",
      "target_id": "word_072",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "一点在这里指代最后剩余的部分文件，语用功能是暗示工作即将轻松完成，为下文愉快聊天营造放松氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_073",
      "target_id": "word_073",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "文件指代与工作相关的文档材料，这里暗示主人公以处理工作事务为表面理由，实际为与女士聊天创造合理情境，起到掩饰真实意图的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_074",
      "target_id": "word_074",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“准备”表示即将实施离开公司的动作，但结合上下文，它实际暗示了对话者因与女士聊天而心情愉快，对下班后的活动抱有期待，从而推动情节从工作状态向社交状态过渡。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_075",
      "target_id": "word_075",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“离开”在此语境中实际指结束当天的工作、下班回家，语用功能是暗示工作日的结束和私人时间的开始，为后续与女士聊天营造轻松愉快的氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_076",
      "target_id": "word_076",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "公司在这里指代工作场所或办公地点，语用功能是明确叙述者结束当日工作的空间位置，为后续离开和聊天行为提供背景。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_077",
      "target_id": "word_077",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“走出”在语境中实际表示完成工作后离开公司大楼的动作，语用功能是推动情节从工作场景过渡到私人行动，暗示下班后的自由与下一步行动的开始。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_078",
      "target_id": "word_078",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“公司大楼”在语境中实际指代主人公的工作场所，即其办公地点所在的建筑物。它承担了推动情节的功能，通过“走出”这一动作自然过渡到下班后的行动场景，暗示主人公已完成当日工作，进入私人时间。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_079",
      "target_id": "word_079",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里“我”指代叙述者本人，是故事中的第一人称视角，承担推动情节发展的功能，通过“我”的动作串联起下班、打电话等后续事件。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_080",
      "target_id": "word_080",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“拿出”在此语境中实际含义是“从口袋或包中取出手机”，语用功能是推动情节发展，表明主人公开始主动联系对方，为后续通话行为做铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_081",
      "target_id": "word_081",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "手机在此语境中实际指代通讯工具，用于存储联系人信息并拨打电话，其语用功能是推动情节发展，暗示主人公主动联系那位女士的意图。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_082",
      "target_id": "word_082",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“找到”实际指从手机通讯录中定位并选中那位女士的电话号码，语用功能是推动情节发展，表明“我”主动联系对方的行动开始。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_083",
      "target_id": "word_083",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "那位在句中指代前文已提及的特定女性，语用功能是明确指称对象，推动情节发展，暗示说话人与该女士有预先约定或已知关系。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_084",
      "target_id": "word_084",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“女士”并非泛指成年女性，而是特指说话人手机通讯录中某个具体联系人，暗示双方关系可能较为正式或疏远，承担了推动情节发展的语用功能，为后续拨打电话的行为提供铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_085",
      "target_id": "word_085",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“的”在此语境中用于连接定语“那位女士”和中心语“电话号码”，表示领属关系，明确电话属于特定对象，推动情节向拨打电话发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_086",
      "target_id": "word_086",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在该语境中，“电话号码”实际指代的是那位女士的联系方式，具体表现为手机中存储的用于拨打的数字序列。其语用功能是推动情节发展，暗示“我”即将主动联系对方，为后续通话或见面埋下伏笔。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_087",
      "target_id": "word_087",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "拨了在此语境中实际含义是拨打号码发起通话，语用功能是推动情节发展，表明主人公主动联系对方以推进后续事件。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_088",
      "target_id": "word_088",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“过去”在此语境中实际表示“向对方（那位女士）的方向”拨打电话，语用功能是推动情节发展，暗示动作的指向性和目的性，即主动联系对方。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_089",
      "target_id": "word_089",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“电话”实际指代的是通过手机拨出的通话连接或通话行为本身，而非实体设备；它承担了推动情节发展的语用功能，表明双方开始直接交流的关键节点。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_090",
      "target_id": "word_090",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“接通”在此语境中实际含义是电话成功建立连接，双方可以开始通话。它承担了推动情节发展的语用功能，标志着从“拨号”到“通话”的关键转折，使后续对话自然展开。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_091",
      "target_id": "word_091",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“后”在此语境中表示“电话接通之后”的时间节点，语用功能是衔接动作顺序，推动情节从“拨打电话”自然过渡到“她笑着问是谁”的对话场景。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_092",
      "target_id": "word_092",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“她”指代前文提到的“那位女士”，在语境中承担明确指称和推动情节的功能，表明电话接通后接听者是这位特定女性。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_093",
      "target_id": "word_093",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“笑着”并非单纯描述面部表情，而是暗示她以礼貌、轻松或略带试探的语气接听电话，以缓和陌生来电的突兀感，同时推动情节自然过渡到对话环节。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_094",
      "target_id": "word_094",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“问”的实际含义是“通过提问来确认对方的身份”，语用功能是表现通话开始时的礼貌性试探和社交互动，推动情节从拨打电话转向对话交流。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_095",
      "target_id": "word_095",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子“她笑着问是谁”中，“是”的实际含义是询问对方的身份，承担确认来电者是谁的语用功能，推动对话从接通到身份确认的环节。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_096",
      "target_id": "word_096",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“谁”在这里的实际含义是询问对方的身份，即打电话的人是谁。它的语用功能是推动情节发展，表明接电话者尚未确认来电者身份，为后续对话展开铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_097",
      "target_id": "word_097",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”在语境中实际含义是说话者向对方确认自己的身份，即电话另一端的接听者。其语用功能是回应对方的询问，消除对方的疑惑，并自然引出后续的邀约，推动对话从确认身份转向见面提议。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_098",
      "target_id": "word_098",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“笑着”在语境中表示说话人以轻松、友善的语气回应对方的询问，同时传递出亲切和期待的情感，语用功能是缓和对话气氛并暗示双方关系融洽，为后续邀约铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_099",
      "target_id": "word_099",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“告诉”在此语境中实际含义是“通过电话向对方说明自己的身份”，承担了消除对方疑惑、确认身份并推动对话进入邀约阶段的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_100",
      "target_id": "word_100",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的她指代的是电话另一端的女性，即接电话并笑着询问身份的人。在语境中，她通过笑声和询问推动对话自然展开，暗示双方关系较为熟悉或轻松，为后续邀请见面营造了友好氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_101",
      "target_id": "word_101",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“是”表示确认身份，语用功能是回应对方的询问，消除疑惑并推动对话进入下一步邀约。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_102",
      "target_id": "word_102",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”不仅指说话者本人，更承担了确认身份、消除对方疑惑的语用功能，同时通过重复对方问话中的“是我”来营造亲切、默契的互动氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_103",
      "target_id": "word_103",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "表示递进关系，连接前后两个动作，语用功能是推动叙述，使“邀请”这一行为自然承接前面的“告知身份”。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_104",
      "target_id": "word_104",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "该语境中“邀请”的实际含义是主动提出与对方在晚上会面的提议，语用功能是推动情节发展，表明说话人希望与对方建立进一步接触的意图。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_105",
      "target_id": "word_105",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "她指代电话另一端的女性，在语境中通过重复使用强化了对话双方的互动关系，并暗示双方已有一定熟悉度，推动后续见面邀约的情节发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_106",
      "target_id": "word_106",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "晚上在当前语境中实际指当天日落之后的时间段，语用功能是约定具体见面时间，推动对话向邀约和安排行程发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_107",
      "target_id": "word_107",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“一起”的实际含义是“共同参与、双方同时在场”，语用功能是表达邀请的意图，暗示希望对方接受见面并共度时间，推动社交互动。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_108",
      "target_id": "word_108",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“见面”实际含义是指双方在晚上约定一个具体地点会面交谈，而不是单纯指“彼此看见”。语用功能是推动情节发展，表达说话人主动提出约会或进一步接触的意图。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_109",
      "target_id": "word_109",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "她在语境中指代的是说话者正在通话的对象，一个与说话者关系亲近、可能为朋友或恋人的女性。该词语承担了明确指称并推动情节发展的功能，暗示双方已有约定且关系融洽，为后续见面邀约提供了情感基础。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_110",
      "target_id": "word_110",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中表示动作或状态发生的处所或范围，具体指电话通话的另一端，语用功能是交代事件发生的背景空间，使叙述更具体自然。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_111",
      "target_id": "word_111",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "电话在这里指代通话中的对方，具体是那个正在与她通话的人所在的位置或状态，语用上强调双方通过通讯工具进行交流的场景，暗示了对话的间接性和距离感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_112",
      "target_id": "word_112",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "那头在句中指电话的另一端，即通话的对方位置。语用功能是借助空间距离的表述来暗示通话双方身处异地，同时自然引出后续的约定与回应，推动情节发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_113",
      "target_id": "word_113",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "她在电话那头核实并最终敲定了见面时间，这一确认行为让邀约从提议变为确定，推动情节从邀请进入具体安排阶段，同时暗示了双方对见面的期待与配合。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_114",
      "target_id": "word_114",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "了在句中表示动作的完成或状态的实现，确认了时间表明确认动作已经结束，答应了则体现回应行为已发生，共同推动情节从邀约到确认的进展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_115",
      "target_id": "word_115",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "她在句子中指的是双方约定的具体见面时刻，承担了推动情节发展的语用功能，暗示了见面安排已经敲定。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_116",
      "target_id": "word_116",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中“我”指代说话者自身，承担叙述主体功能，通过第一人称视角直接表达人物对约定确认的积极情感，推动情节自然过渡到后续见面安排。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_117",
      "target_id": "word_117",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "高兴在此语境中实际含义是表达对邀约被接受后的愉悦与期待，语用功能是强化说话人积极的情感态度，并暗示双方关系融洽、会面顺利推进。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_118",
      "target_id": "word_118",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中，“地”作为状语标记，连接形容词“高兴”与动词“答应”，语用功能是强化说话人听到确认后欣然同意的情感状态，暗示内心愉悦与积极回应，推动情节向会面发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_119",
      "target_id": "word_119",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“答应”的实际含义是欣然同意对方的提议，表达了对见面安排的积极接受和喜悦心情。其语用功能是推动情节发展，明确主角对邀请的肯定态度，并传递出期待的情感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_120",
      "target_id": "word_120",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "了在句中表示动作的完成或状态的实现，确认了时间表明确认动作已经结束，答应了则体现回应动作的完成，共同推动情节从邀约到确认的进展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_121",
      "target_id": "word_121",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "最后在句中表示通话结束前的最终时刻，语用功能是推动情节收束，暗示双方达成一致后对话自然终止。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_122",
      "target_id": "word_122",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“她”实际指代电话另一端的说话对象，即确认时间的人，语用功能是明确对话双方的角色关系，推动情节自然衔接。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_123",
      "target_id": "word_123",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中，“在”表示动作正在进行，强调“她”说话时正处于通话状态，语用功能是交代背景信息，使叙述更连贯自然。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_124",
      "target_id": "word_124",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“电话”实际指代的是通过电话进行的远程通话或沟通场景，而非实体设备。其语用功能是暗示双方并未面对面交流，同时为后文“比手势”这一视觉动作在听觉媒介中的不合理性埋下伏笔，突出说话人开心确认的生动情态。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_125",
      "target_id": "word_125",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“里”并非表示物理空间内部，而是指在电话通话这一媒介或情境中，实际含义是“通过电话”或“在电话交谈的过程中”。其语用功能是强调动作发生的虚拟交流场景，使读者理解手势与言语的同步性，推动情节自然衔接。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_126",
      "target_id": "word_126",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中，“比”实际表示“做出、展示”的动作，指用手势比划出OK形状。其语用功能是生动描绘人物在电话中通过视觉手势强化口头确认，传递出轻松、肯定的情绪，推动情节向达成一致发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_127",
      "target_id": "word_127",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“了”表示动作或状态的实现，即“确认”这个行为已经完成，同时带有轻松、肯定的语气，强化了对话中双方达成一致的愉悦感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_128",
      "target_id": "word_128",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "个在这里是量词，用于修饰手势，具体指代一个OK手势的动作，语用功能是生动形象地描述电话中比划手势的瞬间，推动情节发展并增强画面感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_129",
      "target_id": "word_129",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“OK”手势表示确认、同意或事情已办妥，语用功能是强化口头承诺的肯定态度，同时传递出轻松愉快的情绪，推动对话顺利结束。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_130",
      "target_id": "word_130",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“手势”指通过比出OK形状的手部动作来传达确认、同意或事情顺利的积极信号，其语用功能是强化口头承诺的情感色彩，生动展现说话人开心、爽快的态度，并推动对话向圆满结束发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_131",
      "target_id": "word_131",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "开心在句中表示她通过语气和手势传达出积极、满意的情绪，语用功能是强化她爽快答应时的愉悦态度，暗示双方沟通顺畅、关系融洽。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_132",
      "target_id": "word_132",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子“我高兴地答应了”中，“地”作为状语标记，连接形容词“高兴”与动词“答应”，语用功能是强调主语在答应时的情绪状态，推动情节表达出说话者积极、愉悦的回应态度。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_133",
      "target_id": "word_133",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“说”的实际含义是伴随手势和语气传达出确认、同意和愉悦的情绪，语用功能是强化肯定回应并表达积极情感，推动对话顺利结束。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_134",
      "target_id": "word_134",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "好的在此语境中表示确认和同意，同时传递出愉快、爽快的情绪。它的语用功能是强化肯定回应，并推动对话顺利结束。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_135",
      "target_id": "word_135",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“没问题”表示她爽快地同意或确认了约定，语用功能是表达积极回应和愉快接纳，推动对话顺利结束。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_136",
      "target_id": "word_136",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "下午五点这个具体时间点，在语境中实际指代的是工作结束、获得解放的时刻，承担了表达如释重负和期待下班后自由时光的情感功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_137",
      "target_id": "word_137",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "下午五点指代下班这一时间节点，表达说话者期待已久的解脱与喜悦，语用功能是强调工作结束的准时与满足感，推动情节向轻松愉快的方向转折。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_138",
      "target_id": "word_138",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“终于”在此语境中表达说话人因结束工作而如释重负的强烈情绪，语用功能是突出期待已久的解脱感，并暗示对下班时刻的迫切渴望。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_139",
      "target_id": "word_139",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“到了”在句中表示期待已久的时刻终于来临，语用功能是表达如释重负的喜悦和满足感，同时推动情节从等待转向行动。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_140",
      "target_id": "word_140",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语【下班】在语境中实际含义是结束当天的工作任务，获得自由时间，并暗示说话者因工作结束而感到轻松愉悦。其语用功能是表达情感释放和推动情节向积极方向发展的转折。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_141",
      "target_id": "word_141",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“时间”在句中实际指代下班这一特定时刻，而非泛指时间概念。它承担表达期待与解脱情感的语用功能，暗示说话人终于结束工作、获得自由。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_142",
      "target_id": "word_142",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”实际指代说话者本人，但结合“终于到了下班时间”的上下文，它承担了表达解脱和急切结束工作的语用功能，暗示了说话者完成工作后的放松与对下班的期待。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_143",
      "target_id": "word_143",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“赶紧”在此语境中表示动作的急切和高效，传达出说话人急于结束工作、准时下班的心理，语用功能是强化时间紧迫感和行动效率。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_144",
      "target_id": "word_144",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“整理”在此语境中实际含义是“快速归位并收拾干净”，语用功能是表现主人公结束工作时的利落动作和急切下班的心情，暗示任务完成、准备离开的节奏感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_145",
      "target_id": "word_145",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“好”在此语境中表示动作的完成状态，强调整理工作已经结束、达到有序的结果。它承担了推动情节的语用功能，暗示下班前的准备工作已就绪，为后续“处理完邮件、关上电脑”的行动提供时间上的衔接。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_146",
      "target_id": "word_146",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“桌上”在此语境中实际指代办公桌的桌面，强调工作场景的即时性和下班前的收尾动作，语用功能是具象化整理行为的发生位置，暗示主人公即将结束工作、准备离开的状态。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_147",
      "target_id": "word_147",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“的”在此处是结构助词，用于连接定语“桌上”和中心语“文件”，表示所属或方位关系，具体指明文件、书本和计算器是位于桌面上的物品，使描述更清晰具体。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_148",
      "target_id": "word_148",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“文件”在句中指代办公桌上需要处理的纸质或电子文档材料，属于工作场景中的具体物件。它承担了推动情节的功能，通过列举“文件、书本、计算器”等物品，生动描绘出下班前整理办公桌的忙碌状态，暗示主人公结束了一天的工作。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_149",
      "target_id": "word_149",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“书本”指办公桌上与工作相关的书籍或资料，而非泛指所有书籍。它和“文件”“计算器”并列，共同暗示主人公正在结束一天的工作，推动了下班前整理办公桌的情节。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_150",
      "target_id": "word_150",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“和”在此处是列举连接词，实际含义是“以及”，语用功能是简洁地罗列下班前整理的具体物品，暗示主人公有条不紊地完成收尾工作，为“终于下班”的轻松感做铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_151",
      "target_id": "word_151",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“计算器”指代办公桌上常见的电子计算工具，暗示了说话人从事需要频繁计算的工作（如财务、数据统计等），与文件、书本、邮件、电脑共同构成完整的办公场景，推动了下班前收拾物品、结束工作的情节。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_152",
      "target_id": "word_152",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“处理”在此语境中实际指完成、回复或归档最后几封邮件，以结束当天工作。它承担了推动情节的语用功能，暗示下班前收尾工作的紧迫感和效率，为“下班”这一结果做铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_153",
      "target_id": "word_153",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“完”在此语境中表示动作的彻底结束，强调最后几封邮件被全部处理完毕，没有遗留。它承担了收束动作、暗示下班前任务已全部完成的语用功能，与“最后”呼应，强化了时间节点的终结感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_154",
      "target_id": "word_154",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“最后”在此语境中实际指下班前必须完成的、收尾性的工作，带有结束一天事务、即将解脱的意味。它承担了推动时间线收束、暗示任务紧迫与完成感的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_155",
      "target_id": "word_155",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“几封”在此语境中实际指代“最后需要处理的少量邮件”，强调下班前收尾工作的紧迫性和完成感，语用功能是推动情节从工作状态过渡到下班时刻，暗示任务即将结束的轻松感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_156",
      "target_id": "word_156",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“邮件”指工作相关的电子通信，需要及时处理才能结束当天的工作。它承担了推动情节的功能，暗示主人公在下班前完成了最后的工作任务，为“终于下班”这一结果做铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_157",
      "target_id": "word_157",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“关上”在这里的实际含义是结束当天的工作、准备离开办公室，语用功能是暗示下班这一时间节点的到来，推动从工作状态到离开的过渡。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_158",
      "target_id": "word_158",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“电脑”在句中实际指代办公用的台式或笔记本电脑，是完成邮件处理等工作的工具。其语用功能是暗示工作流程的结束，与“整理文件”“关上”等动作共同构成下班前的收尾场景，推动情节从工作状态过渡到休息状态。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_159",
      "target_id": "word_159",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“一整天”在语境中实际指代从早到晚连续不断的工作时段，强调时间漫长和强度大。其语用功能是强化疲惫感的程度，表达说话人对工作负担的抱怨和渴望休息的迫切心情。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_160",
      "target_id": "word_160",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在“一整天的工作”中，“的”用于连接定语“一整天”和中心语“工作”，强调工作持续的时间长度，突出疲惫感的累积过程，从而强化了后续“疲惫不堪”和“只想回家”的情感表达。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_161",
      "target_id": "word_161",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“工作”在此语境中实际指代一系列具体的办公室事务，如整理文件、处理邮件、使用电脑等脑力劳动。它承担了表达疲惫原因和推动“回家休息”这一结果的语用功能，暗示了工作强度大、持续时间长。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_162",
      "target_id": "word_162",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "让在此语境中表示“致使、使得”，引出前因（一整天的工作）与后果（感到疲惫不堪），承担因果关系的语用功能，强调工作对主体状态的直接影响。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_163",
      "target_id": "word_163",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“我”在语境中实际指代叙述者自身，承担了表达主观感受和推动叙事进程的语用功能，通过强调个人疲惫状态和急切归家的意愿，自然引出后续整理文件、关电脑等具体行动。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_164",
      "target_id": "word_164",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“感到”在此语境中实际含义是“产生并承受某种身心状态”，语用功能是强调工作带来的强烈疲惫感，为后续“只想回家休息”的迫切心情提供情感铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_165",
      "target_id": "word_165",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语在当前语境中实际指因长时间高强度工作导致身体和精神极度疲劳的状态，语用功能是强调劳累程度，为后续“想回家休息”的行为提供情感和逻辑上的合理铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_166",
      "target_id": "word_166",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“只想”在语境中表达说话人强烈的渴望和迫切的心情，强调在疲惫状态下对回家休息这一行为的唯一期待。其语用功能是突出情感上的疲惫与对解脱的向往，推动读者理解主人公结束工作的急切心理。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_167",
      "target_id": "word_167",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“快点”在语境中实际表达说话人因疲惫而急切希望结束当前状态、尽快获得休息的迫切心情，其语用功能是强化情感并推动行动，暗示对解脱的渴望。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_168",
      "target_id": "word_168",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“回家”在此语境中实际含义是回到私人居住空间以获得身心恢复，它承担了表达强烈休息愿望和推动从工作状态向放松状态转换的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_169",
      "target_id": "word_169",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“休息”在语境中实际指结束工作状态、通过回家放松来恢复体力与精神，承担表达迫切渴望解脱劳累、暗示工作已完成的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_170",
      "target_id": "word_170",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“就”在句中强调时间上的紧迫性和巧合性，突出“准备离开”与“领导叫住”几乎同时发生，推动情节转折，暗示意外打断的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_171",
      "target_id": "word_171",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句中强调动作发生的时间点非常紧迫或关键，起到突出转折和增强情节张力的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_172",
      "target_id": "word_172",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”不仅指说话者本人，更通过第一人称视角强化了叙述的主观体验，暗示了说话者疲惫、渴望休息的心理状态，同时为后文领导突然叫住“我”这一情节转折埋下伏笔。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_173",
      "target_id": "word_173",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“准备”实际含义是“正打算、正要去做”，强调动作即将发生但尚未完成。它在语境中承担推动情节转折的功能，暗示“离开”这一行为被突然打断，为后续领导的询问制造了时间上的衔接点。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_174",
      "target_id": "word_174",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“离开”的实际含义是结束当天的工作状态、下班回家休息，语用功能是推动情节转折，暗示主人公即将脱离工作环境，为领导叫住他制造悬念。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_175",
      "target_id": "word_175",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“时”在这里表示一个特定的时间点，即“准备离开”的那个瞬间，语用功能是衔接前后动作，推动情节发展，暗示事件发生的突然性。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_176",
      "target_id": "word_176",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“领导”实际指的是说话人的上级或管理者，承担了推动情节发展的语用功能，暗示了可能被临时安排工作或社交任务，从而加剧了说话人疲惫与无奈的情绪。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_177",
      "target_id": "word_177",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“叫住”在此语境中实际含义是领导主动中断“我”的离开动作，以进行后续询问或安排，带有一种临时、带有目的性的阻止。其语用功能是推动情节转折，暗示可能有额外任务或社交要求，与“只想回家休息”的疲惫心理形成冲突。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_178",
      "target_id": "word_178",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“了”在句中表示动作“叫住”已经完成，强调事件在“准备离开”的时间点上已经发生，推动情节从准备离开转向被领导叫住的转折，暗示后续可能有事发生。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_179",
      "target_id": "word_179",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”不仅指说话者本人，更通过第一人称视角强化了疲惫、无奈的个人感受，同时为下文领导突然打断的情节转折做铺垫，暗示了说话者身不由己的处境。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_180",
      "target_id": "word_180",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“问”并非单纯询问信息，而是领导在试探或暗示可能另有安排（如加班或应酬），带有潜在的指令或社交压力。语用功能是推动情节转折，暗示主人公的休息计划可能受阻。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_181",
      "target_id": "word_181",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”不仅指说话者本人，还隐含了疲惫、渴望解脱的情绪，以及被领导突然叫住时产生的紧张与无奈。它在语境中推动情节转折，暗示了个人计划可能被打断的潜在冲突。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_182",
      "target_id": "word_182",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“晚上”实际指下班后的私人时间，而非单纯的时间段。它承担了试探和邀约的语用功能，暗示领导可能有额外的工作安排或社交要求，从而推动情节向“无法立即回家”的方向发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_183",
      "target_id": "word_183",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“有”的实际含义是询问是否存在“已有其他计划或活动安排”，语用功能是委婉探询对方的时间占用情况，为后续可能提出的邀约或任务做铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_184",
      "target_id": "word_184",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“没有”在此语境中并非询问是否存在安排，而是领导试探性地询问对方是否愿意或方便接受新的任务或邀约，隐含了希望对方配合的意图。其语用功能是委婉地开启话题，为后续提出要求或邀请做铺垫，同时给说话人留出拒绝的余地。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_185",
      "target_id": "word_185",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "领导问“晚上有没有安排”，实际含义是询问我晚上是否有其他计划或应酬，暗示可能想给我布置额外工作或安排任务。该词语在此承担试探和铺垫的语用功能，为后续可能的加班要求做铺垫。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_186",
      "target_id": "word_186",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”指叙述者自己，即被领导叫住并感到紧张的那个人。它在语境中承担了确立叙述视角和表达主观感受的语用功能，通过第一人称直接传递出当事人的心理状态，推动情节向“如实回答”发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_187",
      "target_id": "word_187",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“有些”在句中表示程度轻微，缓和了“紧张”的语气，体现出说话人试图保持镇定、不愿显得过于慌乱的心理状态，同时为后文“如实回答”做铺垫，暗示了面对领导时的谨慎与克制。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_188",
      "target_id": "word_188",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "紧张在这里指说话人面对领导突然询问时产生的忐忑不安、心理压力大的情绪状态，表达出说话人因意外被问话而感到局促和担忧的内心感受。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_189",
      "target_id": "word_189",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "但在这里表示转折，强调尽管内心紧张，仍然选择如实回答，体现出说话人克服情绪、坚持诚实的态度。其语用功能是突出前后行为的对比，暗示回答的真诚与不易。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_190",
      "target_id": "word_190",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“还是”在句中表示转折，强调尽管存在紧张情绪，但说话人克服了心理障碍，选择了如实回答。其语用功能是突出行为选择上的矛盾与最终决定，暗示说话人面对压力时的诚实态度，推动情节展现人物内心的挣扎与行动。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_191",
      "target_id": "word_191",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "如实在这里的实际含义是“坦诚地、不加隐瞒地”，即使内心紧张，仍然选择说出真实情况。它的语用功能是体现说话人在压力下坚持诚实的态度，并暗示回答内容可能涉及个人真实安排或不便透露的信息。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_192",
      "target_id": "word_192",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“回答”指针对领导询问“晚上有没有安排”这一具体问题给出真实回应，承担了推动情节发展的语用功能，同时隐含了说话人因紧张而谨慎应对的态度。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_193",
      "target_id": "word_193",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "领导在这里指代说话人的上级管理者或直接上司，承担了指示权威和推动情节的功能，暗示了对方拥有批准下班的权力并表现出友善态度。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_194",
      "target_id": "word_194",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "领导用笑容缓和了紧张气氛，表达对下属的认可与安抚，同时暗示同意是出于宽容而非完全满意。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_195",
      "target_id": "word_195",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "领导用笑容和催促的语气表达认可，实际含义是批准并催促离开，语用功能是缓解紧张气氛并体现关怀。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_196",
      "target_id": "word_196",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“我”在语境中实际指代说话者本人，承担了叙事视角的定位功能，通过第一人称叙述强化了紧张与服从的代入感，同时暗示了说话者作为下属的被动身份。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_197",
      "target_id": "word_197",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“下班”在句中实际含义是领导允许我结束工作离开岗位，带有一种解脱和获得许可的意味，同时暗示了紧张氛围的缓解。其语用功能是推动情节从紧张转向轻松，并表达出领导对我的体谅和催促。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_198",
      "target_id": "word_198",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句中“并”表示递进关系，连接领导的两个连续动作，语用功能是推动情节发展，使叙述更连贯自然。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_199",
      "target_id": "word_199",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "该语境中“让”的实际含义是“允许、同意”，并带有上级对下级的指令性语用功能，暗示领导以亲切口吻催促对方离开，同时缓解了前文“紧张”的氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_200",
      "target_id": "word_200",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“我”在语境中实际指代说话者本人，承担了明确叙述主体、推动情节发展的语用功能，暗示了说话者作为事件参与者的紧张与顺从。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_201",
      "target_id": "word_201",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "领导用“赶紧”表达了一种带有催促意味的关心，既暗示希望我迅速离开以避免尴尬或进一步追问，也传递出对我紧张情绪的体谅和放行后的轻松态度。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_202",
      "target_id": "word_202",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“回家”在语境中实际含义是“结束工作、离开办公室”，语用功能是表达领导对下属的体谅与催促，暗示谈话结束、允许对方脱离工作状态。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_203",
      "target_id": "word_203",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”在语境中实际指代一个因得到领导许可而如释重负、心情愉悦的下班员工，承担了表达个人情感状态和推动情节从紧张到放松转变的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_204",
      "target_id": "word_204",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "顿时在此语境中表示在领导同意下班的瞬间，心理压力立即解除，强调情绪转变的迅速和彻底。其语用功能是突出从紧张到放松的即时情感变化，并推动情节向轻松愉快的方向过渡。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_205",
      "target_id": "word_205",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“松了”在句中实际指紧张或担忧的情绪得到缓解，不再感到压力。它表达了人物从紧绷状态转为放松的心理变化，推动情节从焦虑转向轻松，并暗示了之前可能存在的顾虑或不安。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_206",
      "target_id": "word_206",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“一口气”在句中实际指紧张情绪突然解除后的轻松感，语用功能是表达如释重负的情感，并暗示之前处于压力或担忧状态。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_207",
      "target_id": "word_207",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“开心地”在句中实际表达的是如释重负后的轻松与满足，因为领导同意下班而心情愉悦。其语用功能是强化主人公从紧张到放松的情绪转折，并暗示对下班回家的期待。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_208",
      "target_id": "word_208",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“准备”在此语境中实际含义是“打算、将要”，表达说话人因获得许可而立即采取离开公司这一行动。其语用功能是体现说话人如释重负后的轻松心情，并推动情节从“被允许下班”过渡到“实际离开”。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_209",
      "target_id": "word_209",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“离开”实际指结束当天工作、获准下班回家，承担了表达轻松解脱感和推动情节收尾的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_210",
      "target_id": "word_210",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“公司”实际指代的是“工作场所”或“办公室”，而非抽象的法人实体。它承担了表达“下班离开工作环境”的语用功能，暗示了从工作状态到个人时间的转换，并配合上下文传递出轻松、解脱的情感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_211",
      "target_id": "word_211",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“我”在句中不仅是叙述主体，更通过连续动作的描写，暗示了说话人从紧张状态中解脱、急于离开的轻松心情，承担了推动情节和表达情感变化的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_212",
      "target_id": "word_212",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“先”表示动作的先后顺序，强调“坐电梯下楼”是后续一系列动作的第一步，在叙事中起到理清时间线索、推动情节发展的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_213",
      "target_id": "word_213",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在该语境中，“坐”的实际含义是“搭乘、乘坐”电梯，而非“坐下”的动作。它承担了叙述动作顺序的语用功能，推动情节自然过渡到下一行为。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_214",
      "target_id": "word_214",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "电梯在此语境中实际指代从公司楼层下到一楼的垂直交通工具，其语用功能是衔接动作顺序，暗示主人公离开公司的过程顺利且自然，为后文“松了一口气”和“开心地离开”提供合理过渡。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_215",
      "target_id": "word_215",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "下楼在此语境中实际指完成工作后离开公司大楼的动作，语用功能是推动情节发展，暗示主人公结束工作任务、准备离开的轻松状态。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_216",
      "target_id": "word_216",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“去”在这里表示完成了一个短暂的动作过程，强调“前往洗手间并返回”的完整事件，语用功能是衔接动作顺序，推动叙事节奏，暗示主人公在离开公司前完成了必要的准备。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_217",
      "target_id": "word_217",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“了”在此处表示动作的完成和事件的时间顺序，语用功能是推动叙事进程，使“去洗手间”成为已发生的环节，为后续“走出大楼”铺垫连贯的动作序列。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_218",
      "target_id": "word_218",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“趟”在这里表示去洗手间的一次往返过程，强调动作的短暂和顺便，语用功能是自然衔接叙事节奏，暗示离开前的常规准备动作，使情节推进更流畅。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_219",
      "target_id": "word_219",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "该词语在语境中实际指代“离开公司前的最后一项常规动作”，暗示主人公在紧张情绪解除后，通过去洗手间进行短暂的自我调整或确认状态，为顺利离开公司做铺垫。其语用功能是推动情节自然过渡，并含蓄表达主人公从紧张到放松的心理转变。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_220",
      "target_id": "word_220",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中，“然后”表示时间上的先后顺序，连接“去洗手间”和“走出大楼”两个连续动作，语用功能是推动叙事进程，使事件描述自然流畅。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_221",
      "target_id": "word_221",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "快步在这里的实际含义是带着轻松、急切的心情迅速行走，语用功能是表现人物如释重负后的愉悦与迫不及待离开的状态，推动情节从紧张转向解脱。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_222",
      "target_id": "word_222",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“走出”在此语境中实际含义是“离开公司大楼并摆脱工作环境”，语用功能是暗示主人公完成工作后如释重负、获得解脱的情感转折，推动情节从紧张到放松的过渡。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_223",
      "target_id": "word_223",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "大楼在这里指代公司所在的办公楼，暗示主人公刚刚离开工作场所，完成了从公司环境到外部空间的转换，推动情节从紧张状态过渡到放松离开。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_224",
      "target_id": "word_224",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“站”在这里的实际含义是“停下脚步、停留在某处”，语用功能是描述人物在做出打车决定前的短暂停顿，暗示了观察和思考的过程，推动情节从行走转向决策。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_225",
      "target_id": "word_225",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中表示“处于某个位置或状态”，具体指“我”的身体位置固定在路边这一空间点。语用功能是交代动作发生的静态背景，为后续“看着”“决定”等动态行为提供空间参照，推动情节从移动（下楼、走路）转向观察与决策。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_226",
      "target_id": "word_226",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“路边”实际指大楼出口附近的人行道或街道边缘，暗示说话人已离开大楼、置身户外，为后续“打车”这一行动提供了空间前提，同时通过对比地铁入口的拥挤，强化了选择打车的合理性，推动情节从室内转向室外并做出交通决策。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_227",
      "target_id": "word_227",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”不仅指叙述者本人，还通过第一人称视角强化了叙述的主观体验，暗示叙述者从大楼内部走向外部空间后，对拥挤环境产生了即时判断与决策，推动情节从“观察”转向“行动”。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_228",
      "target_id": "word_228",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“看着”在此语境中表示“观察、注视”的动作，但更强调说话人短暂停留、做出判断的过程，语用上起到衔接前后动作、暗示决策依据的作用，即通过观察地铁入口的拥挤状况，自然引出“决定打车”的结果。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_229",
      "target_id": "word_229",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "拥挤在这里指地铁入口处人流量大、人群密集，暗示了作者因不愿挤入人群而选择打车，推动了从“打算坐地铁”到“打车回家”的决策转变。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_230",
      "target_id": "word_230",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“的”在句中作为定语标记，连接“拥挤”与“地铁入口”，具体描绘出入口的拥堵状态，为后续“决定打车”提供直观的因果铺垫，推动叙事逻辑。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_231",
      "target_id": "word_231",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "地铁在这里实际指代的是地铁站入口，而非交通工具本身。语用功能是通过“拥挤的地铁入口”这一景象，暗示晚高峰时段人流量大、乘车体验不佳，从而为“决定打车”提供合理动机，推动情节自然过渡。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_232",
      "target_id": "word_232",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在地铁站的物理通道口，指乘客进入地铁站的特定位置，暗示此处人流密集、通行缓慢，为下文“打车回家”的决定提供理由。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_233",
      "target_id": "word_233",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“决定”的实际含义是“经过观察和思考后临时做出的选择”，语用功能是推动情节转折，暗示说话人因为看到地铁入口拥挤而改变了原本可能乘坐地铁的计划，选择了打车。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_234",
      "target_id": "word_234",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "表示经过权衡后做出的最终选择，强调在“地铁”和“打车”之间，说话人倾向于后者。语用功能是表达一种决定或让步，暗示之前可能考虑过地铁但最终放弃。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_235",
      "target_id": "word_235",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "打车在当前语境中实际含义是乘坐出租车或网约车，而不是泛指叫车行为。该词语承担了推动情节发展的语用功能，表明说话人因嫌地铁拥挤而临时改变交通方式，暗示了决策的即时性和对舒适度的考量。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_236",
      "target_id": "word_236",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“回家”在语境中实际指回到自己居住的住所，而非泛指返回家庭或家乡。它承担了推动情节发展的语用功能，表明说话人结束外出活动、选择交通工具返回住所的决策。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_237",
      "target_id": "word_237",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”指代叙述者自身，承担第一人称视角的叙事功能，通过具体行为（用手机确认路线、上出租车）推动情节发展，暗示叙述者是一个主动规划、偏好高效出行方式的现代都市人。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_238",
      "target_id": "word_238",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“用”的实际含义是“借助、通过”，表示手机作为工具或媒介来完成确认路线这一动作。它的语用功能是明确行为方式，推动情节从“决定打车”到“上车”之间的具体操作步骤。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_239",
      "target_id": "word_239",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“手机”的实际含义是指具有导航功能（如地图或路线查询）的智能设备，用于完成“确认回家路线”这一具体任务。它的语用功能是推动情节发展，解释“我”选择打车的原因——通过手机得知路线后，决定避开拥挤的地铁。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_240",
      "target_id": "word_240",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“确认”的实际含义是指通过手机地图或导航软件查看并核实回家的路线，确保方向正确。它承担了推动情节的语用功能，表明主角在做出打车决定前已做好路线准备，暗示了谨慎和计划性。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_241",
      "target_id": "word_241",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“了”在句中表示动作的完成和实现，强调“确认路线”和“上出租车”这两个动作已经发生，推动叙事从决定打车到实际执行的过程。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_242",
      "target_id": "word_242",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“回家”在语境中实际指从当前所在的路边地点返回自己的住处，语用功能是明确行动目的，推动从“决定打车”到“上车”的情节发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_243",
      "target_id": "word_243",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“的”在句中用于连接定语“回家”和中心语“路线”，表示路线与回家之间的归属或关联关系，语用功能是明确所指，使信息表达更清晰自然。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_244",
      "target_id": "word_244",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“路线”在语境中实际指手机导航规划出的从当前位置到家的具体行车路径。它承担了推动情节的功能，说明“我”已经明确了行程方向，为后续打车的决定提供了合理依据。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_245",
      "target_id": "word_245",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句中，“然后”表示时间上的先后顺序，连接“确认路线”和“上车”两个连续动作，语用功能是推动叙事进程，使事件描述自然流畅。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_246",
      "target_id": "word_246",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“上”的实际含义是“乘坐、进入”出租车，语用功能是简洁地描述完成打车动作，推动情节从“决定打车”过渡到“乘车出发”的下一步行动。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_247",
      "target_id": "word_247",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“了”在句中表示动作的完成和状态的实现，强调“确认路线”和“上出租车”这两个动作已经发生，从而推动叙事从“决定打车”进入实际行动阶段，使情节自然衔接。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_248",
      "target_id": "word_248",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“一辆”在语境中实际指代的是“任意一辆”出租车，而非特指某辆具体的车，语用功能是自然叙述打车动作，推动情节从决定打车过渡到乘车行为。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_249",
      "target_id": "word_249",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“出租车”实际指的是通过手机叫车服务预约到的网约车，而非传统意义上的路边扬招出租车。它承担了推动情节的功能，表明说话人放弃了拥挤的地铁，选择了更便捷舒适的出行方式。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_250",
      "target_id": "word_250",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“一路上”在语境中实际指从上车到到家之间的整个行程过程，包括遇到红灯等具体路况。它承担了概括叙述行程经历、并暗示尽管有小阻碍但整体顺利的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_251",
      "target_id": "word_251",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "虽然在这里的实际含义是弱化红灯带来的阻碍，强调结果顺利。它的语用功能是表达一种轻描淡写的转折，暗示红灯并未造成实际影响，从而突出回家的顺利。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_252",
      "target_id": "word_252",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“遇到”在语境中实际指“碰到、经历”红灯这一交通状况，但结合“虽然……还是……”的转折结构，它暗示了红灯并未对行程造成实质阻碍，语用功能是强调顺利结果、弱化小波折，推动情节向“顺利到家”发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_253",
      "target_id": "word_253",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "了在句中表示动作的完成或状态的变化，强调“确认路线”和“上出租车”这两个动作已经实现，推动叙事进展，使事件描述更加完整自然。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_254",
      "target_id": "word_254",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "红灯在句中指交通信号灯的红灯，表示车辆需停车等待的指令。该词语通过描述途中遇到的正常交通状况，暗示行程虽有短暂停顿但整体顺利，起到缓和语气、衬托“顺利到家”结果的作用。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_255",
      "target_id": "word_255",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "虽然表示转折，但实际弱化了“遇到红灯”这一障碍的影响，强调结果“顺利到家”的意外性，起到缓和语气、突出顺利结局的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_256",
      "target_id": "word_256",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”指代叙述者自身，在语境中承担了推动情节发展的主体角色，通过“我”的视角串联起确认路线、乘坐出租车和遇到红灯后顺利回家的完整经历，同时隐含了叙述者对自己顺利归家的轻微庆幸或强调。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_257",
      "target_id": "word_257",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“还是”在句中表示尽管存在红灯这一阻碍因素，但最终结果依然如预期实现，语用功能是强调克服困难后的顺利结果，暗示一种庆幸或如释重负的情感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_258",
      "target_id": "word_258",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“顺利”在语境中实际表示尽管遇到红灯这一小阻碍，但整体行程没有遇到其他麻烦，最终按时到家，强调过程基本顺畅。其语用功能是弱化红灯带来的短暂停顿，突出结果上的满意和轻松感，暗示实际体验比预期更省心。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_259",
      "target_id": "word_259",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "地在这里表示一种转折关系，实际含义相当于“虽然……但是……”中的“但是”，语用功能是强调尽管遇到红灯阻碍，但最终结果仍然顺利，突出意外中的顺利感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_260",
      "target_id": "word_260",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“回到”在句中实际含义是“抵达并进入家中”，强调完成从外部空间向家这一目的地的移动过程。其语用功能是推动情节收束，暗示出行任务顺利结束，并传递出安全、安心的情感色彩。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_261",
      "target_id": "word_261",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "了在句中表示动作或状态的完成，语用功能是强调“确认路线”这一行为已经结束，为后续“上出租车”和“回家”提供前提，推动情节发展。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_262",
      "target_id": "word_262",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个语境中，“家”指的是说话者居住的住所，强调的是一个具体的物理空间和目的地，承担了推动情节发展的功能，表明行程的终点。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_263",
      "target_id": "word_263",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“凌晨”在这里并非指实际时间，而是暗示梦境与现实的时间错位，强调梦境开始于一个本应清醒或结束睡眠的时刻，从而营造出超现实的氛围，推动下文梦境情节的展开。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_264",
      "target_id": "word_264",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "凌晨五点在这里不是指具体时间，而是暗示梦境开始的时间点，与后文“一路上”形成时间上的跳跃，推动从现实进入梦境的过渡。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_265",
      "target_id": "word_265",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”并非指说话者本人，而是指梦境中的“我”，即叙述者在梦中的化身。它承担了区分现实与梦境的语用功能，暗示后续情节发生在虚构的梦境世界中。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_266",
      "target_id": "word_266",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“开始”并非指梦境的起始，而是暗示叙述者从凌晨五点起便陷入一种恍惚或回忆状态，实际是在描述一种似梦非梦的体验。它承担了模糊现实与梦境界限的语用功能，为后文“顺利回家”的异常顺利埋下伏笔。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_267",
      "target_id": "word_267",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“做梦”并非指睡眠中的梦境，而是表达一种不切实际的幻想或奢望，暗示在凌晨五点这样不现实的时间点，却幻想能顺利回家。该词语在语境中承担了反讽的语用功能，通过表面肯定实际否定的方式，暗示现实中的阻碍（如红灯）并未真正被克服。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_268",
      "target_id": "word_268",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦里在此语境中表示梦境这一虚拟时空的起点，语用功能是设定叙述框架，将后续内容明确标记为梦中的非现实体验，从而区分于现实世界。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_269",
      "target_id": "word_269",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境叙述中，“我”指代做梦者自身，承担叙事主体的功能，将虚幻的梦境体验与说话人的主观感受联结起来，使听者能代入其第一视角的历程。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_270",
      "target_id": "word_270",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境叙述中，“走了”实际指梦中的移动或行进，而非现实中的离开；它承担推动梦境情节发展的语用功能，暗示梦者进入一个连贯的虚拟空间体验。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_271",
      "target_id": "word_271",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境语境中，“很长的路”实际暗示了梦者心理上的漫长探索或潜意识中的过渡过程，并非物理距离。它承担了推动梦境叙事、营造虚幻与真实交织氛围的语用功能，同时暗示梦者可能经历了某种精神上的跋涉或等待。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_272",
      "target_id": "word_272",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境叙述中，“看到了”并非指真实的视觉感知，而是指梦境中浮现出闪电这一意象，承担了推进梦境情节、营造画面感的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_273",
      "target_id": "word_273",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "闪电在梦境语境中象征一种突如其来的启示或转折，暗示梦者内心经历了一次强烈的情绪或认知冲击，推动情节从长途跋涉过渡到进入房子的关键变化。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_274",
      "target_id": "word_274",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境叙述中，“然后”不仅表示时间上的先后顺序，更承担了推动情节自然过渡的语用功能，使梦境的片段式体验显得连贯而真实。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_275",
      "target_id": "word_275",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境语境中，“走进”实际表示从外部空间进入房屋内部的动作，但带有虚幻、非现实的意味，语用功能是推动梦境情节从自然场景向室内场景转换，暗示梦境的延续和场景切换。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_276",
      "target_id": "word_276",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句中，“了”表示动作的完成或状态的实现，语用功能是推动梦境叙事，使“走”“看”“走进”这些动作在时间上连贯递进，营造出梦境中事件依次发生的真实感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_277",
      "target_id": "word_277",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境语境中，“一栋房子”并非指具体建筑，而是象征心理上的庇护所或未知的转折点，暗示梦者进入了一个新的心理空间或潜在记忆区域。它承担了推动梦境叙事从外部景象转向内部探索的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_278",
      "target_id": "word_278",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”指代梦中的主体，承担叙事视角功能，通过第一人称叙述强化梦境体验的真实感和沉浸感，同时暗示主体在循环空间中的困惑与无力。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_279",
      "target_id": "word_279",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中表示持续进行某种动作或状态，强调“转来转去”这个行为没有中断，配合“一直”强化了循环往复的单调感和困顿感，推动梦境中迷茫、被困住的氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_280",
      "target_id": "word_280",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“房子”实际指代梦境中一个封闭、令人困惑的空间，象征着内心的困境或思维的死循环。它承担了暗示心理状态和推动情节发展的语用功能，通过物理空间的局限感来映射主人公的迷茫与重复体验。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_281",
      "target_id": "word_281",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“里”在这里指梦境中房子的内部空间，强调被困在封闭环境中的主观感受，暗示梦境的压抑和循环感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_282",
      "target_id": "word_282",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“转来转去”在句中表示在房子里无目的地来回走动，结合梦境上下文，暗示一种被困在封闭空间、无法找到出口或突破的迷茫与焦虑感。其语用功能是强化梦境中循环往复、难以摆脱的心理体验，推动情节从外部空间（长路、闪电）转向内部空间的压抑氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_283",
      "target_id": "word_283",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“感觉”表达的是说话人在梦境中产生的一种主观体验和认知判断，即意识到自己在房子里不断重复同样的路径或状态。它的语用功能是揭示梦境的非现实性和循环感，暗示一种被困住或无法摆脱的心理状态。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_284",
      "target_id": "word_284",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境语境中，“一直”强调主观感受上的持续无间断，暗示迷惘与困顿，推动情节营造出压抑、循环的梦境氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_285",
      "target_id": "word_285",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“在”表示动作正在进行，强调“转来转去”这一行为持续发生，同时与后文“一直循环往复”呼应，暗示梦境中的困顿感和无进展的状态，推动了对梦境的压抑氛围的渲染。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_286",
      "target_id": "word_286",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语在语境中实际指在房子里无意义地来回走动，暗示梦境中迷失方向、被困住的心理状态。语用功能是表达迷茫与焦虑，并推动梦境情节的压抑感。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_287",
      "target_id": "word_287",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“接着”在这里表示时间上的顺承，推动叙事从之前“在房子里转来转去”的循环状态转向新的行动和场景变化，暗示情节的推进和空间的转换。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_288",
      "target_id": "word_288",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”是叙事主体，承担第一人称视角的叙述功能，通过“我”的所见所感推动情节从室内循环转向户外空间的转换，暗示了叙事者从压抑到开阔的心理变化。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_289",
      "target_id": "word_289",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个句子中，“坐”的实际含义是“搭乘、乘坐”交通工具，而不是“坐下”的动作。它承担了推动情节发展的语用功能，表明叙述者从地面状态进入空中旅程的转折点。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_290",
      "target_id": "word_290",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“上”在句中表示从地面进入飞机内部的动作，以及从地面升入空中的空间位移，语用功能是推动情节发展，描述从地面到空中的动态过程，暗示了视角的转换和场景的展开。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_291",
      "target_id": "word_291",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“了”在句中表示动作的完成和状态的实现，语用功能是推动叙事进程，将一系列连续动作（坐、飞、看）按时间顺序呈现，使情节从“循环往复”的静态感转向动态展开。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_292",
      "target_id": "word_292",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在这个句子中，“飞机”的实际含义是作为运输工具，帮助叙述者从封闭的室内空间（循环往复的房子）转移到开阔的天空场景，从而打破之前的压抑感。它的语用功能是推动情节转折，暗示叙述者从困顿状态进入自由、开阔的体验。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_293",
      "target_id": "word_293",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“飞”在句中指乘坐飞机升入空中，实际含义是“通过航空器实现空间位置的快速移动”；语用功能是推动情节从室内场景转向高空视野，暗示视角的转换和叙事的递进。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_294",
      "target_id": "word_294",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“到”在这里表示动作的完成和空间的转移，强调从地面到达天空这一过程，语用功能是推动情节发展，使叙述从室内场景自然过渡到空中体验。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_295",
      "target_id": "word_295",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“了”在句中表示动作的完成和状态的实现，语用功能是推动叙事进程，将一系列连续动作（坐、飞、看）依次呈现，使情节从“循环往复”的静态描述转向动态发展，暗示叙述者已脱离原地打转的状态，进入新的空间体验。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_296",
      "target_id": "word_296",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“天上”在句中实际指飞机飞行时所在的高空区域，而非神话或抽象概念。它承接前文“坐上飞机”，具体描述飞行途中的空间位置，推动情节从室内转向空中场景的转换。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_297",
      "target_id": "word_297",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“看到”在此语境中实际含义是“想象中或回忆中的视觉体验”，而非真实的视觉感知。它承担了推动情节从室内循环的压抑感转向开阔天空的转折功能，暗示主人公通过想象或回忆逃离现实困境。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_298",
      "target_id": "word_298",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“了”在句中表示动作的完成和状态的实现，语用功能是推动叙事进程，将一系列连续发生的动作（坐、飞、看）串联起来，形成完整的情节推进。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_299",
      "target_id": "word_299",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "云朵在句中指代飞机窗外真实的自然景物，与热气球并列，共同构成飞行途中的视觉体验，推动情节从室内循环转向户外开阔场景的过渡。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_300",
      "target_id": "word_300",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“和”在此处连接“云朵”与“热气球”，表示并列列举，语用功能是补充说明所见景物，推动叙述从地面转向空中视野的展开。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_301",
      "target_id": "word_301",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "热气球在这里并非指真实的飞行器，而是与云朵并列的意象，暗示主人公在循环中产生的幻觉或梦境感，推动情节从现实转向超现实的心理空间。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_302",
      "target_id": "word_302",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这里的“我”并非指代真实的说话人，而是指梦境或幻想中的主体，承担了将现实与幻想衔接的语用功能，暗示叙述已从现实场景转入超现实的梦境叙事。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_303",
      "target_id": "word_303",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中，“坐”的实际含义是“乘坐”，指通过热气球这一交通工具进行空中移动。它承担了推动情节发展的语用功能，引出后续“飞向太阳”和“做梦”的幻想性叙述。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_304",
      "target_id": "word_304",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "热气球在句中指代一种梦幻的飞行工具，与太阳、做梦相连，暗示脱离现实、进入幻想或超现实体验，推动情节从现实场景转向梦境。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_305",
      "target_id": "word_305",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“飞向”在语境中实际指乘坐热气球朝太阳方向移动，带有梦幻和超现实的意味，语用功能是推动情节从现实过渡到幻想，暗示主人公进入梦境或想象世界。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_306",
      "target_id": "word_306",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“太阳”并非指实际的天体，而是象征一个遥远、理想或虚幻的目标，与“做梦”呼应，暗示一种脱离现实的浪漫或幻想状态，推动情节从现实观察转向超现实的梦境体验。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_307",
      "target_id": "word_307",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“然后”在这里表示从现实场景（坐热气球飞向太阳）到虚幻场景（又开始做梦）的转折，承担了推动情节从现实过渡到幻想的语用功能，暗示后续内容可能是梦境或想象。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_308",
      "target_id": "word_308",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“又”在这里表示动作的重复或状态的延续，暗示主人公在飞向太阳的奇幻经历之后，再次进入梦境，推动情节从现实或幻想过渡到更深层的虚幻体验。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_309",
      "target_id": "word_309",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“开始”在这里表示从现实体验（坐热气球飞向太阳）转入虚幻或超现实的想象状态，语用功能是标记情节从具体经历跳跃到梦境或幻想，暗示现实与梦境的交织。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_310",
      "target_id": "word_310",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "“做梦”在这里指脱离现实的幻想或想象，与前面“坐热气球飞向太阳”的荒诞情节呼应，暗示叙述者意识到自己正在经历不真实的情景，起到推动情节转折、表达超现实感的作用。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_311",
      "target_id": "word_311",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦里表示梦境作为背景或场景，语用功能是设定叙述的虚拟空间，暗示后续内容并非现实，推动情节进入幻想层面。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_312",
      "target_id": "word_312",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在语境中，“梦里”指代一种超脱现实、充满幻想与自由联想的心理空间，推动情节从热气球飞行过渡到更奇幻的视觉画面，暗示叙述者正沉浸于主观想象或潜意识活动。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_313",
      "target_id": "word_313",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境叙述中，“我”指代做梦者本人，承担叙事主体的功能，通过第一人称视角将一系列超现实意象串联起来，推动情节从现实过渡到幻想场景。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_314",
      "target_id": "word_314",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境语境中，“看到”并非指真实的视觉感知，而是指梦中浮现或呈现的虚幻景象，承担了区分梦境与现实、推动叙事从现实过渡到幻想世界的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_315",
      "target_id": "word_315",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句中，“了”表示动作“看到”已经完成，强调梦境中视觉体验的实现，语用功能是确认和收束对梦境内容的列举，推动叙述从梦境场景转向后续情节。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_316",
      "target_id": "word_316",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境语境中，太阳象征热气球飞行的目标或终点，承担推动梦幻情节发展的功能，暗示一种向往或虚幻的追求。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_317",
      "target_id": "word_317",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境语境中，房子不再是具体的居住建筑，而是象征安全、归属或童年记忆的意象，与太阳、城堡等共同构成梦幻、美好且超现实的画面，推动梦境从自然景观向人文景观过渡，暗示内心对稳定与温暖的向往。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_318",
      "target_id": "word_318",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境语境中，“城堡”并非指真实建筑，而是象征童话般的幻想元素，与太阳、房子等共同构建超现实的浪漫场景，承担营造梦幻氛围、暗示逃离现实的语用功能。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_319",
      "target_id": "word_319",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境语境中，“汽车”并非指现实中的交通工具，而是作为超现实、碎片化意象的一部分，与太阳、城堡等并列，共同营造出奇幻、不连贯的梦境氛围，暗示了梦境中自由跳跃的联想与无逻辑的视觉元素组合。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_320",
      "target_id": "word_320",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句子中，“和”连接了多个并列的梦境意象，语用功能是列举收束，暗示梦境内容的丰富与完整，同时以“美丽的花朵”作为结尾，为梦境增添温暖美好的情感色彩。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_321",
      "target_id": "word_321",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在梦境语境中，美丽并非客观描述花朵的形态，而是表达梦者对花朵的主观愉悦感受，暗示梦境整体温馨、美好的情感基调，推动读者进入梦幻氛围。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
    },
    {
      "annotation_id": "ann_322",
      "target_id": "word_322",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在句中，“的”作为定语标记，连接“美丽”与“花朵”，强调花朵具有美丽这一属性，使梦境画面更具体生动，增强描述的细腻感和情感色彩。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
