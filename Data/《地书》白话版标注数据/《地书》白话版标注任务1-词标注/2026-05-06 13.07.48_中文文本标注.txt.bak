      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "词语“非常”在句中表示程度极高，强化了“惊讶”的情感，语用功能是突出主角在荒诞情境下夸张的意外感受，暗示情节的离奇与幽默。",
      "confidence": 0.85,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "词语在当前句中的语境含义。"
