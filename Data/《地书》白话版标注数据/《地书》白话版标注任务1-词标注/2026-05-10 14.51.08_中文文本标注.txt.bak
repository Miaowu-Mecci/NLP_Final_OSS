      "char_start": 109,
      "char_end": 133,
      "children": ["word_022", "word_023", "word_024", "word_025", "word_026", "word_027", "word_028"]
    },
    {
      "unit_id": "sent_004",
      "unit_type": "sentence",
      "text": "很快就到了下班时间，我打印完最后一点文件，准备离开公司。",
