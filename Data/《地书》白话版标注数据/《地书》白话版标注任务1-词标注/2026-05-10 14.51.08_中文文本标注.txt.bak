    },
    {
      "unit_id": "sent_005",
      "unit_type": "sentence",
      "text": "走出公司大楼，我拿出手机，找到那位女士的电话号码，拨了过去。",
      "sentence_index": 5,
      "char_start": 168,
      "char_end": 207,
      "children": ["word_039", "word_040", "word_041", "word_042", "word_043", "word_044", "word_045", "word_046", "word_047", "word_048", "word_049"]
    },
    {
      "unit_id": "sent_006",
      "unit_type": "sentence",
      "text": "电话接通后，她笑着问是谁。",
