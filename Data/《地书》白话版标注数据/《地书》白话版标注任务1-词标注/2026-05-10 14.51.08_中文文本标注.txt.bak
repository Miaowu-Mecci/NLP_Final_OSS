      "char_start": 224,
      "char_end": 249,
      "children": ["word_056", "word_057", "word_058", "word_059", "word_060", "word_061", "word_062", "word_063", "word_064"]
    },
    {
      "unit_id": "sent_008",
      "unit_type": "sentence",
      "text": "她在电话那头确认了时间，我高兴地答应了。",
      "sentence_index": 8,
      "char_start": 250,
