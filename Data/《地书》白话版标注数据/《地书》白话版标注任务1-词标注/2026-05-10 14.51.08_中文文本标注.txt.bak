      "char_start": 208,
      "char_end": 223,
      "children": ["word_050", "word_051", "word_052", "word_053", "word_054", "word_055"]
    },
    {
      "unit_id": "sent_007",
      "unit_type": "sentence",
      "text": "我笑着告诉她是我，并邀请她晚上一起见面。",
