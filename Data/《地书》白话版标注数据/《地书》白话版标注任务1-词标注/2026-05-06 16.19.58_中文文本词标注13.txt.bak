      "children": ["word_132", "word_133", "word_134", "word_135", "word_136", "word_137", "word_138", "word_139", "word_140", "word_141", "word_142", "word_143"]
    },
    {
      "unit_id": "sent_008",
      "unit_type": "sentence",
      "text": "我看着机票，想去旅行，忍不住笑了。",
      "sentence_index": 8,
      "char_start": 0,
      "char_end": 0,
      "children": ["word_144", "word_145", "word_146", "word_147", "word_148", "word_149", "word_150", "word_151", "word_152", "word_153"]
    },
    {
      "unit_id": "sent_009",
      "unit_type": "sentence",
      "text": "我想到我们结婚后去度蜜月，笑了。",
      "sentence_index": 9,
      "char_start": 0,
      "char_end": 0,
      "children": ["word_154", "word_155", "word_156", "word_157", "word_158", "word_159", "word_160", "word_161", "word_162", "word_163", "word_164", "word_165"]
    },
    {
      "unit_id": "sent_010",
      "unit_type": "sentence",
      "text": "我拿起手机给她发消息。",
      "sentence_index": 10,
      "char_start": 0,
      "char_end": 0,
      "children": ["word_166", "word_167", "word_168", "word_169", "word_170", "word_171", "word_172", "word_173", "word_174"]
    },
    {
      "unit_id": "sent_011",
      "unit_type": "sentence",
      "text": "我问她：\"结婚后想去哪度蜜月？\"她回：\"想去自由女神像，还有埃菲尔铁塔……\"",
      "sentence_index": 11,
      "char_start": 0,
      "char_end": 0,
      "children": ["word_175", "word_176", "word_177", "word_178", "word_179", "word_180", "word_181", "word_182", "word_183", "word_184", "word_185", "word_186", "word_187", "word_188", "word_189", "word_190", "word_191", "word_192", "word_193", "word_194", "word_195", "word_196", "word_197", "word_198", "word_199"]
    },
    {
      "unit_id": "sent_012",
      "unit_type": "sentence",
      "text": "电话响了，我看着机票，想去悉尼歌剧院、富士山、泰姬陵、加拿大、金字塔……最后选了美国。",
      "sentence_index": 12,
      "char_start": 0,
      "char_end": 0,
      "children": ["word_200", "word_201", "word_202", "word_203", "word_204", "word_205", "word_206", "word_207", "word_208", "word_209", "word_210", "word_211", "word_212", "word_213", "word_214", "word_215", "word_216", "word_217", "word_218", "word_219", "word_220", "word_221", "word_222", "word_223", "word_224", "word_225", "word_226", "word_227"]
    },
    {
      "unit_id": "sent_013",
      "unit_type": "sentence",
      "text": "美国的景点有白宫、迪士尼、梦露、体育馆、自由女神像、世贸中心。",
      "sentence_index": 13,
      "char_start": 0,
      "char_end": 0,
      "children": ["word_228", "word_229", "word_230", "word_231", "word_232", "word_233", "word_234", "word_235", "word_236", "word_237", "word_238", "word_239", "word_240", "word_241", "word_242", "word_243"]
    },
    {
      "unit_id": "sent_014",
      "unit_type": "sentence",
      "text": "我想到世贸中心被炸了，有点惊讶。",
      "sentence_index": 14,
      "char_start": 0,
      "char_end": 0,
      "children": ["word_244", "word_245", "word_246", "word_247", "word_248", "word_249", "word_250", "word_251", "word_252", "word_253"]
    },
    {
      "unit_id": "sent_015",
      "unit_type": "sentence",
      "text": "我查了去美国的航班、机场、酒店和攻略。",
      "sentence_index": 15,
      "char_start": 0,
      "char_end": 0,
      "children": ["word_254", "word_255", "word_256", "word_257", "word_258", "word_259", "word_260", "word_261", "word_262", "word_263", "word_264", "word_265"]
    },
