  "source_text": {
    "text_id": "text_001",
    "title": "失恋老友喝酒记",
    "source": "教师提供",
    "raw_text": "晚上九点，我接到了刚失恋的老友的电话，他让我过去陪他喝酒。我本想开车过去，但路上堵车非常严重，到处都是车，还遇到了红灯和车祸。我只能无奈地在车里等待，心里非常着急。好不容易回到家，我开始喝酒。不久，老友也来了，他告诉我他失恋了，心里很难过。我笑着安慰他，劝他不要再想那些不开心的事。我们一起喝酒，时间慢慢流逝。后来，老友要坐公交车回家，外面下起了雨。我在楼下等他，他问我是不是和那个女人分手了，是不是坐公交车。我告诉他是的，并且指向了天上的乌云。他说下雨了，没有太阳，还问我要不要伞。我同意了。我们在雨中等待公交车，他去了趟卫生间。等了很久，他终于出来了，还亲了我一下。我们继续喝酒，我感到非常开心。最后，他回家了，我一个人站在雨中，心里有些难过，不知道他什么时候才能走出失恋的阴影。",
    "notes": "按语义基元标注，每句话标注整体属性"
  },
  "units": [
    {
      "unit_id": "sent_001",
      "unit_type": "sentence",
      "text": "晚上九点，我接到了刚失恋的老友的电话",
      "sentence_index": 1,
      "char_start": 0,
      "char_end": 19,
      "children": []
    },
    {
      "unit_id": "sent_002",
      "unit_type": "sentence",
      "text": "他让我过去陪他喝酒",
      "sentence_index": 2,
      "char_start": 20,
      "char_end": 31,
      "children": []
    },
    {
      "unit_id": "sent_003",
      "unit_type": "sentence",
      "text": "我本想开车过去",
      "sentence_index": 3,
      "char_start": 32,
      "char_end": 39,
      "children": []
    },
    {
      "unit_id": "sent_004",
      "unit_type": "sentence",
      "text": "但路上堵车非常严重",
      "sentence_index": 4,
      "char_start": 40,
      "char_end": 51,
      "children": []
    },
    {
      "unit_id": "sent_005",
      "unit_type": "sentence",
      "text": "到处都是车",
      "sentence_index": 5,
      "char_start": 52,
      "char_end": 57,
      "children": []
    },
    {
      "unit_id": "sent_006",
      "unit_type": "sentence",
      "text": "还遇到了红灯和车祸",
      "sentence_index": 6,
      "char_start": 58,
      "char_end": 68,
      "children": []
    },
    {
      "unit_id": "sent_007",
      "unit_type": "sentence",
      "text": "我只能无奈地在车里等待",
      "sentence_index": 7,
      "char_start": 69,
      "char_end": 82,
      "children": []
    },
    {
      "unit_id": "sent_008",
      "unit_type": "sentence",
      "text": "心里非常着急",
      "sentence_index": 8,
      "char_start": 83,
      "char_end": 89,
      "children": []
    },
    {
      "unit_id": "sent_009",
      "unit_type": "sentence",
      "text": "好不容易回到家",
      "sentence_index": 9,
      "char_start": 90,
      "char_end": 97,
      "children": []
    },
    {
      "unit_id": "sent_010",
      "unit_type": "sentence",
      "text": "我开始喝酒",
      "sentence_index": 10,
      "char_start": 98,
      "char_end": 103,
      "children": []
    },
    {
      "unit_id": "sent_011",
      "unit_type": "sentence",
      "text": "不久，老友也来了",
      "sentence_index": 11,
      "char_start": 104,
      "char_end": 113,
      "children": []
    },
    {
      "unit_id": "sent_012",
      "unit_type": "sentence",
      "text": "他告诉我他失恋了",
      "sentence_index": 12,
      "char_start": 114,
      "char_end": 123,
      "children": []
    },
    {
      "unit_id": "sent_013",
      "unit_type": "sentence",
      "text": "心里很难过",
      "sentence_index": 13,
      "char_start": 124,
      "char_end": 129,
      "children": []
    },
    {
      "unit_id": "sent_014",
      "unit_type": "sentence",
      "text": "我笑着安慰他",
      "sentence_index": 14,
      "char_start": 130,
      "char_end": 137,
      "children": []
    },
    {
      "unit_id": "sent_015",
      "unit_type": "sentence",
      "text": "劝他不要再想那些不开心的事",
      "sentence_index": 15,
      "char_start": 138,
      "char_end": 152,
      "children": []
    },
    {
      "unit_id": "sent_016",
      "unit_type": "sentence",
      "text": "我们一起喝酒",
      "sentence_index": 16,
      "char_start": 153,
      "char_end": 159,
      "children": []
    },
    {
      "unit_id": "sent_017",
      "unit_type": "sentence",
      "text": "时间慢慢流逝",
      "sentence_index": 17,
      "char_start": 160,
      "char_end": 166,
      "children": []
    },
    {
      "unit_id": "sent_018",
      "unit_type": "sentence",
      "text": "后来，老友要坐公交车回家",
      "sentence_index": 18,
      "char_start": 167,
      "char_end": 181,
      "children": []
    },
    {
      "unit_id": "sent_019",
      "unit_type": "sentence",
      "text": "外面下起了雨",
      "sentence_index": 19,
      "char_start": 182,
      "char_end": 188,
      "children": []
    },
    {
      "unit_id": "sent_020",
      "unit_type": "sentence",
      "text": "我在楼下等他",
      "sentence_index": 20,
      "char_start": 189,
      "char_end": 196,
      "children": []
    },
    {
      "unit_id": "sent_021",
      "unit_type": "sentence",
      "text": "他问我是不是和那个女人分手了",
      "sentence_index": 21,
      "char_start": 197,
      "char_end": 213,
      "children": []
    },
    {
      "unit_id": "sent_022",
      "unit_type": "sentence",
      "text": "是不是坐公交车",
      "sentence_index": 22,
      "char_start": 214,
      "char_end": 221,
      "children": []
    },
    {
      "unit_id": "sent_023",
      "unit_type": "sentence",
      "text": "我告诉他是的",
      "sentence_index": 23,
      "char_start": 222,
      "char_end": 229,
      "children": []
    },
    {
      "unit_id": "sent_024",
      "unit_type": "sentence",
      "text": "并且指向了天上的乌云",
      "sentence_index": 24,
      "char_start": 230,
      "char_end": 241,
      "children": []
    },
    {
      "unit_id": "sent_025",
      "unit_type": "sentence",
      "text": "他说下雨了",
      "sentence_index": 25,
      "char_start": 242,
      "char_end": 248,
      "children": []
    },
    {
      "unit_id": "sent_026",
      "unit_type": "sentence",
      "text": "没有太阳",
      "sentence_index": 26,
      "char_start": 249,
      "char_end": 254,
      "children": []
    },
    {
      "unit_id": "sent_027",
      "unit_type": "sentence",
      "text": "还问我要不要伞",
      "sentence_index": 27,
      "char_start": 255,
      "char_end": 263,
      "children": []
    },
    {
      "unit_id": "sent_028",
      "unit_type": "sentence",
      "text": "我同意了",
      "sentence_index": 28,
      "char_start": 264,
      "char_end": 269,
      "children": []
    },
    {
      "unit_id": "sent_029",
      "unit_type": "sentence",
      "text": "我们在雨中等待公交车",
      "sentence_index": 29,
      "char_start": 270,
      "char_end": 282,
      "children": []
    },
    {
      "unit_id": "sent_030",
      "unit_type": "sentence",
      "text": "他去了趟卫生间",
      "sentence_index": 30,
      "char_start": 283,
      "char_end": 291,
      "children": []
    },
    {
      "unit_id": "sent_031",
      "unit_type": "sentence",
      "text": "等了很久",
      "sentence_index": 31,
      "char_start": 292,
      "char_end": 297,
      "children": []
    },
    {
      "unit_id": "sent_032",
      "unit_type": "sentence",
      "text": "他终于出来了",
      "sentence_index": 32,
      "char_start": 298,
      "char_end": 305,
      "children": []
    },
    {
      "unit_id": "sent_033",
      "unit_type": "sentence",
      "text": "还亲了我一下",
      "sentence_index": 33,
      "char_start": 306,
      "char_end": 313,
      "children": []
    },
    {
      "unit_id": "sent_034",
      "unit_type": "sentence",
      "text": "我们继续喝酒",
      "sentence_index": 34,
      "char_start": 314,
      "char_end": 321,
      "children": []
    },
    {
      "unit_id": "sent_035",
      "unit_type": "sentence",
      "text": "我感到非常开心",
      "sentence_index": 35,
      "char_start": 322,
      "char_end": 330,
      "children": []
    },
    {
      "unit_id": "sent_036",
      "unit_type": "sentence",
      "text": "最后，他回家了",
      "sentence_index": 36,
      "char_start": 331,
      "char_end": 339,
      "children": []
    },
    {
      "unit_id": "sent_037",
      "unit_type": "sentence",
      "text": "我一个人站在雨中",
      "sentence_index": 37,
      "char_start": 340,
      "char_end": 349,
      "children": []
    },
    {
      "unit_id": "sent_038",
      "unit_type": "sentence",
      "text": "心里有些难过",
      "sentence_index": 38,
      "char_start": 350,
      "char_end": 357,
      "children": []
    },
    {
      "unit_id": "sent_039",
      "unit_type": "sentence",
      "text": "不知道他什么时候才能走出失恋的阴影",
      "sentence_index": 39,
      "char_start": 358,
      "char_end": 378,
      "children": []
    }
  ],
