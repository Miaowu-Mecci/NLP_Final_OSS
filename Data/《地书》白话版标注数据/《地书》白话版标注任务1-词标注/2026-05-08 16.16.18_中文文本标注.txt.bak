      "target_id": "word_172",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "关于卫生棉条的事情或问题。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "“事”泛指相关事宜。"
    },
