  "annotations": [
    {
      "annotation_id": "ann_001",
      "target_id": "word_001",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "叙事者本人，话语的出发点。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "第一人称叙事者。"
    },
    {
      "annotation_id": "ann_002",
      "target_id": "word_002",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "快速查看时间以做出下班决定的动作。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "“看了”+“眼”的组合，表示短暂、不经意的动作。"
    },
    {
      "annotation_id": "ann_003",
      "target_id": "word_003",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "办公桌上的计时器，暗示“时间到”。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "这里“时钟”是下班决定的直接依据。"
    },
    {
      "annotation_id": "ann_004",
      "target_id": "word_004",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "断然不接受加班要求。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "语气中带有坚决和一丝解脱感。"
    },
    {
      "annotation_id": "ann_005",
      "target_id": "word_005",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "动作完成的标记，表示“拒绝”已成事实。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "动态助词“了”，此处表示动作的完结。"
    },
    {
      "annotation_id": "ann_006",
      "target_id": "word_006",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "下班时间后的额外工作。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "语境中特指工作时间结束后可能被要求继续的工作。"
    },
    {
      "annotation_id": "ann_007",
      "target_id": "word_007",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "发自内心地展现笑容的动作。",
      "confidence": 0.94,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "表示拒绝加班后的轻松和自主。"
    },
    {
      "annotation_id": "ann_008",
      "target_id": "word_008",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "因决定拒绝加班而产生的满意表情。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "与上下文中的无奈/烦躁形成对比。"
    },
    {
      "annotation_id": "ann_009",
      "target_id": "word_009",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "伸出手臂准备执行关机的动作。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "具体化的身体动作，紧接着就要关电脑。"
    },
    {
      "annotation_id": "ann_010",
      "target_id": "word_010",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "执行关闭计算机的动作，象征彻底下班。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "“关电脑”在这里是下班仪式的核心动作。"
    },
    {
      "annotation_id": "ann_011",
      "target_id": "word_011",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "表示“关电脑”这个动作的完成。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "再一次出现，强调一系列动作的相继完成。"
    },
    {
      "annotation_id": "ann_012",
      "target_id": "word_012",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "工作的工具，关掉它意味着工作的结束。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "此处是具体物品，也具有象征意义。"
    },
    {
      "annotation_id": "ann_013",
      "target_id": "word_013",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "指代叙事者和他的同事两个人。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "包括说话人和另一人。"
    },
