      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "保持在座位上的姿势，是一种持续的状态。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "不同于“坐了”，而是强调状态的延续。"
