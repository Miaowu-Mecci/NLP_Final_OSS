      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "聊天结束后的分离。"
    },
    {
      "annotation_id": "ann_157",
      "target_id": "word_157",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "指代告别的同事。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "同事的动作为“下楼”。"
    },
    {
      "annotation_id": "ann_158",
      "target_id": "word_158",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "同事离开星巴克或这栋楼的行动。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "\"下楼\"暗示他们之前在二楼或更高楼层，或者同事要前往一楼。"
    },
    {
      "annotation_id": "ann_159",
      "target_id": "word_159",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "与同事道别的叙事者。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "叙事者的动作为“往楼上走”。"
    },
    {
      "annotation_id": "ann_160",
      "target_id": "word_160",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "朝着楼上的方向移动。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "与同事的“下楼”方向相反，形成动作上的分道扬镳。"
    },
    {
      "annotation_id": "ann_161",
      "target_id": "word_161",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "场景中持续运转的计时器。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "与开头呼应，作为时间流逝的背景音。"
    },
    {
      "annotation_id": "ann_162",
      "target_id": "word_162",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "时钟在行走，模拟其发出的声音，强调时间在安静中流逝。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "兼具声音（滴答）和状态（走着）的描述。"
    },
    {
      "annotation_id": "ann_163",
      "target_id": "word_163",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "行走和上楼动作的主体。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "叙事者。"
    },
    {
      "annotation_id": "ann_164",
      "target_id": "word_164",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "完成了上楼的过程，到达楼上空间。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "\"上了楼\"是动趋结构，表示完成。"
    },
    {
      "annotation_id": "ann_165",
      "target_id": "word_165",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在楼层里多次变换方向行走，暗示路线有点复杂或在寻找。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "描写在楼内的行走路径。"
    },
    {
      "annotation_id": "ann_166",
      "target_id": "word_166",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "表示移动方向的介词，指向目的地。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "引出目的地洗手间。"
    },
    {
      "annotation_id": "ann_167",
      "target_id": "word_167",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "叙事者行走的目的地，也是处理私事的地方。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "引出后续“卫生棉条”等非常私人的语境。"
    },
    {
      "annotation_id": "ann_168",
      "target_id": "word_168",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "向目的地行进。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "\"走去\"是未完成的过程。"
    },
    {
      "annotation_id": "ann_169",
      "target_id": "word_169",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "内心活动的叙事者。",
