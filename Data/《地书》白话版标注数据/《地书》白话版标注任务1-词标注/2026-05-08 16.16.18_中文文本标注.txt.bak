      "target_id": "word_019",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "叙事者本人。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "持续的叙事视角。"
    },
