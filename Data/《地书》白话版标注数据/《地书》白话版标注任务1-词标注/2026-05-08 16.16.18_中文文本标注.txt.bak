      "target_id": "word_018",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "员工下班后常去的咖啡连锁店，表示休闲社交的场所。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "不仅是地点名，更代表了职场人休闲的生活方式。"
    },
