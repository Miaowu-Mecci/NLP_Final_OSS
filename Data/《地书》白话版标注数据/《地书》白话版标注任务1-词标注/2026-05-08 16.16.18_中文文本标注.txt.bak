    {
      "annotation_id": "ann_017",
      "target_id": "word_017",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "朝某个方向行进，目的地明确。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "“走向”带有目的地的指向性。"
