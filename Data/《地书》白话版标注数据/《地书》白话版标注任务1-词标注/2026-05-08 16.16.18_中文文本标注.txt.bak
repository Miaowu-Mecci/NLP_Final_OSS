    {
      "annotation_id": "ann_026",
      "target_id": "word_026",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "前后动作顺承，表示于是、就。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "承接挥手之后的下一个动作。"
    },
    {
      "annotation_id": "ann_027",
      "target_id": "word_027",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "完成就座的动作。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "“坐”+“了”，动作刚发生。"
    },
    {
      "annotation_id": "ann_028",
      "target_id": "word_028",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "身体由站立变为座椅上的状态。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "方向补语，表示向下进入座位。"
    },
    {
      "annotation_id": "ann_029",
      "target_id": "word_029",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "聊天话题的发起者。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "对话中这一话题的主要分享者。"
    },
    {
      "annotation_id": "ann_030",
      "target_id": "word_030",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "连接谈话的两个参与者。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "并列连词。"
    },
    {
      "annotation_id": "ann_031",
      "target_id": "word_031",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "对话的另一方，叙事者本人。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "同事的谈话对象。"
    },
    {
      "annotation_id": "ann_032",
      "target_id": "word_032",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "开始轻松、非正式的闲谈。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "\"聊起天来\"表示聊天的起始并带有一定的随意感。"
    },
    {
      "annotation_id": "ann_033",
      "target_id": "word_033",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "直接引语开始的标记。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "前引号。"
    },
    {
      "annotation_id": "ann_034",
      "target_id": "word_034",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "指代当前的天气状况。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "同事用\"这\"来开启话题，指代大家都能感受到的天气。"
    },
    {
      "annotation_id": "ann_035",
      "target_id": "word_035",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "同事用来打开话匣子的日常话题。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "闲聊中最常见、最安全的话题。"
    },
    {
      "annotation_id": "ann_036",
      "target_id": "word_036",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "阴晴不定，变化无常。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "描述了天气的不稳定，也为接下来的“不安”情绪做了铺垫。"
    },
    {
      "annotation_id": "ann_037",
      "target_id": "word_037",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "马上，很快就要，强调一种即将发生的趋势。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "不是用眼睛看，而是表示时间上的迫近。"
    },
    {
      "annotation_id": "ann_038",
      "target_id": "word_038",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "表示再一次，再次，有种“怎么又来了”的不耐烦意味。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "暗示天气的这种变化已经发生过很多次。"
    },
    {
      "annotation_id": "ann_039",
      "target_id": "word_039",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "同事对天气即将变坏的预测和感慨。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "完整的陈述，带有预测性。"
    },
    {
      "annotation_id": "ann_040",
      "target_id": "word_040",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "话语的若有所思或未尽之感。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "省略号表示语气的延长和思考。"
    },
    {
      "annotation_id": "ann_041",
      "target_id": "word_041",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "直接引语结束的标记。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "后引号。"
    },
    {
      "annotation_id": "ann_042",
      "target_id": "word_042",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "叙事者，即聊天中的倾听者。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "对话框架中，叙述者自称。"
    },
    {
      "annotation_id": "ann_043",
      "target_id": "word_043",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "接收并理解同事话语的动作。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "进行中的感知动作。"
    },
    {
      "annotation_id": "ann_044",
      "target_id": "word_044",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "内心感受的处所。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "不是解剖学的，而是抽象情感的容器。"
    },
    {
      "annotation_id": "ann_045",
      "target_id": "word_045",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "对于反复无常的天气话题感到轻微厌倦和无力感。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "表现出对闲聊话题的复杂情绪。"
    },
    {
      "annotation_id": "ann_046",
      "target_id": "word_046",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "因天气即将变坏而引起的一丝轻微担忧或心神不宁。",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "和“无奈”并列，描绘出一种微妙而混杂的内心状态。"
    },
    {
      "annotation_id": "ann_047",
      "target_id": "word_047",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "叙事者，即将发言并点单的人。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "再次出现，强调主动转换话题。"
    },
    {
      "annotation_id": "ann_048",
      "target_id": "word_048",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "用轻松、带笑的方式讲话，试图转移话题，打破由天气带来的沉闷或尴尬。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "\"笑着说\"是一种有目的的交际策略。"
    },
    {
      "annotation_id": "ann_049",
      "target_id": "word_049",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "直接引语开始的标记。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "我所说的话的起始。"
    },
    {
      "annotation_id": "ann_050",
      "target_id": "word_050",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "点单时的口语化表达，\"要一杯\"的意思。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "以量词“杯”直接指代饮品，省略了“一”。"
    },
    {
      "annotation_id": "ann_051",
      "target_id": "word_051",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在星巴克语境下，点的是含有咖啡因的提神饮品。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "下班后放松，但仍需要咖啡因。"
    },
    {
      "annotation_id": "ann_052",
      "target_id": "word_052",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "连接并列的点单项目。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "\"A and B\"结构。"
    },
    {
      "annotation_id": "ann_053",
      "target_id": "word_053",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "搭配咖啡的点心，组成一份典型的咖啡店简餐。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "不是单纯的面包，而是特定场合的常见搭配。"
    },
    {
      "annotation_id": "ann_054",
      "target_id": "word_054",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "直接引语结束的标记。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "我所说话语的结束。"
    },
    {
      "annotation_id": "ann_055",
      "target_id": "word_055",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "对叙事者点单进行回应的那人，即之前那位同事。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "保持叙述对象的一致。"
    },
    {
      "annotation_id": "ann_056",
      "target_id": "word_056",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "同事也以友好的笑容回应了叙事者的点单提议。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "\"笑着回应\"与前文\"笑着说\"呼应，气氛转向融洽。"
    },
    {
      "annotation_id": "ann_057",
      "target_id": "word_057",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "同事直接引语开始的标记。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "同事话语的起始。"
    },
    {
      "annotation_id": "ann_058",
      "target_id": "word_058",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "同事效仿叙事者的口吻进行点单。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "\"我也来一杯绿茶\"的简化表达，体现了对话的连贯性和轻松感。"
    },
    {
      "annotation_id": "ann_059",
      "target_id": "word_059",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "同事选择的饮品，咖啡因含量较低，与叙事者的“咖啡”形成对比。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "点单内容体现个人偏好。"
    },
