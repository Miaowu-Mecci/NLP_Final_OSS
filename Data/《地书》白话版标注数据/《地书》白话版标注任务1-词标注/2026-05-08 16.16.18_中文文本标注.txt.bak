      "annotation_id": "ann_060",
      "target_id": "word_060",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "在绿茶之外，额外附加点一个。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "\"再加个\"表明了补充说明的关系。"
    },
    {
      "annotation_id": "ann_061",
      "target_id": "word_061",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "同事在绿茶之外加的食品，可能是作为一种健康轻食的选择。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "呼应叙事者的“牛角包”，完整了各自的简餐组合。"
    },
    {
      "annotation_id": "ann_062",
      "target_id": "word_062",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "同事话语结束的标记。",
      "confidence": 0.99,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "同事话语的结束。"
    },
    {
