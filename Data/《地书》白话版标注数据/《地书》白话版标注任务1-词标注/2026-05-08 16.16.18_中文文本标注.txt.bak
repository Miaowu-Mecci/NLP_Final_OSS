    {
      "annotation_id": "ann_016",
      "target_id": "word_016",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "从楼上办公室区域向下走向出口。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "结合上下文，办公室应在楼上。"
