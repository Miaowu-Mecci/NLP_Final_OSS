      "annotation_id": "ann_014",
      "target_id": "word_014",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "强调“我们”的数量是二。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "对“我们”的补充说明。"
    },
    {
      "annotation_id": "ann_015",
      "target_id": "word_015",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "不分开，共同行动。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "描述二人同行的状态。"
