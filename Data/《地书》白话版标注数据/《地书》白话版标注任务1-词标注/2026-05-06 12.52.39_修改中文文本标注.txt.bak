  "annotations": [
    {
      "annotation_id": "ann_001",
      "target_id": "word_001",
      "target_type": "word",
      "task_id": "pragmatic_meaning_001",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "点明故事发生的具体时间，是深夜中的深夜。这个时间点通常与深度睡眠和潜意识活动相关，为即将展开的梦境叙事提供了合理的时间背景，也暗示了主人公可能因疲惫而迅速入睡。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "时间状语为梦境铺垫"
    },
    {
      "annotation_id": "ann_002",
      "target_id": "word_002",
      "target_type": "word",
      "task_id": "pragmatic_meaning_002",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "指睡眠状态。这个词的使用标志着叙事从现实世界平滑过渡到非现实的梦境世界，是整个梦境故事的起点。",
      "confidence": 0.97,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "现实与梦境的转换点"
    },
    {
      "annotation_id": "ann_003",
      "target_id": "word_003",
      "target_type": "word",
      "task_id": "pragmatic_meaning_003",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "明确指出后续内容是发生在主人公的梦境中，而非现实。它为整个叙事设定了一个超现实的框架，让读者对接下来可能出现的荒诞、非逻辑情节有所预期。",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "设定叙事框架"
    },
    {
      "annotation_id": "ann_004",
      "target_id": "word_004",
      "target_type": "word",
      "task_id": "pragmatic_meaning_004",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "形容争吵的程度非常剧烈、紧张。这个词语为梦境的第一个场景注入了强烈的冲突感和负面情绪，暗示了主人公潜意识中可能存在焦虑或矛盾。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "情绪强度描写"
    },
    {
      "annotation_id": "ann_005",
      "target_id": "word_005",
      "target_type": "word",
      "task_id": "pragmatic_meaning_005",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "一个表示时间顺序的连接词。它表明梦境内容的转换，从“争吵”场景平滑地过渡到“世界末日”场景，体现了梦境的非线性、跳跃式特点。",
      "confidence": 0.94,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "梦境场景的转换标记"
    },
    {
      "annotation_id": "ann_006",
      "target_id": "word_006",
      "target_type": "word",
      "task_id": "pragmatic_meaning_006",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "一个具有强烈文化符号意义的词，指代全球性的毁灭性灾难。梦境中出现这个场景，象征着极致的恐惧、混乱和失控感，是潜意识中深层焦虑的具象化表现。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "核心恐惧意象"
    },
    {
      "annotation_id": "ann_007",
      "target_id": "word_007",
      "target_type": "word",
      "task_id": "pragmatic_meaning_007",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "描述海浪覆盖并吞噬地球的动作。这个动词极具破坏力和压迫感，生动地描绘了灾难的毁灭性场面，强化了“世界末日”的绝望氛围。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "灾难场景的动态描写"
    }
  ]
