      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "指当天中午12点到日落前的时间段，这里具体指下午六点这个时间点",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "与具体时间'六点'连用，限定时间范围"
    },
    {
      "annotation_id": "ann_002",
      "target_id": "word_002",
      "target_type": "word",
      "task_id": "pragmatic_meaning",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "指下午6点整，即18:00，是具体的时间点",
      "confidence": 0.98,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "与'下午'连用，明确为傍晚时刻"
