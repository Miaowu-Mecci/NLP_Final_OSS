  "annotations": [
    {
      "annotation_id": "ann_001",
      "target_id": "word_001",
      "target_type": "word",
      "task_id": "pragmatic_meaning_001",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "强调时间非常晚，是深夜时分。这个时间点选择步行，暗示了主人公可能有心事，或者享受独处的宁静，为整个故事的孤寂、内省基调奠定了基础。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "时间状语奠定叙事基调"
    },
    {
      "annotation_id": "ann_002",
      "target_id": "word_002",
      "target_type": "word",
      "task_id": "pragmatic_meaning_002",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "表明主人公放弃了一种更快捷、更常规的交通方式。这个否定选择是后续“步行”行为的前提，突显了其行为的非典型性和主动性，暗示了某种刻意为之的意图。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "否定选择突显行为意图"
    },
    {
      "annotation_id": "ann_003",
      "target_id": "word_003",
      "target_type": "word",
      "task_id": "pragmatic_meaning_003",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "这是主人公在深夜做出的核心行为。步行是一种缓慢、沉浸式的移动方式，暗示他可能在享受孤独、思考问题，或者在体验一种与城市夜晚的直接接触。",
      "confidence": 0.94,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "核心行为揭示人物状态"
    },
    {
      "annotation_id": "ann_004",
      "target_id": "word_004",
      "target_type": "word",
      "task_id": "pragmatic_meaning_004",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "一个导航工具。在步行时使用地图，一方面说明路程可能不熟悉，另一方面也增添了一丝探索或迷路的意味，与深夜独自前行的氛围相符。",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "道具暗示人物状态"
    },
    {
      "annotation_id": "ann_005",
      "target_id": "word_005",
      "target_type": "word",
      "task_id": "pragmatic_meaning_005",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "既是现实中自己留下的痕迹，也具有象征意义。它代表着主人公走过的路、经历的时间，是连接起点与终点的具象化线索，带有一种自我追随的哲学意味。",
      "confidence": 0.91,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "核心意象，具有双重含义"
    },
    {
      "annotation_id": "ann_006",
      "target_id": "word_006",
      "target_type": "word",
      "task_id": "pragmatic_meaning_006",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "描述了环境的物理状态，也映射了主人公的内心世界。这种安静不是祥和，而是一种空旷、孤寂的感受，强化了“只有我一个人的脚步声”的孤独感。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "环境描写烘托内心感受"
    },
    {
      "annotation_id": "ann_007",
      "target_id": "word_007",
      "target_type": "word",
      "task_id": "pragmatic_meaning_007",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "一个代表秩序、安全和权威的地点。在深夜的步行路线中特意提到“警察局”，可能暗示主人公对安全的潜意识关注，或是在孤寂环境中寻找一种心理上的锚点。",
      "confidence": 0.90,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "特定地点的象征意义"
    },
    {
      "annotation_id": "ann_008",
      "target_id": "word_008",
      "target_type": "word",
      "task_id": "pragmatic_meaning_008",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "路上的一个“他者”。她的出现打破了主人公独自一人的状态，但她只是一个短暂的、没有互动的过客。这个细节增加了场景的真实感，也反衬出主人公的孤独。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "次要人物反衬主角状态"
    },
    {
      "annotation_id": "ann_009",
      "target_id": "word_009",
      "target_type": "word",
      "task_id": "pragmatic_meaning_009",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "一个广阔、开放的意象。女人抬头看天空的动作，可能是在思考、寻找方向，或是单纯地感受夜色。这个动作将叙事视角从地面引向高空，增添了一丝诗意和遐想空间。",
      "confidence": 0.89,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "动作描写的象征性"
    },
    {
      "annotation_id": "ann_010",
      "target_id": "word_010",
      "target_type": "word",
      "task_id": "pragmatic_meaning_010",
      "task_label_zh": "语境实际含义",
      "task_label_en": "Pragmatic Meaning",
      "value": "形容脚印的形态。它不仅指物理距离的遥远，更暗示了时间的漫长和过程的艰辛。这个叠词的使用，强化了主人公一路走来的感受，让“终于走到了家”的结局更具分量。",
      "confidence": 0.94,
      "llm_used": true,
      "llm_name": "Qwen",
      "annotator_note": "形容词强化过程感"
    }
  ]
