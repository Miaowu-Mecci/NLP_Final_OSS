      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我看着她，想起她整理衣服的样子，心里有点心动。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": ""
    },
    {
