      "target_id": "sent_22_007",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "他吐得满地都是，我帮他收拾干净，还找到了他的钱包、手机和钥匙。",
      "confidence": 0.82,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": ""
    },
    {
      "annotation_id": "a_ft_22_008",
      "target_id": "sent_22_008",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "他的狗看到我们回来特别兴奋。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": ""
    },
    {
      "annotation_id": "a_ft_22_009",
      "target_id": "sent_22_009",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我把他扶上床，他还在胡言乱语。",
      "confidence": 0.88,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": ""
    },
    {
      "annotation_id": "a_ft_22_010",
      "target_id": "sent_22_010",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我照顾了他很久，他又吐了一次。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": ""
    },
    {
      "annotation_id": "a_ft_22_011",
      "target_id": "sent_22_011",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "看着他睡得很沉，我既无奈又心疼。",
