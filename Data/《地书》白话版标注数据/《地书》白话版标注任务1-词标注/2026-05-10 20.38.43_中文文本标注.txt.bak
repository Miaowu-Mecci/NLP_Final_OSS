      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": ""
    },
    {
      "annotation_id": "a_ft_17_008",
      "target_id": "sent_17_008",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我先坐电梯下楼去了一趟洗手间，然后快步走出大楼。",
