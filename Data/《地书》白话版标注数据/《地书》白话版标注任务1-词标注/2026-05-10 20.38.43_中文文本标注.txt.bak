      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我盯着棉条发了一会儿呆。",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": ""
    },
    {
      "annotation_id": "a_ft_10_025",
      "target_id": "sent_10_025",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我走出隔间有点发懵，仿佛听到音乐，看见不远处的女生回头看了我一眼。",
      "confidence": 0.8,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": ""
    },
    {
