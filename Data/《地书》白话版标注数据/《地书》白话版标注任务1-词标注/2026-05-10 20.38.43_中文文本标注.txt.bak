      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": ""
    },
    {
      "annotation_id": "a_ft_17_003",
      "target_id": "sent_17_003",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "忙了一整天我累坏了，只想早点回家休息。",
