      "unit_id": "word_001_003",
      "unit_type": "word",
      "text": "给她准备一份生日礼物——",
      "sentence_id": "sent_001",
      "word_index_in_sentence": 3,
      "char_start": 13,
      "char_end": 24
    },
    {
      "unit_id": "word_001_004",
      "unit_type": "word",
      "text": "她马上就要30岁了。",
      "sentence_id": "sent_001",
      "word_index_in_sentence": 4,
      "char_start": 25,
      "char_end": 34
    },
    {
      "unit_id": "word_002_001",
      "unit_type": "word",
      "text": "我又想到，",
      "sentence_id": "sent_002",
      "word_index_in_sentence": 1,
      "char_start": 35,
      "char_end": 39
    },
    {
      "unit_id": "word_002_002",
      "unit_type": "word",
      "text": "要是送她一份求婚礼物，",
      "sentence_id": "sent_002",
      "word_index_in_sentence": 2,
      "char_start": 40,
      "char_end": 50
    },
    {
      "unit_id": "word_002_003",
      "unit_type": "word",
      "text": "我们就能结婚了，",
      "sentence_id": "sent_002",
      "word_index_in_sentence": 3,
      "char_start": 51,
      "char_end": 58
    },
    {
      "unit_id": "word_002_004",
      "unit_type": "word",
      "text": "可送什么好呢？",
      "sentence_id": "sent_002",
      "word_index_in_sentence": 4,
      "char_start": 59,
      "char_end": 65
    },
    {
      "unit_id": "word_003_001",
      "unit_type": "word",
      "text": "她喜欢香奈儿，",
      "sentence_id": "sent_003",
      "word_index_in_sentence": 1,
      "char_start": 66,
      "char_end": 72
    },
    {
      "unit_id": "word_003_002",
      "unit_type": "word",
      "text": "可我没钱，",
      "sentence_id": "sent_003",
      "word_index_in_sentence": 2,
      "char_start": 73,
      "char_end": 77
    },
    {
      "unit_id": "word_003_003",
      "unit_type": "word",
      "text": "买不起。",
      "sentence_id": "sent_003",
      "word_index_in_sentence": 3,
      "char_start": 78,
      "char_end": 81
    },
    {
      "unit_id": "word_004_001",
      "unit_type": "word",
      "text": "走着走着，",
      "sentence_id": "sent_004",
      "word_index_in_sentence": 1,
      "char_start": 82,
      "char_end": 86
    },
    {
      "unit_id": "word_004_002",
      "unit_type": "word",
      "text": "我看到一家书店，",
      "sentence_id": "sent_004",
      "word_index_in_sentence": 2,
      "char_start": 87,
      "char_end": 94
    },
    {
      "unit_id": "word_004_003",
      "unit_type": "word",
      "text": "想到书也是个不错的礼物。",
      "sentence_id": "sent_004",
      "word_index_in_sentence": 3,
      "char_start": 95,
      "char_end": 106
    },
    {
      "unit_id": "word_005_001",
      "unit_type": "word",
      "text": "我走进书店，",
      "sentence_id": "sent_005",
      "word_index_in_sentence": 1,
      "char_start": 107,
      "char_end": 112
    },
    {
      "unit_id": "word_005_002",
      "unit_type": "word",
      "text": "翻了翻书，",
      "sentence_id": "sent_005",
      "word_index_in_sentence": 2,
      "char_start": 113,
      "char_end": 117
    },
    {
      "unit_id": "word_005_003",
      "unit_type": "word",
      "text": "突然想到可以在书里夹一朵玫瑰，",
      "sentence_id": "sent_005",
      "word_index_in_sentence": 3,
      "char_start": 118,
      "char_end": 132
    },
    {
      "unit_id": "word_005_004",
      "unit_type": "word",
      "text": "可玫瑰很快就枯萎了，",
      "sentence_id": "sent_005",
      "word_index_in_sentence": 4,
      "char_start": 133,
      "char_end": 142
    },
    {
      "unit_id": "word_005_005",
      "unit_type": "word",
      "text": "我的心也跟着碎了。",
      "sentence_id": "sent_005",
      "word_index_in_sentence": 5,
      "char_start": 143,
      "char_end": 151
    },
    {
      "unit_id": "word_006_001",
      "unit_type": "word",
      "text": "我又想到书里藏着坏人，",
      "sentence_id": "sent_006",
      "word_index_in_sentence": 1,
      "char_start": 152,
      "char_end": 162
    },
    {
      "unit_id": "word_006_002",
      "unit_type": "word",
      "text": "用枪指着我，",
      "sentence_id": "sent_006",
      "word_index_in_sentence": 2,
      "char_start": 163,
      "char_end": 168
    },
    {
      "unit_id": "word_006_003",
      "unit_type": "word",
      "text": "有点害怕。",
      "sentence_id": "sent_006",
      "word_index_in_sentence": 3,
      "char_start": 169,
      "char_end": 173
    },
    {
      "unit_id": "word_007_001",
      "unit_type": "word",
      "text": "坏人开枪打我，",
      "sentence_id": "sent_007",
      "word_index_in_sentence": 1,
      "char_start": 174,
      "char_end": 180
    },
    {
      "unit_id": "word_007_002",
      "unit_type": "word",
      "text": "我躲开了，",
      "sentence_id": "sent_007",
      "word_index_in_sentence": 2,
      "char_start": 181,
      "char_end": 185
    },
    {
      "unit_id": "word_007_003",
      "unit_type": "word",
      "text": "有点生气。",
      "sentence_id": "sent_007",
      "word_index_in_sentence": 3,
      "char_start": 186,
      "char_end": 190
    },
    {
      "unit_id": "word_008_001",
      "unit_type": "word",
      "text": "我看着机票，",
      "sentence_id": "sent_008",
      "word_index_in_sentence": 1,
      "char_start": 191,
      "char_end": 196
    },
    {
      "unit_id": "word_008_002",
      "unit_type": "word",
      "text": "想去旅行，",
      "sentence_id": "sent_008",
      "word_index_in_sentence": 2,
      "char_start": 197,
      "char_end": 201
    },
    {
      "unit_id": "word_008_003",
      "unit_type": "word",
      "text": "忍不住笑了。",
      "sentence_id": "sent_008",
      "word_index_in_sentence": 3,
      "char_start": 202,
      "char_end": 207
    },
    {
      "unit_id": "word_009_001",
      "unit_type": "word",
      "text": "我想到我们结婚后去度蜜月，",
      "sentence_id": "sent_009",
      "word_index_in_sentence": 1,
      "char_start": 208,
      "char_end": 220
    },
    {
      "unit_id": "word_009_002",
      "unit_type": "word",
      "text": "笑了。",
      "sentence_id": "sent_009",
      "word_index_in_sentence": 2,
      "char_start": 221,
      "char_end": 223
    },
    {
      "unit_id": "word_010_001",
      "unit_type": "word",
      "text": "我拿起手机",
      "sentence_id": "sent_010",
      "word_index_in_sentence": 1,
      "char_start": 224,
      "char_end": 228
    },
    {
      "unit_id": "word_010_002",
      "unit_type": "word",
      "text": "给她发消息。",
      "sentence_id": "sent_010",
      "word_index_in_sentence": 2,
      "char_start": 229,
      "char_end": 234
    },
    {
      "unit_id": "word_011_001",
      "unit_type": "word",
      "text": "我问她：“结婚后想去哪度蜜月？”",
      "sentence_id": "sent_011",
      "word_index_in_sentence": 1,
      "char_start": 235,
      "char_end": 250
    },
    {
      "unit_id": "word_011_002",
      "unit_type": "word",
      "text": "她回：“想去自由女神像，还有埃菲尔铁塔……”",
      "sentence_id": "sent_011",
      "word_index_in_sentence": 2,
      "char_start": 251,
      "char_end": 272
    },
    {
      "unit_id": "word_012_001",
      "unit_type": "word",
      "text": "电话响了，",
      "sentence_id": "sent_012",
      "word_index_in_sentence": 1,
      "char_start": 273,
      "char_end": 277
    },
    {
      "unit_id": "word_012_002",
      "unit_type": "word",
      "text": "我看着机票，",
      "sentence_id": "sent_012",
      "word_index_in_sentence": 2,
      "char_start": 278,
      "char_end": 283
    },
    {
      "unit_id": "word_012_003",
      "unit_type": "word",
      "text": "想去悉尼歌剧院、富士山、泰姬陵、加拿大、金字塔……最后选了美国。",
      "sentence_id": "sent_012",
      "word_index_in_sentence": 3,
      "char_start": 284,
      "char_end": 315
    },
    {
      "unit_id": "word_013_001",
      "unit_type": "word",
      "text": "美国的景点有",
      "sentence_id": "sent_013",
      "word_index_in_sentence": 1,
      "char_start": 316,
      "char_end": 321
    },
    {
      "unit_id": "word_013_002",
      "unit_type": "word",
      "text": "白宫、迪士尼、梦露、体育馆、自由女神像、世贸中心。",
      "sentence_id": "sent_013",
      "word_index_in_sentence": 2,
      "char_start": 322,
      "char_end": 346
    },
    {
      "unit_id": "word_014_001",
      "unit_type": "word",
      "text": "我想到世贸中心被炸了，",
      "sentence_id": "sent_014",
      "word_index_in_sentence": 1,
      "char_start": 347,
      "char_end": 357
    },
    {
      "unit_id": "word_014_002",
      "unit_type": "word",
      "text": "有点惊讶。",
      "sentence_id": "sent_014",
      "word_index_in_sentence": 2,
      "char_start": 358,
      "char_end": 362
    },
    {
      "unit_id": "word_015_001",
      "unit_type": "word",
      "text": "我查了去美国的航班、机场、酒店和攻略。",
      "sentence_id": "sent_015",
      "word_index_in_sentence": 1,
      "char_start": 363,
      "char_end": 381
    },
    {
      "unit_id": "word_016_001",
      "unit_type": "word",
      "text": "各种酒店都列了出来，",
      "sentence_id": "sent_016",
      "word_index_in_sentence": 1,
      "char_start": 382,
      "char_end": 391
    },
    {
      "unit_id": "word_016_002",
      "unit_type": "word",
      "text": "五星的、三星的、经济型的，",
      "sentence_id": "sent_016",
      "word_index_in_sentence": 2,
      "char_start": 392,
      "char_end": 404
    },
    {
      "unit_id": "word_016_003",
      "unit_type": "word",
      "text": "还有博物馆、剧院，",
      "sentence_id": "sent_016",
      "word_index_in_sentence": 3,
      "char_start": 405,
      "char_end": 413
    },
    {
      "unit_id": "word_016_004",
      "unit_type": "word",
      "text": "各种奢侈品品牌。",
      "sentence_id": "sent_016",
      "word_index_in_sentence": 4,
      "char_start": 414,
      "char_end": 421
    },
    {
      "unit_id": "word_017_001",
      "unit_type": "word",
      "text": "我点了赞，",
      "sentence_id": "sent_017",
      "word_index_in_sentence": 1,
      "char_start": 422,
      "char_end": 426
    },
    {
      "unit_id": "word_017_002",
      "unit_type": "word",
      "text": "笑着继续翻书，",
      "sentence_id": "sent_017",
      "word_index_in_sentence": 2,
      "char_start": 427,
      "char_end": 433
    },
    {
      "unit_id": "word_017_003",
      "unit_type": "word",
      "text": "走着走着到了门口，",
      "sentence_id": "sent_017",
      "word_index_in_sentence": 3,
      "char_start": 434,
      "char_end": 442
    },
    {
      "unit_id": "word_017_004",
      "unit_type": "word",
      "text": "红灯亮了，",
      "sentence_id": "sent_017",
      "word_index_in_sentence": 4,
      "char_start": 443,
      "char_end": 447
    },
    {
      "unit_id": "word_017_005",
      "unit_type": "word",
      "text": "停了下来。",
      "sentence_id": "sent_017",
      "word_index_in_sentence": 5,
      "char_start": 448,
      "char_end": 452
    },
    {
      "unit_id": "word_018_001",
      "unit_type": "word",
      "text": "我想到她，",
      "sentence_id": "sent_018",
      "word_index_in_sentence": 1,
      "char_start": 453,
      "char_end": 457
    },
    {
      "unit_id": "word_018_002",
      "unit_type": "word",
      "text": "转身往回走，",
      "sentence_id": "sent_018",
      "word_index_in_sentence": 2,
      "char_start": 458,
      "char_end": 463
    },
    {
      "unit_id": "word_018_003",
      "unit_type": "word",
      "text": "又查了巴黎的景点，",
      "sentence_id": "sent_018",
      "word_index_in_sentence": 3,
      "char_start": 464,
      "char_end": 472
    },
    {
      "unit_id": "word_018_004",
      "unit_type": "word",
      "text": "巴黎圣母院、蒙娜丽莎、埃菲尔铁塔……到了门口。",
      "sentence_id": "sent_018",
      "word_index_in_sentence": 4,
      "char_start": 473,
      "char_end": 495
    },
    {
      "unit_id": "word_019_001",
      "unit_type": "word",
      "text": "我刷卡结账，",
      "sentence_id": "sent_019",
      "word_index_in_sentence": 1,
      "char_start": 496,
      "char_end": 501
    },
    {
      "unit_id": "word_019_002",
      "unit_type": "word",
      "text": "想着买两本书当礼物。",
      "sentence_id": "sent_019",
      "word_index_in_sentence": 2,
      "char_start": 502,
      "char_end": 511
    },
    {
      "unit_id": "word_020_001",
      "unit_type": "word",
      "text": "付了钱，",
      "sentence_id": "sent_020",
      "word_index_in_sentence": 1,
      "char_start": 512,
      "char_end": 515
    },
    {
      "unit_id": "word_020_002",
      "unit_type": "word",
      "text": "拿到了礼物，",
      "sentence_id": "sent_020",
      "word_index_in_sentence": 2,
      "char_start": 516,
      "char_end": 521
    },
    {
      "unit_id": "word_020_003",
      "unit_type": "word",
      "text": "想到她会很开心。",
      "sentence_id": "sent_020",
      "word_index_in_sentence": 3,
      "char_start": 522,
      "char_end": 529
    },
    {
      "unit_id": "word_021_001",
      "unit_type": "word",
      "text": "我看着礼物，",
      "sentence_id": "sent_021",
      "word_index_in_sentence": 1,
      "char_start": 530,
      "char_end": 535
    },
    {
      "unit_id": "word_021_002",
      "unit_type": "word",
      "text": "纠结要不要送她。",
      "sentence_id": "sent_021",
      "word_index_in_sentence": 2,
      "char_start": 536,
      "char_end": 543
    },
    {
      "unit_id": "word_022_001",
      "unit_type": "word",
      "text": "走出书店，",
      "sentence_id": "sent_022",
      "word_index_in_sentence": 1,
      "char_start": 544,
      "char_end": 548
    },
    {
      "unit_id": "word_022_002",
      "unit_type": "word",
      "text": "想到她的生日，",
      "sentence_id": "sent_022",
      "word_index_in_sentence": 2,
      "char_start": 549,
      "char_end": 555
    },
    {
      "unit_id": "word_022_003",
      "unit_type": "word",
      "text": "又回头看了看。",
      "sentence_id": "sent_022",
      "word_index_in_sentence": 3,
      "char_start": 556,
      "char_end": 562
    },
    {
      "unit_id": "word_023_001",
      "unit_type": "word",
      "text": "我想着相机太贵，不买；",
      "sentence_id": "sent_023",
      "word_index_in_sentence": 1,
      "char_start": 563,
      "char_end": 573
    },
    {
      "unit_id": "word_023_002",
      "unit_type": "word",
      "text": "平板太贵，不买；",
      "sentence_id": "sent_023",
      "word_index_in_sentence": 2,
      "char_start": 574,
      "char_end": 581
    },
    {
      "unit_id": "word_023_003",
      "unit_type": "word",
      "text": "滑板太贵，不买；",
      "sentence_id": "sent_023",
      "word_index_in_sentence": 3,
      "char_start": 582,
      "char_end": 589
    },
    {
      "unit_id": "word_023_004",
      "unit_type": "word",
      "text": "游戏不贵，买了，",
      "sentence_id": "sent_023",
      "word_index_in_sentence": 4,
      "char_start": 590,
      "char_end": 597
    },
    {
      "unit_id": "word_023_005",
      "unit_type": "word",
      "text": "忍不住笑了。",
      "sentence_id": "sent_023",
      "word_index_in_sentence": 5,
      "char_start": 598,
      "char_end": 603
    },
    {
      "unit_id": "word_024_001",
      "unit_type": "word",
      "text": "我想到她和游戏，",
      "sentence_id": "sent_024",
      "word_index_in_sentence": 1,
      "char_start": 604,
      "char_end": 611
    },
    {
      "unit_id": "word_024_002",
      "unit_type": "word",
      "text": "还是去结账吧。",
      "sentence_id": "sent_024",
      "word_index_in_sentence": 2,
      "char_start": 612,
      "char_end": 618
    },
    {
      "unit_id": "word_025_001",
      "unit_type": "word",
      "text": "结完账，",
      "sentence_id": "sent_025",
      "word_index_in_sentence": 1,
      "char_start": 619,
      "char_end": 622
    },
    {
      "unit_id": "word_025_002",
      "unit_type": "word",
      "text": "走出书店，",
      "sentence_id": "sent_025",
      "word_index_in_sentence": 2,
      "char_start": 623,
      "char_end": 627
    },
    {
      "unit_id": "word_025_003",
      "unit_type": "word",
      "text": "看了看时间，",
      "sentence_id": "sent_025",
      "word_index_in_sentence": 3,
      "char_start": 628,
      "char_end": 633
    },
    {
      "unit_id": "word_025_004",
      "unit_type": "word",
      "text": "回公司。",
      "sentence_id": "sent_025",
      "word_index_in_sentence": 4,
      "char_start": 634,
      "char_end": 637
    },
    {
      "unit_id": "word_026_001",
      "unit_type": "word",
      "text": "刷了工牌，",
      "sentence_id": "sent_026",
      "word_index_in_sentence": 1,
      "char_start": 638,
      "char_end": 642
    },
    {
      "unit_id": "word_026_002",
      "unit_type": "word",
      "text": "走进电梯，",
      "sentence_id": "sent_026",
      "word_index_in_sentence": 2,
      "char_start": 643,
      "char_end": 647
    },
    {
      "unit_id": "word_026_003",
      "unit_type": "word",
      "text": "看到快递的牌子，",
      "sentence_id": "sent_026",
      "word_index_in_sentence": 3,
      "char_start": 648,
      "char_end": 655
    },
    {
      "unit_id": "word_026_004",
      "unit_type": "word",
      "text": "有点惊讶。",
      "sentence_id": "sent_026",
      "word_index_in_sentence": 4,
      "char_start": 656,
      "char_end": 660
    },
    {
      "unit_id": "word_027_001",
      "unit_type": "word",
      "text": "按了电梯，",
      "sentence_id": "sent_027",
      "word_index_in_sentence": 1,
      "char_start": 661,
      "char_end": 665
    },
    {
      "unit_id": "word_027_002",
      "unit_type": "word",
      "text": "电梯到了1、2……89楼，",
      "sentence_id": "sent_027",
      "word_index_in_sentence": 2,
      "char_start": 666,
      "char_end": 678
    },
    {
      "unit_id": "word_027_003",
      "unit_type": "word",
      "text": "红灯停了，",
      "sentence_id": "sent_027",
      "word_index_in_sentence": 3,
      "char_start": 679,
      "char_end": 683
    },
    {
      "unit_id": "word_027_004",
      "unit_type": "word",
      "text": "开门，",
      "sentence_id": "sent_027",
      "word_index_in_sentence": 4,
      "char_start": 684,
      "char_end": 686
    },
    {
      "unit_id": "word_027_005",
      "unit_type": "word",
      "text": "出去。",
      "sentence_id": "sent_027",
      "word_index_in_sentence": 5,
      "char_start": 687,
      "char_end": 689
    },
    {
      "unit_id": "word_028_001",
      "unit_type": "word",
      "text": "左转，",
      "sentence_id": "sent_028",
      "word_index_in_sentence": 1,
      "char_start": 690,
      "char_end": 692
    },
    {
      "unit_id": "word_028_002",
      "unit_type": "word",
      "text": "直行，",
      "sentence_id": "sent_028",
      "word_index_in_sentence": 2,
      "char_start": 693,
      "char_end": 695
    },
    {
      "unit_id": "word_028_003",
      "unit_type": "word",
      "text": "转弯，",
      "sentence_id": "sent_028",
      "word_index_in_sentence": 3,
      "char_start": 696,
      "char_end": 698
    },
    {
      "unit_id": "word_028_004",
      "unit_type": "word",
      "text": "直行，",
      "sentence_id": "sent_028",
      "word_index_in_sentence": 4,
      "char_start": 699,
      "char_end": 701
    },
    {
      "unit_id": "word_028_005",
      "unit_type": "word",
      "text": "再转弯，",
      "sentence_id": "sent_028",
      "word_index_in_sentence": 5,
      "char_start": 702,
      "char_end": 705
    },
    {
      "unit_id": "word_028_006",
      "unit_type": "word",
      "text": "直行，",
      "sentence_id": "sent_028",
      "word_index_in_sentence": 6,
      "char_start": 706,
      "char_end": 708
    },
    {
      "unit_id": "word_028_007",
      "unit_type": "word",
      "text": "打卡，",
      "sentence_id": "sent_028",
      "word_index_in_sentence": 7,
      "char_start": 709,
      "char_end": 711
    },
    {
      "unit_id": "word_028_008",
      "unit_type": "word",
      "text": "刷手机，",
      "sentence_id": "sent_028",
      "word_index_in_sentence": 8,
      "char_start": 712,
      "char_end": 715
    },
    {
      "unit_id": "word_028_009",
      "unit_type": "word",
      "text": "开门。",
      "sentence_id": "sent_028",
      "word_index_in_sentence": 9,
      "char_start": 716,
      "char_end": 718
    },
    {
      "unit_id": "word_029_001",
      "unit_type": "word",
      "text": "走到工位，",
      "sentence_id": "sent_029",
      "word_index_in_sentence": 1,
      "char_start": 719,
      "char_end": 723
    },
    {
      "unit_id": "word_029_002",
      "unit_type": "word",
      "text": "坐下。",
      "sentence_id": "sent_029",
      "word_index_in_sentence": 2,
      "char_start": 724,
      "char_end": 726
    },
    {
      "unit_id": "word_030_001",
      "unit_type": "word",
      "text": "凌晨两点，",
      "sentence_id": "sent_030",
      "word_index_in_sentence": 1,
      "char_start": 727,
      "char_end": 731
    },
    {
      "unit_id": "word_030_002",
      "unit_type": "word",
      "text": "我躺在床上，",
      "sentence_id": "sent_030",
      "word_index_in_sentence": 2,
      "char_start": 732,
      "char_end": 737
    },
    {
      "unit_id": "word_030_003",
      "unit_type": "word",
      "text": "很快就进入了梦乡。",
      "sentence_id": "sent_030",
      "word_index_in_sentence": 3,
      "char_start": 738,
      "char_end": 746
    },
    {
      "unit_id": "word_031_001",
      "unit_type": "word",
      "text": "在梦里，",
      "sentence_id": "sent_031",
      "word_index_in_sentence": 1,
      "char_start": 747,
      "char_end": 750
    },
    {
      "unit_id": "word_031_002",
      "unit_type": "word",
      "text": "我看到两个人在激烈地争吵。",
      "sentence_id": "sent_031",
      "word_index_in_sentence": 2,
      "char_start": 751,
      "char_end": 763
    },
    {
      "unit_id": "word_032_001",
      "unit_type": "word",
      "text": "接着，",
      "sentence_id": "sent_032",
      "word_index_in_sentence": 1,
      "char_start": 764,
      "char_end": 766
    },
    {
      "unit_id": "word_032_002",
      "unit_type": "word",
      "text": "我梦见了 2012 年世界末日的场景，",
      "sentence_id": "sent_032",
      "word_index_in_sentence": 2,
      "char_start": 767,
      "char_end": 785
    },
    {
      "unit_id": "word_032_003",
      "unit_type": "word",
      "text": "巨大的海浪淹没了地球，",
      "sentence_id": "sent_032",
      "word_index_in_sentence": 3,
      "char_start": 786,
      "char_end": 796
    },
    {
      "unit_id": "word_032_004",
      "unit_type": "word",
      "text": "人们纷纷逃到山上避难。",
      "sentence_id": "sent_032",
      "word_index_in_sentence": 4,
      "char_start": 797,
      "char_end": 807
    },
    {
      "unit_id": "word_033_001",
      "unit_type": "word",
      "text": "凌晨三点，",
      "sentence_id": "sent_033",
      "word_index_in_sentence": 1,
      "char_start": 808,
      "char_end": 812
    },
    {
      "unit_id": "word_033_002",
      "unit_type": "word",
      "text": "我被蚊子的嗡嗡声吵醒了。",
      "sentence_id": "sent_033",
      "word_index_in_sentence": 2,
      "char_start": 813,
      "char_end": 824
    },
    {
      "unit_id": "word_034_001",
      "unit_type": "word",
      "text": "我听到外面有人在吵架，",
      "sentence_id": "sent_034",
      "word_index_in_sentence": 1,
      "char_start": 825,
      "char_end": 835
    },
    {
      "unit_id": "word_034_002",
      "unit_type": "word",
      "text": "感到非常烦躁。",
      "sentence_id": "sent_034",
      "word_index_in_sentence": 2,
      "char_start": 836,
      "char_end": 842
    },
    {
      "unit_id": "word_035_001",
      "unit_type": "word",
      "text": "我开始用手拍蚊子，",
      "sentence_id": "sent_035",
      "word_index_in_sentence": 1,
      "char_start": 843,
      "char_end": 851
    },
    {
      "unit_id": "word_035_002",
      "unit_type": "word",
      "text": "并用杀虫剂喷它们，",
      "sentence_id": "sent_035",
      "word_index_in_sentence": 2,
      "char_start": 852,
      "char_end": 860
    },
    {
      "unit_id": "word_035_003",
      "unit_type": "word",
      "text": "但蚊子总是飞来飞去，",
      "sentence_id": "sent_035",
      "word_index_in_sentence": 3,
      "char_start": 861,
      "char_end": 870
    },
    {
      "unit_id": "word_035_004",
      "unit_type": "word",
      "text": "很难打到。",
      "sentence_id": "sent_035",
      "word_index_in_sentence": 4,
      "char_start": 871,
      "char_end": 875
    },
    {
      "unit_id": "word_036_001",
      "unit_type": "word",
      "text": "我关掉电视和灯，",
      "sentence_id": "sent_036",
      "word_index_in_sentence": 1,
      "char_start": 876,
      "char_end": 883
    },
    {
      "unit_id": "word_036_002",
      "unit_type": "word",
      "text": "准备睡觉，",
      "sentence_id": "sent_036",
      "word_index_in_sentence": 2,
      "char_start": 884,
      "char_end": 888
    },
    {
      "unit_id": "word_036_003",
      "unit_type": "word",
      "text": "但蚊子还是不停地骚扰我。",
      "sentence_id": "sent_036",
      "word_index_in_sentence": 3,
      "char_start": 889,
      "char_end": 900
    },
    {
      "unit_id": "word_037_001",
      "unit_type": "word",
      "text": "我打开台灯，",
      "sentence_id": "sent_037",
      "word_index_in_sentence": 1,
      "char_start": 901,
      "char_end": 906
    },
    {
      "unit_id": "word_037_002",
      "unit_type": "word",
      "text": "继续用杀虫剂和苍蝇拍消灭蚊子。",
      "sentence_id": "sent_037",
      "word_index_in_sentence": 2,
      "char_start": 907,
      "char_end": 921
    },
    {
      "unit_id": "word_038_001",
      "unit_type": "word",
      "text": "我追着蚊子跑，",
      "sentence_id": "sent_038",
      "word_index_in_sentence": 1,
      "char_start": 922,
      "char_end": 928
    },
    {
      "unit_id": "word_038_002",
      "unit_type": "word",
      "text": "上下挥舞着杀虫剂，",
      "sentence_id": "sent_038",
      "word_index_in_sentence": 2,
      "char_start": 929,
      "char_end": 937
    },
    {
      "unit_id": "word_038_003",
      "unit_type": "word",
      "text": "累得满头大汗。",
      "sentence_id": "sent_038",
      "word_index_in_sentence": 3,
      "char_start": 938,
      "char_end": 944
    },
    {
      "unit_id": "word_039_001",
      "unit_type": "word",
      "text": "最后，",
      "sentence_id": "sent_039",
      "word_index_in_sentence": 1,
      "char_start": 945,
      "char_end": 947
    },
    {
      "unit_id": "word_039_002",
      "unit_type": "word",
      "text": "我终于打死了一只蚊子，",
      "sentence_id": "sent_039",
      "word_index_in_sentence": 2,
      "char_start": 948,
      "char_end": 958
    },
    {
      "unit_id": "word_039_003",
      "unit_type": "word",
      "text": "手上沾满了血。",
      "sentence_id": "sent_039",
      "word_index_in_sentence": 3,
      "char_start": 959,
      "char_end": 965
    },
    {
      "unit_id": "word_040_001",
      "unit_type": "word",
      "text": "我关掉台灯，",
      "sentence_id": "sent_040",
      "word_index_in_sentence": 1,
      "char_start": 966,
      "char_end": 971
    },
    {
      "unit_id": "word_040_002",
      "unit_type": "word",
      "text": "终于可以安心睡觉了。",
      "sentence_id": "sent_040",
      "word_index_in_sentence": 2,
      "char_start": 972,
      "char_end": 981
    }
  ],
  "annotations": [
    {
      "annotation_id": "ann_ft_001",
