    "source_text": {
        "text_id": "10",
        "title": "10点",
        "source": "教师提供",
        "raw_text": "我看了眼时钟，拒绝了加班，露出微笑，伸手关掉了电脑。我们两人一起下楼，走向星巴克。我看着红衣服的同事，他挥了挥手，我们便坐了下来。同事和我聊起天来：“这天气时晴时阴，眼看又要下雨了……”我听着，心里有点无奈，又有点不安。我笑着说：“来杯咖啡和牛角包。”同事端着绿茶说：“看世界杯，巴西对葡萄牙！”我忍不住笑了。我捧着咖啡说：“看这球赛的精彩瞬间！”同事又说：“最近在找房子。”我接话：“刚看新闻，说房价跌了。”我又补了句：“不过油价倒是涨了！”同事说：“我看股票涨了。”同事又吐槽：“油价涨得离谱，车都快开不起了！”他看起来有点生气。我叹了口气：“我看的股票跌了。”同事说：“汇率倒是涨了。”我们就这么聊着天。我们挥手告别，他下楼，我往楼上走。时钟滴答走着，我上了楼，左转右转，朝着洗手间走去。我心里想着卫生棉条的事，走进洗手间，看着棉条，拉上了隔间的拉链。我看着棉条，发了会儿呆。走出隔间，我有点懵，耳边好像响起了音乐，看着不远处的女生，她回头看了我一眼。我看着她，想起她整理衣服的样子，心里有点心动。时钟继续走着，我往工位走，想起了垃圾分类的事。我把垃圾丢了，走回工位，坐了下来。",
        "notes": "用于自然语言文本标注示例"
    },
    "units": [
        {
        "unit_id": "sent_001",
        "unit_type": "sentence",
        "text": "我看了眼时钟，拒绝了加班，露出了微笑，伸手关掉了电脑。",
        "sentence_index": 1,
        "char_start": 0,
        "char_end": 24,
        "children": ["word_001", "word_002", "word_003", "word_004", "word_005", "word_006", "word_007", "word_008"]
        },
        {
        "unit_id": "sent_002",
        "unit_type": "sentence",
        "text": "我们两人一起下楼，走向星巴克。",
        "sentence_index": 2,
        "char_start": 25,
        "char_end": 39,
        "children": ["word_009", "word_010", "word_011", "word_012"]
        },
        {
        "unit_id": "sent_003",
        "unit_type": "sentence",
        "text": "我看着红衣服的同事，他挥了挥手，我们便坐了下来。",
        "sentence_index": 3,
        "char_start": 40,
        "char_end": 64,
        "children": ["word_013", "word_014", "word_015", "word_016", "word_017", "word_018", "word_019", "word_020", "word_021", "word_022"]
        },
        {
        "unit_id": "sent_004",
        "unit_type": "sentence",
        "text": "同事和我聊起天来：“这天气时晴时阴，眼看又要下雨了……”",
        "sentence_index": 4,
        "char_start": 65,
        "char_end": 89,
        "children": ["word_023", "word_024", "word_025", "word_026", "word_027", "word_028", "word_029", "word_030", "word_031", "word_032", "word_033", "word_034", "word_035", "word_036"]
        },
        {
        "unit_id": "sent_005",
        "unit_type": "sentence",
        "text": "我听着，心里有点无奈，又有点不安。",
        "sentence_index": 5,
        "char_start": 90,
        "char_end": 107,
        "children": ["word_037", "word_038", "word_039", "word_040", "word_041", "word_042", "word_043", "word_044", "word_045"]
        },
        {
        "unit_id": "sent_006",
        "unit_type": "sentence",
        "text": "我笑着说：“来杯咖啡和牛角包。”",
        "sentence_index": 6,
        "char_start": 108,
        "char_end": 123,
        "children": ["word_046", "word_047", "word_048", "word_049", "word_050", "word_051", "word_052", "word_053"]
        },
        {
        "unit_id": "sent_007",
        "unit_type": "sentence",
        "text": "同事端着绿茶说：“看世界杯，巴西对葡萄牙！”",
        "sentence_index": 7,
        "char_start": 124,
        "char_end": 145,
        "children": ["word_054", "word_055", "word_056", "word_057", "word_058", "word_059", "word_060", "word_061", "word_062", "word_063", "word_064"]
        },
        {
        "unit_id": "sent_008",
        "unit_type": "sentence",
        "text": "我忍不住笑了。",
        "sentence_index": 8,
        "char_start": 146,
        "char_end": 153,
        "children": ["word_065", "word_066", "word_067"]
        },
        {
        "unit_id": "sent_009",
        "unit_type": "sentence",
        "text": "我捧着咖啡说：“看这球赛的精彩瞬间！”",
        "sentence_index": 9,
        "char_start": 154,
        "char_end": 173,
        "children": ["word_068", "word_069", "word_070", "word_071", "word_072", "word_073", "word_074", "word_075", "word_076"]
        },
        {
        "unit_id": "sent_010",
        "unit_type": "sentence",
        "text": "同事又说：“最近在找房子。”",
        "sentence_index": 10,
        "char_start": 174,
        "char_end": 188,
        "children": ["word_077", "word_078", "word_079", "word_080", "word_081", "word_082"]
        },
        {
        "unit_id": "sent_011",
        "unit_type": "sentence",
        "text": "我接话：“刚看新闻，说房价跌了。”",
        "sentence_index": 11,
        "char_start": 189,
        "char_end": 205,
        "children": ["word_083", "word_084", "word_085", "word_086", "word_087", "word_088", "word_089", "word_090", "word_091"]
        },
        {
        "unit_id": "sent_012",
        "unit_type": "sentence",
        "text": "我又补了句：“不过油价倒是涨了！”",
        "sentence_index": 12,
        "char_start": 206,
        "char_end": 223,
        "children": ["word_092", "word_093", "word_094", "word_095", "word_096", "word_097", "word_098", "word_099", "word_100"]
        },
        {
        "unit_id": "sent_013",
        "unit_type": "sentence",
        "text": "同事说：“我看股票涨了。”",
        "sentence_index": 13,
        "char_start": 224,
        "char_end": 237,
        "children": ["word_101", "word_102", "word_103", "word_104", "word_105", "word_106"]
        },
        {
        "unit_id": "sent_014",
        "unit_type": "sentence",
        "text": "同事又吐槽：“油价涨得离谱，车都快开不起了！”",
        "sentence_index": 14,
        "char_start": 238,
        "char_end": 261,
        "children": ["word_107", "word_108", "word_109", "word_110", "word_111", "word_112", "word_113", "word_114", "word_115", "word_116", "word_117", "word_118", "word_119", "word_120"]
        },
        {
        "unit_id": "sent_015",
        "unit_type": "sentence",
        "text": "他看起来有点生气。",
        "sentence_index": 15,
        "char_start": 262,
        "char_end": 272,
        "children": ["word_121", "word_122", "word_123", "word_124"]
        },
        {
        "unit_id": "sent_016",
        "unit_type": "sentence",
        "text": "我叹了口气：“我看的股票跌了。”",
        "sentence_index": 16,
        "char_start": 273,
        "char_end": 289,
        "children": ["word_125", "word_126", "word_127", "word_128", "word_129", "word_130", "word_131", "word_132"]
        },
        {
        "unit_id": "sent_017",
        "unit_type": "sentence",
        "text": "同事说：“汇率倒是涨了。”",
        "sentence_index": 17,
        "char_start": 290,
        "char_end": 303,
        "children": ["word_133", "word_134", "word_135", "word_136", "word_137", "word_138"]
        },
        {
        "unit_id": "sent_018",
        "unit_type": "sentence",
        "text": "我们就这么聊着天。",
        "sentence_index": 18,
        "char_start": 304,
        "char_end": 313,
        "children": ["word_139", "word_140", "word_141"]
        },
        {
        "unit_id": "sent_019",
        "unit_type": "sentence",
        "text": "我们挥手告别，他下楼，我往楼上走。",
        "sentence_index": 19,
        "char_start": 314,
        "char_end": 334,
        "children": ["word_142", "word_143", "word_144", "word_145", "word_146", "word_147", "word_148", "word_149", "word_150", "word_151"]
        },
        {
        "unit_id": "sent_020",
        "unit_type": "sentence",
        "text": "时钟滴答走着，我上了楼，左转右转，朝着洗手间走去。",
        "sentence_index": 20,
        "char_start": 335,
        "char_end": 363,
        "children": ["word_152", "word_153", "word_154", "word_155", "word_156", "word_157", "word_158", "word_159", "word_160"]
        },
        {
        "unit_id": "sent_021",
        "unit_type": "sentence",
        "text": "我心里想着卫生棉条的事，走进洗手间，看着棉条，拉上了隔间的拉链。",
        "sentence_index": 21,
        "char_start": 364,
        "char_end": 403,
        "children": ["word_161", "word_162", "word_163", "word_164", "word_165", "word_166", "word_167", "word_168", "word_169", "word_170", "word_171", "word_172", "word_173", "word_174"]
        },
        {
        "unit_id": "sent_022",
        "unit_type": "sentence",
        "text": "我看着棉条，发了会儿呆。",
        "sentence_index": 22,
        "char_start": 404,
        "char_end": 418,
        "children": ["word_175", "word_176", "word_177", "word_178", "word_179"]
        },
        {
        "unit_id": "sent_023",
        "unit_type": "sentence",
        "text": "走出隔间，我有点懵，耳边好像响起了音乐，看着不远处的女生，她回头看了我一眼。",
        "sentence_index": 23,
        "char_start": 419,
        "char_end": 462,
        "children": ["word_180", "word_181", "word_182", "word_183", "word_184", "word_185", "word_186", "word_187", "word_188", "word_189", "word_190", "word_191", "word_192", "word_193", "word_194", "word_195", "word_196", "word_197"]
        },
        {
        "unit_id": "sent_024",
        "unit_type": "sentence",
        "text": "我看着她，想起她整理衣服的样子，心里有点心动。",
        "sentence_index": 24,
        "char_start": 463,
        "char_end": 490,
        "children": ["word_198", "word_199", "word_200", "word_201", "word_202", "word_203", "word_204", "word_205", "word_206", "word_207", "word_208", "word_209"]
        },
        {
        "unit_id": "sent_025",
        "unit_type": "sentence",
        "text": "时钟继续走着，我往工位走，想起了垃圾分类的事。",
        "sentence_index": 25,
        "char_start": 491,
        "char_end": 517,
        "children": ["word_210", "word_211", "word_212", "word_213", "word_214", "word_215", "word_216", "word_217", "word_218"]
        },
        {
        "unit_id": "sent_026",
        "unit_type": "sentence",
        "text": "我把垃圾丢了，走回工位，坐了下来。",
        "sentence_index": 26,
        "char_start": 518,
        "char_end": 537,
        "children": ["word_219", "word_220", "word_221", "word_222", "word_223", "word_224", "word_225", "word_226"]
        },
