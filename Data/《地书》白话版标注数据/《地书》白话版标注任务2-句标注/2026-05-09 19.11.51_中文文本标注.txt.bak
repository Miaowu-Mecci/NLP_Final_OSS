    "annotations": [
    {
        "annotation_id": "ann_001",
        "target_id": "sent_001",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我看了看墙上的时钟，拒绝了加班的请求，脸上露出了微笑，然后伸手把电脑给关了。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "将一连串动作分解，使用更口语化的表达，突出动作的先后顺序。"
    },
    {
        "annotation_id": "ann_002",
        "target_id": "sent_002",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我和同事两个人一起下了楼，朝着星巴克走去。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "用更自然的语序重述。"
    },
    {
        "annotation_id": "ann_003",
        "target_id": "sent_003",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我发现那个穿红衣服的同事也在，他对我招了招手，于是我们就坐了下来。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "补充因果关联词，使逻辑更清晰。"
    },
    {
        "annotation_id": "ann_004",
        "target_id": "sent_004",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "同事和我闲聊起来，他抱怨说：“这天气一会儿晴天一会儿阴天，看样子马上又要下雨了……”",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "将“聊起天来”译为“闲聊”，并明确“眼看”的预测意味。"
    },
    {
        "annotation_id": "ann_005",
        "target_id": "sent_005",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我一边听他说，心里一边觉得有些无奈，还隐隐有些不安的感觉。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "用“一边...一边...”反映同时发生的心理活动，更符合中文口语习惯。"
    },
    {
        "annotation_id": "ann_006",
        "target_id": "sent_006",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我笑了笑，对他们说：“来一杯咖啡和一个牛角包吧。”",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "“笑着说”直接译成更简单的“笑了笑”，句子更流畅。"
    },
    {
        "annotation_id": "ann_007",
        "target_id": "sent_007",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "同事手里捧着他的绿茶，提议道：“咱们看世界杯吧，现在是巴西队对上葡萄牙队！”",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "补充“现在是”以强化比赛正在进行的状态。"
    },
    {
        "annotation_id": "ann_008",
        "target_id": "sent_008",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "听到这话，我忍不住笑了起来。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "补充“听到这话”，让“忍不住笑了”的上下文更完整。"
    },
    {
        "annotation_id": "ann_009",
        "target_id": "sent_009",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我端着手中的咖啡说：“快看球场上这个精彩的瞬间！”",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "调整语序，更符合口语。"
    },
    {
        "annotation_id": "ann_010",
        "target_id": "sent_010",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "同事接着又聊起：“最近我一直在找房子呢。”",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "用“接着又聊起”继承对话关系，用“在···呢”保留中文口语的进行时态。"
    },
    {
        "annotation_id": "ann_011",
        "target_id": "sent_011",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我接过话茬说：“我刚刚看新闻，说房价好像跌了。”",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "“接话”意译为“接过话茬”，使句子更自然。"
    },
    {
        "annotation_id": "ann_012",
        "target_id": "sent_012",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我又加了一句：“不过石油价格倒是涨上去了！”",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "“补了句”译成更白话的“加了一句”。"
    },
    {
        "annotation_id": "ann_013",
        "target_id": "sent_013",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "同事回应道：“我手里的股票倒是涨了。”",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "补充“手里”以对应原文“我看的股票”。"
    },
    {
        "annotation_id": "ann_014",
        "target_id": "sent_014",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "同事又忍不住埋怨道：“油价涨得也太离谱了，我的车都快开不起了！”",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "“吐槽”译为更具体的“埋怨”，并加“忍不住”强化情绪。"
    },
    {
        "annotation_id": "ann_015",
        "target_id": "sent_015",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "他看上去好像有点气不过的样子。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "将“生气”具体化为“气不过的样子”，更符合口语。"
    },
    {
        "annotation_id": "ann_016",
        "target_id": "sent_016",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我叹了口气，说：“我看的那些股票倒是都跌了。”",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "原文“我看的股票”理解为“我看的那些股票”。"
    },
    {
        "annotation_id": "ann_017",
        "target_id": "sent_017",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "同事说：“人民币兑美元的汇率倒是涨上来了。”",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "明确“汇率”的具体对象。"
    },
    {
        "annotation_id": "ann_018",
        "target_id": "sent_018",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "就这样，我们你一言我一语的闲聊了起来。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "用成语“你一言我一语”生动概括对话场景。"
    },
    {
        "annotation_id": "ann_019",
        "target_id": "sent_019",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我们挥手道了别，他转身去楼下，我一个人往楼上走去。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "拆分三人称动作，逻辑更清楚。"
    },
    {
        "annotation_id": "ann_020",
        "target_id": "sent_020",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "远处只听到时钟滴答滴答地走着，我上了楼，在走廊里绕来绕去，最后朝着洗手间那边走了过去。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "将“左转右转”意译为“绕来绕去”，更符合中文口语表达。"
    },
    {
        "annotation_id": "ann_021",
        "target_id": "sent_021",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我心里惦记着卫生棉条的事，就走进洗手间，盯着棉条发了一下呆，然后拉上了隔间的拉链。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "将“想着”具体化为“惦记着”，并将“走进”“看着”等动作用更连贯的方式重述。"
    },
    {
        "annotation_id": "ann_022",
        "target_id": "sent_022",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我看着卫生棉条，愣愣地发了一会儿呆。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "用“愣愣地”修饰“发呆”，使描写更生动。"
    },
    {
        "annotation_id": "ann_023",
        "target_id": "sent_023",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我从隔间走出来，脑子有点迷迷糊糊的，耳边似乎响起了一阵音乐。我看见不远处站着一个女生，她刚好也回头看了我一眼。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "拆分长句为两个短句，更符合中文表达习惯。"
    },
    {
        "annotation_id": "ann_024",
        "target_id": "sent_024",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我看着她的背影，脑海里浮现出刚才她整理衣服的样子，心里忽然感到有点心动。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "用“忽然感到”突出心动的瞬间性。"
    },
    {
        "annotation_id": "ann_025",
        "target_id": "sent_025",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "时钟还在继续往前走着，我一边往工位走，一边忽然想起了垃圾分类相关的事情。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "用“一边...一边...”结构突出两个动作的同时性。"
    },
    {
        "annotation_id": "ann_026",
        "target_id": "sent_026",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我把垃圾丢掉，然后走回了工位，坐下来歇了一会儿。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "用“歇了一会儿”补充“坐下来”之后的潜在状态。"
    }
    ]
}