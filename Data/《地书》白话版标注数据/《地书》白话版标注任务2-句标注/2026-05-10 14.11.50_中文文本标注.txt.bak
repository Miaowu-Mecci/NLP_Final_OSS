      "char_end": 41,
      "children": []
    },
    {
      "unit_id": "sent_003",
      "unit_type": "sentence",
      "text": "我看了眼手机信号，路过限速280的路牌，前方有警示标识，路上严重拥堵，公交无法通行。",
      "sentence_index": 3,
      "char_start": 42,
