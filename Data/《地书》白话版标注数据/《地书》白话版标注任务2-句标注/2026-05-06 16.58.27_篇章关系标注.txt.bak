  "source_text": {
    "text_id": "text_001",
    "title": "中文自然文本",
    "source": "教师提供",
    "raw_text": "\n午夜十二点，我没有开车，而是选择步行回家。我看着地图，沿着脚下的脚印，一步步向前走。路上很安静，只有我一个人的脚步声。\n我经过了一个门口，又经过了一个警察局门口。走着走着，我看到一个女人，抬头看了看天空，然后继续往前走。\n沿着长长的脚印，我终于走到了家。\n",
    "notes": "篇章关系标注任务"
  },
  "units": [
    {
      "unit_id": "sent_001",
      "unit_type": "sentence",
      "text": "午夜十二点，我没有开车，而是选择步行回家。",
      "sentence_index": 1,
      "char_start": 0,
      "char_end": 17,
      "children": []
    },
    {
      "unit_id": "sent_002",
      "unit_type": "sentence",
      "text": "我看着地图，沿着脚下的脚印，一步步向前走。",
      "sentence_index": 2,
      "char_start": 18,
      "char_end": 41,
      "children": []
    },
    {
      "unit_id": "sent_003",
      "unit_type": "sentence",
      "text": "路上很安静，只有我一个人的脚步声。",
      "sentence_index": 3,
      "char_start": 42,
      "char_end": 60,
      "children": []
    },
    {
      "unit_id": "sent_004",
      "unit_type": "sentence",
      "text": "我经过了一个门口，又经过了一个警察局门口。",
      "sentence_index": 4,
      "char_start": 61,
      "char_end": 83,
      "children": []
    },
    {
      "unit_id": "sent_005",
      "unit_type": "sentence",
      "text": "走着走着，我看到一个女人，抬头看了看天空，然后继续往前走。",
      "sentence_index": 5,
      "char_start": 84,
      "char_end": 117,
      "children": []
    },
    {
      "unit_id": "sent_006",
      "unit_type": "sentence",
      "text": "沿着长长的脚印，我终于走到了家。",
      "sentence_index": 6,
      "char_start": 118,
      "char_end": 136,
      "children": []
    }
