  "source_text": {
    "text_id": "text_001",
    "title": "23点车祸现场",
    "source": "教师提供",
    "raw_text": "晚上十一点，我在回家的路上，看到前面发生了一起车祸。两辆车撞在了一起，车主们正在激烈地争吵，互相指责对方的过错。我感到非常惊讶，停下脚步观看。\n很快，警察赶到了现场。他们介入调查，询问了两位车主的情况。警察也向我询问了事情的经过，我笑着配合调查，给他们看了我的手机和电脑记录，证明我与此事无关。\n警察对我的说法感到有些疑惑，我紧张得流了汗。他们查看了我的手机记录后，让我先在一旁等待，然后继续调查另一位车主。我站在那里，看着警察忙碌的身影，心里想着这场车祸到底是谁的责任。",
    "notes": "23:00时间段文本 - 任务2：语句划分及篇章关系标注"
  },
  "units": [
    {
      "unit_id": "sent_001",
      "unit_type": "sentence",
      "text": "晚上十一点",
      "sentence_index": 1,
      "char_start": 0,
      "char_end": 5,
      "children": []
    },
    {
      "unit_id": "sent_002",
      "unit_type": "sentence",
      "text": "我在回家的路上",
      "sentence_index": 2,
      "char_start": 6,
      "char_end": 13,
      "children": []
    },
    {
      "unit_id": "sent_003",
      "unit_type": "sentence",
      "text": "看到前面发生了一起车祸",
      "sentence_index": 3,
      "char_start": 14,
      "char_end": 26,
      "children": []
    },
    {
      "unit_id": "sent_004",
      "unit_type": "sentence",
      "text": "两辆车撞在了一起",
      "sentence_index": 4,
      "char_start": 27,
      "char_end": 36,
      "children": []
    },
    {
      "unit_id": "sent_005",
      "unit_type": "sentence",
      "text": "车主们正在激烈地争吵",
      "sentence_index": 5,
      "char_start": 37,
      "char_end": 48,
      "children": []
    },
    {
      "unit_id": "sent_006",
      "unit_type": "sentence",
      "text": "互相指责对方的过错",
      "sentence_index": 6,
      "char_start": 49,
      "char_end": 59,
      "children": []
    },
    {
      "unit_id": "sent_007",
      "unit_type": "sentence",
      "text": "我感到非常惊讶",
      "sentence_index": 7,
      "char_start": 60,
      "char_end": 67,
      "children": []
    },
    {
      "unit_id": "sent_008",
      "unit_type": "sentence",
      "text": "停下脚步观看",
      "sentence_index": 8,
      "char_start": 68,
      "char_end": 74,
      "children": []
    },
    {
      "unit_id": "sent_009",
      "unit_type": "sentence",
      "text": "很快，",
      "sentence_index": 9,
      "char_start": 0,
      "char_end": 3,
      "children": []
    },
    {
      "unit_id": "sent_010",
      "unit_type": "sentence",
      "text": "警察赶到了现场。",
      "sentence_index": 10,
      "char_start": 4,
      "char_end": 12,
      "children": []
    },
    {
      "unit_id": "sent_011",
      "unit_type": "sentence",
      "text": "他们介入调查，",
      "sentence_index": 11,
      "char_start": 13,
      "char_end": 19,
      "children": []
    },
    {
      "unit_id": "sent_012",
      "unit_type": "sentence",
      "text": "询问了两位车主的情况。",
      "sentence_index": 12,
      "char_start": 20,
      "char_end": 32,
      "children": []
    },
    {
      "unit_id": "sent_013",
      "unit_type": "sentence",
      "text": "警察也向我询问了事情的经过，",
      "sentence_index": 13,
      "char_start": 33,
      "char_end": 48,
      "children": []
    },
    {
      "unit_id": "sent_014",
      "unit_type": "sentence",
      "text": "我笑着配合调查，",
      "sentence_index": 14,
      "char_start": 49,
      "char_end": 57,
      "children": []
    },
    {
      "unit_id": "sent_015",
      "unit_type": "sentence",
      "text": "给他们看了我的手机和电脑记录，",
      "sentence_index": 15,
      "char_start": 58,
      "char_end": 74,
      "children": []
    },
    {
      "unit_id": "sent_016",
      "unit_type": "sentence",
      "text": "证明我与此事无关。",
      "sentence_index": 16,
      "char_start": 75,
      "char_end": 85,
      "children": []
    },
    {
      "unit_id": "sent_017",
      "unit_type": "sentence",
      "text": "警察对我的说法感到有些疑惑，",
      "sentence_index": 17,
      "char_start": 0,
      "char_end": 15,
      "children": []
    },
    {
      "unit_id": "sent_018",
      "unit_type": "sentence",
      "text": "我紧张得流了汗。",
      "sentence_index": 18,
      "char_start": 16,
      "char_end": 25,
      "children": []
    },
    {
      "unit_id": "sent_019",
      "unit_type": "sentence",
      "text": "他们查看了我的手机记录后，",
      "sentence_index": 19,
      "char_start": 26,
      "char_end": 40,
      "children": []
    },
    {
      "unit_id": "sent_020",
      "unit_type": "sentence",
      "text": "让我先在一旁等待，",
      "sentence_index": 20,
      "char_start": 41,
      "char_end": 51,
      "children": []
    },
    {
      "unit_id": "sent_021",
      "unit_type": "sentence",
      "text": "然后继续调查另一位车主。",
      "sentence_index": 21,
      "char_start": 52,
      "char_end": 65,
      "children": []
    },
    {
      "unit_id": "sent_022",
      "unit_type": "sentence",
      "text": "我站在那里，",
      "sentence_index": 22,
      "char_start": 66,
      "char_end": 72,
      "children": []
    },
    {
      "unit_id": "sent_023",
      "unit_type": "sentence",
      "text": "看着警察忙碌的身影，",
      "sentence_index": 23,
      "char_start": 73,
      "char_end": 85,
      "children": []
    },
    {
      "unit_id": "sent_024",
      "unit_type": "sentence",
      "text": "心里想着这场车祸到底是谁的责任。",
      "sentence_index": 24,
      "char_start": 86,
      "char_end": 104,
      "children": []
    }
  ],
