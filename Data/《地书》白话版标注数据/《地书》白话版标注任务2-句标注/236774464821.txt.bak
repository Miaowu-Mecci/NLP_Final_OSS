      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "后来，老友说要坐公交车回家，这时候外面下起雨来了。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "交代离开方式与天气变化"
    },
    {
      "annotation_id": "ann_009",
