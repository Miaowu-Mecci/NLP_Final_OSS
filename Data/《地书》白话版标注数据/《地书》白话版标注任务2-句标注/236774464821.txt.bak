      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "没过多久，老友也来了，他跟我说自己失恋了，心里特别难受。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "传递失恋事实与内心难过"
    },
    {
      "annotation_id": "ann_006",
      "target_id": "sent_006",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我笑着安慰他，劝他别再想那些不开心的事了。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "突出安慰行为与劝导内容"
    },
    {
      "annotation_id": "ann_007",
      "target_id": "sent_007",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我俩一边喝酒，一边让时间悄悄过去。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "简洁表达相伴与时间流逝"
    },
    {
      "annotation_id": "ann_008",
