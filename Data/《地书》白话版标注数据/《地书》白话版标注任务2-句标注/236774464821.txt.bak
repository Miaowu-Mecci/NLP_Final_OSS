      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我只好无可奈何地坐在车里干等着，心里急得不行。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "突出无奈与焦急情绪"
    },
    {
      "annotation_id": "ann_004",
