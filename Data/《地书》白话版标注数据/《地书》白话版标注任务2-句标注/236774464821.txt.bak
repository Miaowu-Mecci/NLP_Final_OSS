      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我在楼下等他，他问我是不是跟那个女人分手了，又问我是不是要坐公交车。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "清晰表达等待与对话内容"
