      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "好不容易才回到家里，我打开酒开始喝。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "简洁表达归家与开始喝酒"
