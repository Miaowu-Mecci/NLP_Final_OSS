      "target_id": "sent_004",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我正要走的时候，上司忽然喊住我，问我今晚有没有什么计划。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
