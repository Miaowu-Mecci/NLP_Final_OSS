      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我匆忙收拾好桌面上的文档、书本和计算器，把剩余的几封邮件也处理完毕，然后关掉了电脑。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
