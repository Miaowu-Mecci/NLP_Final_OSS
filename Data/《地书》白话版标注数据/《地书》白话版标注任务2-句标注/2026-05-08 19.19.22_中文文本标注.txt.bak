      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "忙了一整天实在太累了，我现在唯一的想法就是赶紧回家好好歇一歇。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
