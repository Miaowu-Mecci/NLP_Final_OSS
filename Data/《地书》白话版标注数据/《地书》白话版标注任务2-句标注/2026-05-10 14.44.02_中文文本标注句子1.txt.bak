    {
      "unit_id": "sent_001",
      "unit_type": "sentence",
      "text": "时钟指向下午两点，我深吸一口气，点开电脑，准备开始赶工。",
      "sentence_index": 1,
      "char_start": 0,
      "char_end": 27,
      "children": ["word_001", "word_002", "word_003", "word_004", "word_005", "word_006", "word_007", "word_008", "word_009", "word_010", "word_011", "word_012"]
    },
    {
      "unit_id": "sent_002",
      "unit_type": "sentence",
      "text": "时间紧迫，我得抓紧每一分每一秒。",
      "sentence_index": 2,
      "char_start": 28,
      "char_end": 45,
      "children": ["word_013", "word_014", "word_015", "word_016", "word_017", "word_018", "word_019", "word_020", "word_021"]
