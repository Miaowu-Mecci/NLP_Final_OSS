    {
      "unit_id": "sent_003",
      "unit_type": "sentence",
      "text": "我快速地处理着文件，将它们保存、关闭，然后发送到打印机。",
      "sentence_index": 3,
      "char_start": 46,
      "char_end": 79,
      "children": ["word_022", "word_023", "word_024", "word_025", "word_026", "word_027", "word_028", "word_029", "word_030", "word_031", "word_032", "word_033", "word_034", "word_035", "word_036"]
    },
    {
      "unit_id": "sent_004",
      "unit_type": "sentence",
      "text": "打印的过程中，我收到了一封邮件，是领导发来的。",
      "sentence_index": 4,
      "char_start": 80,
      "char_end": 103,
      "children": ["word_037", "word_038", "word_039", "word_040", "word_041", "word_042", "word_043", "word_044", "word_045", "word_046", "word_047", "word_048"]
    },
    {
      "unit_id": "sent_005",
      "unit_type": "sentence",
      "text": "我一看内容，顿时面露难色。",
      "sentence_index": 5,
      "char_start": 104,
      "char_end": 118,
      "children": ["word_049", "word_050", "word_051", "word_052", "word_053", "word_054", "word_055"]
    },
    {
      "unit_id": "sent_006",
      "unit_type": "sentence",
      "text": "紧接着，领导的催促电话就打了进来，他在电话那头不停地催促我，问我进度如何。",
      "sentence_index": 6,
      "char_start": 119,
      "char_end": 160,
      "children": ["word_056", "word_057", "word_058", "word_059", "word_060", "word_061", "word_062", "word_063", "word_064", "word_065", "word_066", "word_067", "word_068", "word_069", "word_070", "word_071", "word_072", "word_073"]
    },
    {
      "unit_id": "sent_007",
      "unit_type": "sentence",
      "text": "我急得像热锅上的蚂蚁，在工位上团团转，额头直冒汗。",
      "sentence_index": 7,
      "char_start": 161,
      "char_end": 187,
      "children": ["word_074", "word_075", "word_076", "word_077", "word_078", "word_079", "word_080", "word_081", "word_082", "word_083", "word_084", "word_085", "word_086"]
    },
    {
      "unit_id": "sent_008",
      "unit_type": "sentence",
      "text": "我绞尽脑汁，想着该如何完成这项紧急任务。",
      "sentence_index": 8,
      "char_start": 188,
      "char_end": 210,
      "children": ["word_087", "word_088", "word_089", "word_090", "word_091", "word_092", "word_093", "word_094", "word_095", "word_096", "word_097"]
    },
    {
      "unit_id": "sent_009",
      "unit_type": "sentence",
      "text": "我需要打印大量的文件，包括文件夹里的资料、键盘录入的内容、文档、书籍和报表。",
      "sentence_index": 9,
      "char_start": 211,
      "char_end": 256,
      "children": ["word_098", "word_099", "word_100", "word_101", "word_102", "word_103", "word_104", "word_105", "word_106", "word_107", "word_108", "word_109", "word_110", "word_111", "word_112", "word_113", "word_114", "word_115", "word_116", "word_117", "word_118"]
    },
    {
      "unit_id": "sent_010",
      "unit_type": "sentence",
      "text": "就在我手忙脚乱的时候，电话又响了，是另一个关于不同项目的咨询。",
      "sentence_index": 10,
      "char_start": 257,
      "char_end": 288,
      "children": ["word_119", "word_120", "word_121", "word_122", "word_123", "word_124", "word_125", "word_126", "word_127", "word_128", "word_129", "word_130", "word_131", "word_132", "word_133", "word_134"]
    },
    {
      "unit_id": "sent_011",
      "unit_type": "sentence",
      "text": "事情似乎遇到了阻碍，我有点沮丧，但电话那头又传来了好消息，让我松了一口气。",
      "sentence_index": 11,
      "char_start": 289,
      "char_end": 334,
      "children": ["word_135", "word_136", "word_137", "word_138", "word_139", "word_140", "word_141", "word_142", "word_143", "word_144", "word_145", "word_146", "word_147", "word_148", "word_149", "word_150", "word_151", "word_152", "word_153"]
    },
    {
      "unit_id": "sent_012",
      "unit_type": "sentence",
      "text": "这时，一位资深的同事（或领导）走了过来，指着我的屏幕质问我：“你看你弄的这是什么？”",
      "sentence_index": 12,
      "char_start": 335,
      "char_end": 382,
      "children": ["word_154", "word_155", "word_156", "word_157", "word_158", "word_159", "word_160", "word_161", "word_162", "word_163", "word_164", "word_165", "word_166", "word_167", "word_168", "word_169", "word_170", "word_171"]
    },
    {
      "unit_id": "sent_013",
      "unit_type": "sentence",
      "text": "我在电话里被他狠狠地骂了一顿，感觉自己就像被枪和锤子轮番攻击。",
      "sentence_index": 13,
      "char_start": 383,
      "char_end": 421,
      "children": ["word_172", "word_173", "word_174", "word_175", "word_176", "word_177", "word_178", "word_179", "word_180", "word_181", "word_182", "word_183", "word_184", "word_185", "word_186", "word_187", "word_188"]
    },
    {
      "unit_id": "sent_014",
      "unit_type": "sentence",
      "text": "他要求我必须连夜打印出来，否则后果不堪设想。",
      "sentence_index": 14,
      "char_start": 422,
      "char_end": 449,
      "children": ["word_189", "word_190", "word_191", "word_192", "word_193", "word_194", "word_195", "word_196", "word_197", "word_198", "word_199", "word_200", "word_201"]
    },
    {
      "unit_id": "sent_015",
      "unit_type": "sentence",
      "text": "我向他解释，如果不完成打印，我可能连饭都吃不上。",
      "sentence_index": 15,
      "char_start": 450,
      "char_end": 477,
      "children": ["word_202", "word_203", "word_204", "word_205", "word_206", "word_207", "word_208", "word_209", "word_210", "word_211", "word_212", "word_213", "word_214"]
    },
    {
      "unit_id": "sent_016",
      "unit_type": "sentence",
      "text": "他质疑我的工作量，问我是不是在偷懒。",
      "sentence_index": 16,
      "char_start": 478,
      "char_end": 500,
      "children": ["word_215", "word_216", "word_217", "word_218", "word_219", "word_220", "word_221", "word_222", "word_223", "word_224", "word_225"]
    },
    {
      "unit_id": "sent_017",
      "unit_type": "sentence",
      "text": "我反驳说我不是为了吃饭才工作，但最终还是做出了让步，接受了他提出的要求。",
      "sentence_index": 17,
      "char_start": 501,
      "char_end": 546,
      "children": ["word_226", "word_227", "word_228", "word_229", "word_230", "word_231", "word_232", "word_233", "word_234", "word_235", "word_236", "word_237", "word_238", "word_239", "word_240", "word_241", "word_242", "word_243", "word_244", "word_245"]
    },
    {
      "unit_id": "sent_018",
      "unit_type": "sentence",
      "text": "我举手示意，表示明白了，然后转身去找另一位同事帮忙。",
      "sentence_index": 18,
      "char_start": 547,
      "char_end": 576,
      "children": ["word_246", "word_247", "word_248", "word_249", "word_250", "word_251", "word_252", "word_253", "word_254", "word_255", "word_256", "word_257", "word_258"]
    },
    {
      "unit_id": "sent_019",
      "unit_type": "sentence",
      "text": "那位资深同事看到我，笑着问我吃饭了没有。",
      "sentence_index": 19,
      "char_start": 577,
      "char_end": 600,
      "children": ["word_259", "word_260", "word_261", "word_262", "word_263", "word_264", "word_265", "word_266", "word_267", "word_268", "word_269"]
    },
    {
      "unit_id": "sent_020",
      "unit_type": "sentence",
      "text": "我确认了一下文件，然后继续打印。",
      "sentence_index": 20,
      "char_start": 601,
      "char_end": 621,
      "children": ["word_270", "word_271", "word_272", "word_273", "word_274", "word_275", "word_276", "word_277", "word_278"]
    },
    {
      "unit_id": "sent_021",
      "unit_type": "sentence",
      "text": "他看到我完成了任务，对我表示了满意和认可，我也对他表示了感谢。",
      "sentence_index": 21,
      "char_start": 622,
      "char_end": 662,
      "children": ["word_279", "word_280", "word_281", "word_282", "word_283", "word_284", "word_285", "word_286", "word_287", "word_288", "word_289", "word_290", "word_291", "word_292", "word_293", "word_294", "word_295"]
    },
    {
      "unit_id": "sent_022",
      "unit_type": "sentence",
      "text": "最后，他似乎对我表示了赞赏，让我感觉自己的努力得到了回报。",
      "sentence_index": 22,
      "char_start": 663,
      "char_end": 699,
      "children": ["word_296", "word_297", "word_298", "word_299", "word_300", "word_301", "word_302", "word_303", "word_304", "word_305", "word_306", "word_307", "word_308", "word_309", "word_310"]
    },
    {
      "unit_id": "sent_023",
      "unit_type": "sentence",
      "text": "我继续埋头打印，汗水浸湿了后背。",
      "sentence_index": 23,
      "char_start": 700,
      "char_end": 722,
      "children": ["word_311", "word_312", "word_313", "word_314", "word_315", "word_316", "word_317", "word_318", "word_319", "word_320", "word_321"]
    },
    {
      "unit_id": "sent_024",
      "unit_type": "sentence",
      "text": "终于，所有文件都打印完毕，我整理好文件夹，长长地舒了一口气。",
      "sentence_index": 24,
      "char_start": 723,
      "char_end": 763,
      "children": ["word_322", "word_323", "word_324", "word_325", "word_326", "word_327", "word_328", "word_329", "word_330", "word_331", "word_332", "word_333", "word_334", "word_335", "word_336", "word_337", "word_338", "word_339"]
    },
    {
      "unit_id": "sent_025",
      "unit_type": "sentence",
      "text": "我赶紧去了趟洗手间，回来后，我在文件夹里找到最终的文件，再次确认无误后，将它存到了 U 盘里。",
      "sentence_index": 25,
