      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我迅速整理好桌上的文件、书本和计算器，处理完最后几封邮件，然后关掉了电脑。",
      "confidence": 0.95,
      "llm_used": true,
