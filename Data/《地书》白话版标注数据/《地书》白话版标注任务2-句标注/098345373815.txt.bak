      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "一整天的劳累让我疲惫不堪，只想赶快回家休息。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "简化表达，将‘工作让我感到’改为‘劳累让我’。"
