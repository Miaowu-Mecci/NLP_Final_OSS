      ]
    },
    {
      "unit_id": "p21__s_21_16",
      "unit_type": "sentence",
      "text": "最后，他回家了，我一个人站在雨中，心里有些难过，不知道他什么时候才能走出失恋的阴影。",
      "sentence_index": 16,
      "children": [
        "p21__w_208",
        "p21__w_209",
        "p21__w_210",
        "p21__w_211",
        "p21__w_212",
