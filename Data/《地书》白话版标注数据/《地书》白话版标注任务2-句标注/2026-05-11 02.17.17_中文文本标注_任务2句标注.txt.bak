        "p3__word_122",
        "p3__word_123",
        "p3__word_124",
        "p3__word_125",
        "p3__word_126",
        "p3__word_127",
        "p3__word_128",
        "p3__word_129",
        "p3__word_130",
        "p3__word_131"
      ]
    },
    {
      "unit_id": "p3__sent_009",
      "unit_type": "sentence",
      "text": "地铁到站，停稳。",
      "sentence_index": 9,
      "char_start": 185,
      "char_end": 193,
      "children": [
        "p3__word_132",
        "p3__word_133",
        "p3__word_134",
        "p3__word_135",
        "p3__word_136"
      ]
    },
    {
      "unit_id": "p3__sent_010",
      "unit_type": "sentence",
      "text": "我跟着人流下车，跑上扶梯，快步冲向写字楼。",
      "sentence_index": 10,
      "char_start": 193,
      "char_end": 215,
      "children": [
        "p3__word_137",
        "p3__word_138",
        "p3__word_139",
        "p3__word_140",
        "p3__word_141",
        "p3__word_142",
        "p3__word_143",
        "p3__word_144",
        "p3__word_145",
        "p3__word_146",
