  "annotations": [
    {
      "annotation_id": "p1__ann_0001",
      "target_id": "p1__sent_001",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我穿过马路上的斑马线，一边看着地图上的城市定位图标，从西边往东边走。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "合并了句子翻译任务"
    },
    {
      "annotation_id": "p1__ann_0002",
      "target_id": "p1__sent_002",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我在坐公交还是坐地铁之间纠结了一会儿。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p1__ann_0003",
      "target_id": "p1__sent_003",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我瞅了一眼手机上的信号图标，经过一个限速280的路牌，又看到前面有警示标志，路上堵得特别厉害，公交车根本过不去。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p1__ann_0004",
      "target_id": "p1__sent_004",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我决定改坐地铁，下了楼进到地铁站里，一看前面排的队老长。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p1__ann_0005",
      "target_id": "p1__sent_005",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我也跟着排进队伍里，一边刷卡进站，一边瞅着表，急得我脑门都冒汗了。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p1__ann_0006",
      "target_id": "p1__sent_006",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "眼看时间快到了，可队伍还是排得那么长，我握紧拳头想：前面可是有领导在，绝对不能迟到！",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p1__ann_0007",
      "target_id": "p1__sent_007",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "待会儿还要打文件、整资料、做报表，这些活儿都在那儿等着我呢。我瞅了眼排的长队，又看了一圈钟表，脸上的表情跟着变得又惊又急，汗珠子直往外冒。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p2__ann_0001",
      "target_id": "p2__sent_p2_01",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "排着的长队一点点往前挪，时间一分一秒过去，队伍还是一眼望不到头，急得我满头是汗，而且外面的雨越下越大了。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "口语化补充因果逻辑和焦急情绪。"
    },
    {
      "annotation_id": "p2__ann_0002",
      "target_id": "p2__sent_p2_02",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "总算熬到我了，我赶紧刷卡顺利进了站，心里终于松了一口气笑了出来，然后大步流星地朝扶梯冲过去拼命赶路。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p2__ann_0003",
      "target_id": "p2__sent_p2_03",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "等跑到地铁上车点，头上的红灯刚好闪烁，紧接着车门就打开了！",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p2__ann_0004",
      "target_id": "p2__sent_p2_04",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "趁着车门开着，我一个箭步硬挤进了车厢里，随后地铁关上门开动了。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p2__ann_0005",
      "target_id": "p2__sent_p2_05",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我站在车厢里看着窗外的雨，终于如释重负，百无聊赖地盯着车门上的警告标志看。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p2__ann_0006",
      "target_id": "p2__sent_p2_06",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "这时候旁边有人顺手递给我一些东西。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p2__ann_0007",
      "target_id": "p2__sent_p2_07",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我抬头看了看地铁的路线图，心里盘算着要从这儿坐到换乘站，最后再坐到终点站去。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p2__ann_0008",
      "target_id": "p2__sent_p2_08",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "车厢里人挤人，那些背着大包的乘客一个接一个地从我身旁蹭过去，我被像夹心饼干一样挤在中间，心里从一开始的生气变得好委屈，感觉整个人都要崩溃了。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p2__ann_0009",
      "target_id": "p2__sent_p2_09",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "盯着线路图，眼瞅着离换乘的那一站越来越近，我死死锁定一个座位，大步流星地冲过去准备抢座。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p2__ann_0010",
      "target_id": "p2__sent_p2_10",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "最后总算是有惊无险地冲到了空座前，一屁股坐了下去。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "p4__ann_0001",
      "target_id": "p4__s_1",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我飞快地冲进电梯，随手按下了上下楼的按键。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p4__ann_0002",
      "target_id": "p4__s_2",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我低头瞅了眼时间，着急地又按了一次键，电梯总算到了。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p4__ann_0003",
      "target_id": "p4__s_3",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我跟着排队的人流挤进电梯，按了89楼，电梯门一关，便开始往上走。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p4__ann_0004",
      "target_id": "p4__s_4",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "刚到2楼电梯就停了，我气得直瞪眼，本想干脆去爬楼梯，结果发现2楼的消防通道被堵得严严实实，只能坐电梯接着上3楼。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p4__ann_0005",
      "target_id": "p4__s_5",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "谁知到了4楼电梯又停了，我惊得合不拢嘴；接着5楼又停，我满脸无奈，急得汗都止不住往下流。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p4__ann_0006",
      "target_id": "p4__s_6",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "这破电梯就这么每层都停，我的心情也从生气升级成了狂怒，最后简直快要崩溃了。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p4__ann_0007",
      "target_id": "p4__s_7",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "好不容易熬到87楼，电梯又停住了，我气得脸色铁青，眼睁睁看着又有人走进来，电梯门在那儿反反复复地开开关关、上上下下！",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p4__ann_0008",
      "target_id": "p4__s_8",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我拼命狂按关门键，按完一次又按一次！",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p4__ann_0009",
      "target_id": "p4__s_9",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "这时头顶的广播响了：“本电梯最多限坐10人！严重超载，禁止运行！”",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p4__ann_0010",
      "target_id": "p4__s_10",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我死死盯着这破电梯，烦躁得抓狂。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p4__ann_0011",
      "target_id": "p4__s_11",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "看着车厢里挤得满满当当，这密集程度简直就像一堆木乃伊列成了方阵，我气得火冒三丈。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p4__ann_0012",
      "target_id": "p4__s_12",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "竟然还有人指着电梯门，瞎指挥不让里面的人出去，我这下彻底出离愤怒了！",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p5__ann_0001",
      "target_id": "p5__s_p5_1",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "上班时间终于到了！",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p5__ann_0002",
      "target_id": "p5__s_p5_2",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我急匆匆走进电梯，一开门就像无头苍蝇一样，快步直走、下楼、再直走、又爬上楼、原路返回、接着下楼、再继续直行，完全是在大楼里绕圈子。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p5__ann_0003",
      "target_id": "p5__s_p5_3",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "绕到了88楼后，我又接着往前走，上楼、折返、下楼，一路瞎转悠，好不容易终于到了89楼！",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p5__ann_0004",
      "target_id": "p5__s_p5_4",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我赶紧一路小跑进了公司的电梯。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p5__ann_0005",
      "target_id": "p5__s_p5_5",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "从电梯出来后，我又是一阵下楼、直走、再直走、拐弯，跑得太急突然弯下腰猛烈地咳嗽起来，等喘过气后又接着直走、拐弯、再直行。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p5__ann_0006",
      "target_id": "p5__s_p5_6",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我掏出工牌刷卡，拿出手机扫码开门，一路上走得飞快，途中还不停地跟同事挥手打招呼，最后跟一位女同事挥手说了声再见。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p5__ann_0007",
      "target_id": "p5__s_p5_7",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "进门后我拐了个弯，径直往前走，推开门，终于走到自己的办公桌前一屁股坐了下来。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p5__ann_0008",
      "target_id": "p5__s_p5_8",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "抬头看了一眼时间，我紧张得脑门直冒冷汗。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p5__ann_0009",
      "target_id": "p5__s_p5_9",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "发现自己居然准点没迟到，我开心地对着空气比了个“胜利”的手势！",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek"
    },
    {
      "annotation_id": "p21__ann_0233",
      "target_id": "p21__s_21_1",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "晚上九点，我接到了一个电话，是刚刚失恋的老朋友打来的，他希望我能过去陪他喝酒散散心。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘散散心’体现喝酒的目的，使语境更完整。"
    },
    {
      "annotation_id": "p21__ann_0234",
      "target_id": "p21__s_21_2",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我本来打算开车过去，没想到路上堵得一塌糊涂，到处都是车，还撞上了红灯和一起车祸。",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘没想到’‘一塌糊涂’强化出行受阻的意外感。"
    },
    {
      "annotation_id": "p21__ann_0235",
      "target_id": "p21__s_21_3",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我毫无办法，只能无奈地困在车里干等，心里急得不行。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘干等’‘急得不行’强化无助与焦急的情绪。"
    },
    {
      "annotation_id": "p21__ann_0236",
      "target_id": "p21__s_21_4",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "费了好大劲才终于到家，我进门就开始喝酒。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘费了好大劲’使动作的迫切感更强。"
    },
    {
      "annotation_id": "p21__ann_0237",
      "target_id": "p21__s_21_5",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "没过多久，老友也来了，他向我倾诉说自己失恋了，心里非常痛苦。",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘向我倾诉’使情感表达更到位。"
    },
    {
      "annotation_id": "p21__ann_0238",
      "target_id": "p21__s_21_6",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我笑着宽慰他，劝他别再纠结那些让人难过的事了。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘纠结’使劝说的针对性更强。"
    },
    {
      "annotation_id": "p21__ann_0239",
      "target_id": "p21__s_21_7",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我们就这样一边喝酒一边聊着，时间悄悄地流走了。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘就这样’‘悄悄地’使场景更有画面感。"
    },
    {
      "annotation_id": "p21__ann_0240",
      "target_id": "p21__s_21_8",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "再后来，老友说要坐公交车回家了，这时外面也开始下雨。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘这时也’强化两件事同时发生的巧合感。"
    },
    {
      "annotation_id": "p21__ann_0241",
      "target_id": "p21__s_21_9",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我在楼下等他，他却问我是不是跟那个女人分手了，还问我现在是不是也要坐公交车。",
      "confidence": 0.91,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘却’体现问题的出其不意。"
    },
    {
      "annotation_id": "p21__ann_0242",
      "target_id": "p21__s_21_10",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我告诉他是的，同时抬手指向了天上那片乌沉沉的云。",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘抬手’使肢体动作描写更具体。"
    },
    {
      "annotation_id": "p21__ann_0243",
      "target_id": "p21__s_21_11",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "他说外面下雨了，看不到太阳，然后问我要不要带把伞。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘外面’使陈述更口语自然。"
    },
    {
      "annotation_id": "p21__ann_0244",
      "target_id": "p21__s_21_12",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我答应了他。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "改‘同意’为‘答应’使口语感更强。"
    },
    {
      "annotation_id": "p21__ann_0245",
      "target_id": "p21__s_21_13",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我们站在雨里一起等公交车，他中途去了一趟卫生间。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘站在雨里’使场景关系更清晰。"
    },
    {
      "annotation_id": "p21__ann_0246",
      "target_id": "p21__s_21_14",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "等了很长时间，他才总算出来了，还顺带亲了我一下。",
      "confidence": 0.91,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘顺带’使后续动作的随意感更自然。"
    },
    {
      "annotation_id": "p21__ann_0247",
      "target_id": "p21__s_21_15",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我们继续喝酒，我心里感到说不出的开心。",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘说不出的’使情绪更有层次感。"
    },
    {
      "annotation_id": "p21__ann_0248",
      "target_id": "p21__s_21_16",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "到最后，他回家去了，我一个人孤零零地站在雨里，心里泛起一阵说不清的难过，不知道他究竟要到什么时候才能真正走出失恋的阴影。",
      "confidence": 0.91,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充‘孤零零’使结尾的孤独感更深沉。"
    },
    {
      "annotation_id": "p2am__ann_0001",
      "target_id": "p2am__sent_001",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "到了半夜两点钟，我一躺上床就迅速睡着了。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "口语化翻译重述"
    },
    {
      "annotation_id": "p2am__ann_0002",
      "target_id": "p2am__sent_002",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "做梦的时候，我看着有俩人正在面红耳赤地吵架。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "增强场景感的重述"
    },
    {
      "annotation_id": "p2am__ann_0003",
      "target_id": "p2am__sent_003",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "紧接着我又梦到了类似电影《2012》里的末日画面，滔天巨浪把整个地球都吞没了，大家全都在往高山上跑着逃命。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "把三段小句连贯串联"
    },
    {
      "annotation_id": "p3__ann_0151",
      "target_id": "p3__sent_001",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "地铁从出发站出发，经过换乘站，继续向终点方向行驶过去。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充\"出发站出发\"使行程逻辑更完整。"
    },
    {
      "annotation_id": "p3__ann_0152",
      "target_id": "p3__sent_002",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "车厢里有人在挥手，我突然闻到一股难闻的气味！",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充\"车厢里\"\"突然\"\"难闻的\"使场景和情绪更具体。"
    },
    {
      "annotation_id": "p3__ann_0153",
      "target_id": "p3__sent_003",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "旁边有人大声说话，声音又清晰又刺耳，难闻的气味也一阵阵涌来，我真恨不得立刻戴上口罩把鼻子捂住！",
      "confidence": 0.91,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充\"大声\"\"又清晰又刺耳\"\"一阵阵\"\"立刻\"强化感官刺激与情绪反应。"
    },
    {
      "annotation_id": "p3__ann_0154",
      "target_id": "p3__sent_004",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "车厢里贴着醒目的禁止饮食标识，乘客们也都遵守规定，没有人在吃东西。",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充\"醒目的\"\"乘客们\"\"遵守规定\"使观察视角更自然。"
    },
    {
      "annotation_id": "p3__ann_0155",
      "target_id": "p3__sent_005",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "即便如此我还是一脸不满，就在这时，有人穿着高跟鞋直接踩到了我的脚，我顿时露出一副震惊的表情！",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充\"即便如此\"\"就在这时\"\"直接踩到了我的脚\"\"顿时\"强化事件的突发感。"
    },
    {
      "annotation_id": "p3__ann_0156",
      "target_id": "p3__sent_006",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "地铁到站停下，信号灯变红，车门打开，我随着人群一起下了车。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充\"停下\"\"变红\"\"一起\"使动作更连贯自然。"
    },
    {
      "annotation_id": "p3__ann_0157",
      "target_id": "p3__sent_007",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "换乘后我又惦记起座位这件事，赶紧跑过去抢了一个，坐下来之后松了口气，不禁露出微笑。",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充\"换乘后\"\"赶紧\"\"松了口气\"体现抢座成功后的满足感。"
    },
    {
      "annotation_id": "p3__ann_0158",
      "target_id": "p3__sent_008",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "地铁到了下一站，距离终点已经不远了。我环顾四周，看着那些空着的和有人坐着的位置，注意到旁边站着一位孕妇。我犹豫地看了看自己的座位，最终还是站起身来，把座位让给了她。",
      "confidence": 0.91,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充\"环顾四周\"\"犹豫地\"\"最终还是\"体现让座时内心的短暂权衡，使人物形象更真实。"
    },
    {
      "annotation_id": "p3__ann_0159",
      "target_id": "p3__sent_009",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "地铁缓缓驶入站台，平稳地停了下来。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充\"缓缓驶入站台\"\"平稳地\"使短句扩展为更完整的场景描述。"
    },
    {
      "annotation_id": "p3__ann_0160",
      "target_id": "p3__sent_010",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我随着涌出的人流下了车，快步跑上自动扶梯，然后一路冲向目的地写字楼。",
      "confidence": 0.93,
      "llm_used": true,
      "llm_name": "Claude",
      "annotator_note": "补充\"涌出的\"\"一路\"使出站场景的动感更强。"
    }
  ]
}