    },
    {
      "unit_id": "p2am__sent_001",
      "unit_type": "sentence",
      "text": "凌晨两点，我躺在床上，很快就进入了梦乡。",
      "sentence_index": 1,
      "children": [
        "p2am__word_001",
        "p2am__word_002",
        "p2am__word_003",
        "p2am__word_004",
        "p2am__word_005",
        "p2am__word_006",
        "p2am__word_007",
        "p2am__word_008"
      ]
    },
    {
      "unit_id": "p2am__sent_002",
      "unit_type": "sentence",
      "text": "在梦里，我看到两个人在激烈地争吵。",
      "sentence_index": 2,
      "children": [
        "p2am__word_009",
        "p2am__word_010",
        "p2am__word_011",
        "p2am__word_012",
        "p2am__word_013",
        "p2am__word_014",
        "p2am__word_015",
        "p2am__word_016",
        "p2am__word_017"
      ]
    },
    {
      "unit_id": "p2am__sent_003",
      "unit_type": "sentence",
      "text": "接着，我梦见了 2012 年世界末日的场景，巨大的海浪淹没了地球，人们纷纷逃到山上避难。",
      "sentence_index": 3,
      "children": [
        "p2am__word_018",
        "p2am__word_019",
        "p2am__word_020",
        "p2am__word_021",
        "p2am__word_022",
        "p2am__word_023",
        "p2am__word_024",
        "p2am__word_025",
        "p2am__word_026",
        "p2am__word_027",
        "p2am__word_028",
        "p2am__word_029",
        "p2am__word_030",
        "p2am__word_031",
        "p2am__word_032",
        "p2am__word_033",
        "p2am__word_034"
      ]
    },
    {
      "unit_id": "p3__sent_001",
      "unit_type": "sentence",
      "text": "地铁从起点开往换乘站，再往终点驶去。",
      "sentence_index": 1,
      "char_start": 0,
      "char_end": 18,
      "children": [
        "p3__word_001",
        "p3__word_002",
        "p3__word_003",
        "p3__word_004",
        "p3__word_005",
        "p3__word_006",
        "p3__word_007",
        "p3__word_008",
        "p3__word_009",
        "p3__word_010",
        "p3__word_011",
        "p3__word_012",
        "p3__word_013",
        "p3__word_014"
      ]
    },
    {
      "unit_id": "p3__sent_002",
      "unit_type": "sentence",
      "text": "有人挥手，我闻到异味！",
      "sentence_index": 2,
      "char_start": 18,
      "char_end": 29,
      "children": [
        "p3__word_015",
        "p3__word_016",
        "p3__word_017",
        "p3__word_018",
        "p3__word_019",
        "p3__word_020",
        "p3__word_021",
        "p3__word_022",
        "p3__word_023"
      ]
    },
    {
      "unit_id": "p3__sent_003",
      "unit_type": "sentence",
      "text": "有人在旁说话，声音清晰，气味冲来，我恨不得戴上口罩！",
      "sentence_index": 3,
      "char_start": 29,
      "char_end": 54,
      "children": [
        "p3__word_024",
        "p3__word_025",
        "p3__word_026",
        "p3__word_027",
        "p3__word_028",
        "p3__word_029",
        "p3__word_030",
        "p3__word_031",
        "p3__word_032",
        "p3__word_033",
        "p3__word_034",
        "p3__word_035",
        "p3__word_036",
        "p3__word_037",
        "p3__word_038",
        "p3__word_039",
        "p3__word_040",
        "p3__word_041",
        "p3__word_042",
        "p3__word_043"
      ]
    },
    {
      "unit_id": "p3__sent_004",
      "unit_type": "sentence",
      "text": "地铁禁止饮食标识清晰，车厢内无人进食。",
      "sentence_index": 4,
      "char_start": 54,
      "char_end": 74,
      "children": [
        "p3__word_044",
        "p3__word_045",
        "p3__word_046",
        "p3__word_047",
        "p3__word_048",
        "p3__word_049",
        "p3__word_050",
        "p3__word_051",
        "p3__word_052",
        "p3__word_053",
        "p3__word_054",
        "p3__word_055",
        "p3__word_056",
        "p3__word_057"
      ]
    },
    {
      "unit_id": "p3__sent_005",
      "unit_type": "sentence",
      "text": "我仍面露怒色，有人穿高跟鞋踩了我，我露出震惊的表情！",
      "sentence_index": 5,
      "char_start": 74,
      "char_end": 100,
      "children": [
        "p3__word_058",
        "p3__word_059",
        "p3__word_060",
        "p3__word_061",
        "p3__word_062",
        "p3__word_063",
        "p3__word_064",
        "p3__word_065",
        "p3__word_066",
        "p3__word_067",
        "p3__word_068",
        "p3__word_069",
        "p3__word_070",
        "p3__word_071",
        "p3__word_072",
        "p3__word_073",
        "p3__word_074",
        "p3__word_075",
        "p3__word_076",
        "p3__word_077",
        "p3__word_078",
        "p3__word_079"
      ]
    },
    {
      "unit_id": "p3__sent_006",
      "unit_type": "sentence",
      "text": "地铁到站，红灯亮起，车门开启，我跟着队伍下车。",
      "sentence_index": 6,
      "char_start": 100,
      "char_end": 123,
      "children": [
        "p3__word_080",
        "p3__word_081",
        "p3__word_082",
        "p3__word_083",
        "p3__word_084",
        "p3__word_085",
        "p3__word_086",
        "p3__word_087",
        "p3__word_088",
        "p3__word_089",
        "p3__word_090",
        "p3__word_091",
        "p3__word_092",
        "p3__word_093",
        "p3__word_094",
        "p3__word_095",
        "p3__word_096",
        "p3__word_097"
      ]
    },
    {
      "unit_id": "p3__sent_007",
      "unit_type": "sentence",
      "text": "我又想起座位，跑过去抢，坐下后露出微笑。",
      "sentence_index": 7,
      "char_start": 123,
      "char_end": 144,
      "children": [
        "p3__word_098",
        "p3__word_099",
        "p3__word_100",
        "p3__word_101",
        "p3__word_102",
        "p3__word_103",
        "p3__word_104",
        "p3__word_105",
        "p3__word_106",
        "p3__word_107",
        "p3__word_108",
        "p3__word_109",
        "p3__word_110",
        "p3__word_111",
        "p3__word_112",
        "p3__word_113",
        "p3__word_114",
        "p3__word_115"
      ]
    },
    {
      "unit_id": "p3__sent_008",
      "unit_type": "sentence",
      "text": "地铁到了下一站，快到终点，我看着空座与有人的座位，一位孕妇站在旁边，我看了看座位，起身让座。",
      "sentence_index": 8,
      "char_start": 144,
      "char_end": 185,
      "children": [
        "p3__word_100",
        "p3__word_101",
        "p3__word_102",
