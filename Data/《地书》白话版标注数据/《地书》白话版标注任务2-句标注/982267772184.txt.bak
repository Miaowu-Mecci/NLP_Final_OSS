  "units": [
    {
      "unit_id": "sent_001",
      "unit_type": "sentence",
      "text": "我接起電話，驚訝地發現是醫院打來的，得知有人發燒住院了。",
      "sentence_index": 1,
      "char_start": 62,
      "char_end": 90
    },
    {
      "unit_id": "sent_002",
      "unit_type": "sentence",
      "text": "凌晨一點，我在回家的路上看到了一隻狗，我向它揮手，它也搖著尾巴回應我。",
      "sentence_index": 2,
      "char_start": 234,
      "char_end": 272
    }
  ],
