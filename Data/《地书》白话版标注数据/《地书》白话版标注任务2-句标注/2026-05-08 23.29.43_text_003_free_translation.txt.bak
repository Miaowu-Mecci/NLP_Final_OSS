      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我和许多人一起赏花，随后梦境还在继续。",
      "confidence": 0.94,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "在保留原句基本信息的基础上，用更自然清楚的中文进行重述。"
