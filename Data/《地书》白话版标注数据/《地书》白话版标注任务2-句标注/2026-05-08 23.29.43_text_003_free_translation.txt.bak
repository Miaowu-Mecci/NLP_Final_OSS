      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我在房子里不停绕圈，觉得场景像是在反复循环。",
      "confidence": 0.94,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "在保留原句基本信息的基础上，用更自然清楚的中文进行重述。"
