      "char_end": 215,
      "children": ["word_081", "word_082", "word_083", "word_084", "word_085", "word_086", "word_087", "word_088"]
    },
    {
      "unit_id": "sent_009",
      "unit_type": "sentence",
      "text": "同事端着绿茶说：\"看世界杯，巴西对葡萄牙！\"我忍不住笑了。",
      "sentence_index": 9,
      "char_start": 216,
      "char_end": 253,
      "children": ["word_089", "word_090", "word_091", "word_092", "word_093", "word_094", "word_095", "word_096", "word_097", "word_098", "word_099", "word_100", "word_101", "word_102", "word_103"]
    },
    {
      "unit_id": "sent_010",
      "unit_type": "sentence",
      "text": "我捧着咖啡说：\"看这球赛的精彩瞬间！\"",
      "sentence_index": 10,
      "char_start": 254,
      "char_end": 278,
      "children": ["word_104", "word_105", "word_106", "word_107", "word_108", "word_109", "word_110", "word_111", "word_112"]
    },
    {
      "unit_id": "sent_011",
      "unit_type": "sentence",
      "text": "同事又说：\"最近在找房子。\"",
      "sentence_index": 11,
