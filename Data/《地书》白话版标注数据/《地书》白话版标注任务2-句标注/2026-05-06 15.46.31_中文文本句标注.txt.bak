      "children": ["word_180", "word_181", "word_182", "word_183", "word_184", "word_185", "word_186", "word_187", "word_188", "word_189"]
    },
    {
      "unit_id": "sent_020",
      "unit_type": "sentence",
      "text": "时钟滴答走着，我上了楼，左转右转，朝着洗手间走去。",
