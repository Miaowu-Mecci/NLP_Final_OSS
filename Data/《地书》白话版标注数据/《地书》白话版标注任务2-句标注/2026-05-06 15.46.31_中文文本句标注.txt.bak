      "children": ["word_050", "word_051", "word_052", "word_053", "word_054", "word_055", "word_056", "word_057", "word_058", "word_059"]
    },
    {
      "unit_id": "sent_006",
      "unit_type": "sentence",
      "text": "我笑着说：\"来杯咖啡和牛角包。\"",
