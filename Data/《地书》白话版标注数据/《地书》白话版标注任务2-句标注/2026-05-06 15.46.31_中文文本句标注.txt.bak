      "children": ["word_069", "word_070", "word_071", "word_072", "word_073", "word_074", "word_075", "word_076", "word_077", "word_078", "word_079", "word_080"]
    },
    {
      "unit_id": "sent_008",
      "unit_type": "sentence",
      "text": "我们坐着，有一搭没一搭地聊着天。",
      "sentence_index": 8,
