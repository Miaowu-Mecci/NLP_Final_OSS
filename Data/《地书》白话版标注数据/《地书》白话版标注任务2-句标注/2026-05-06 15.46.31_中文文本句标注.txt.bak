      "char_end": 673,
      "children": ["word_245", "word_246", "word_247", "word_248", "word_249", "word_250", "word_251", "word_252", "word_253", "word_254", "word_255", "word_256", "word_257", "word_258"]
    },
    {
      "unit_id": "sent_025",
      "unit_type": "sentence",
      "text": "时钟继续走着，我往工位走，想起了垃圾分类的事。",
