      "char_end": 296,
      "children": ["word_113", "word_114", "word_115", "word_116", "word_117", "word_118", "word_119"]
    },
    {
      "unit_id": "sent_012",
      "unit_type": "sentence",
      "text": "我接话：\"刚看新闻，说房价跌了。\"",
      "sentence_index": 12,
