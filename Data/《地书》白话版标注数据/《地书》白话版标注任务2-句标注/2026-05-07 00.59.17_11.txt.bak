        "target_id": "sent_007",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "他醉得吐了一地，我帮他清理干净，还找到了他的钱包、手机和钥匙。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "“收拾干净”改为“清理干净”，更符合口语习惯"
      },
      {
        "annotation_id": "ann_sent_008",
        "target_id": "sent_008",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "他的狗见我们回来了，特别兴奋。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "“看到”改为“见”，“非常兴奋”简化为“特别兴奋”"
      },
      {
        "annotation_id": "ann_sent_009",
        "target_id": "sent_009",
        "target_type": "sentence",
        "task_id": "free_translation",
        "task_label_zh": "自由翻译",
        "task_label_en": "Free Translation",
        "value": "我把他搀扶到床上，他还在不停说胡话。",
        "confidence": 0.95,
        "llm_used": true,
        "llm_name": "DeepSeek",
        "annotator_note": "“扶到”改为“搀扶到”，增加动作的细致感"
