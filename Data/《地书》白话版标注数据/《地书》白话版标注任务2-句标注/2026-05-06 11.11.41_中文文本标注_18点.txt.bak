    {"annotation_id": "a_w025", "target_id": "word_025", "target_type": "word", "task_id": "morphological_like_features", "value": ["multi_character_word", "classifier_structure"], "confidence": 0.95, "llm_used": true, "llm_name": "Gemini"},

    {"annotation_id": "a_s001", "target_id": "sent_001", "target_type": "sentence", "task_id": "free_translation", "value": "傍晚六点，我下班回家，因为觉得热，进门第一件事就是赶紧把空调开起来降温。", "confidence": 0.92, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s002", "target_id": "sent_002", "target_type": "sentence", "task_id": "free_translation", "value": "我从冰箱里拿出一瓶冰镇饮料，舒舒服服地喝了几口。", "confidence": 0.95, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s003", "target_id": "sent_003", "target_type": "sentence", "task_id": "free_translation", "value": "接着我去浴室洗了个澡，洗完后开始精心准备晚上约会穿的衣服，在试穿了多套后终于找到了满意的装扮。", "confidence": 0.92, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s004", "target_id": "sent_004", "target_type": "sentence", "task_id": "free_translation", "value": "我一边听着音乐一边吹干头发，心情特别好。", "confidence": 0.95, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s005", "target_id": "sent_005", "target_type": "sentence", "task_id": "free_translation", "value": "在这个时候，她也正在她自己的家里忙着准备。", "confidence": 0.92, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s006", "target_id": "sent_006", "target_type": "sentence", "task_id": "free_translation", "value": "她戴上了帽子和眼镜，挑了半天口红的颜色，涂抹完毕后，又仔细化了全妆，并弄干了头发。", "confidence": 0.90, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s007", "target_id": "sent_007", "target_type": "sentence", "task_id": "free_translation", "value": "她同样也在放着音乐，做着出门的最后准备。", "confidence": 0.95, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s008", "target_id": "sent_008", "target_type": "sentence", "task_id": "free_translation", "value": "我搭配好了鞋子和饰品，准备出发。", "confidence": 0.95, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s009", "target_id": "sent_009", "target_type": "sentence", "task_id": "free_translation", "value": "临走前，我给她发信息再次确认了我们约好的时间。", "confidence": 0.95, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s010", "target_id": "sent_010", "target_type": "sentence", "task_id": "free_translation", "value": "然后我关了家里的空调和手机，径直走出门去。", "confidence": 0.92, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s011", "target_id": "sent_011", "target_type": "sentence", "task_id": "free_translation", "value": "我刚离开家没多远，她就打来了电话，我带着一丝紧张的心情接听了。", "confidence": 0.90, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s012", "target_id": "sent_012", "target_type": "sentence", "task_id": "free_translation", "value": "通完话后，我立刻前往花店，买了一束由12朵鲜花组成的花束。", "confidence": 0.95, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s013", "target_id": "sent_013", "target_type": "sentence", "task_id": "free_translation", "value": "我手中捧着鲜花，脑海里全是对她的思念，甚至幻想她看到这束花时的喜悦模样。", "confidence": 0.92, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s014", "target_id": "sent_014", "target_type": "sentence", "task_id": "free_translation", "value": "最终我们碰面了，我把买好的花送给了她。", "confidence": 0.95, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s015", "target_id": "sent_015", "target_type": "sentence", "task_id": "free_translation", "value": "她带着欣喜的心情接过鲜花，我们默契地看着对方笑了。", "confidence": 0.95, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s016", "target_id": "sent_016", "target_type": "sentence", "task_id": "free_translation", "value": "随后我们结伴前往了之前定好的那个酒吧。", "confidence": 0.95, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s017", "target_id": "sent_017", "target_type": "sentence", "task_id": "free_translation", "value": "在酒吧坐下后，她询问我是否打算回家，而我心里其实更盼望能在这里和她多享受一会儿独处时光。", "confidence": 0.90, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s018", "target_id": "sent_018", "target_type": "sentence", "task_id": "free_translation", "value": "我们要了一些啤酒，边喝边聊天。", "confidence": 0.95, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s019", "target_id": "sent_019", "target_type": "sentence", "task_id": "free_translation", "value": "忽然间，我余光瞥见了一些反常的现象，这让我有些吃惊。", "confidence": 0.92, "llm_used": true, "llm_name": "Gemini"},
    {"annotation_id": "a_s020", "target_id": "sent_020", "target_type": "sentence", "task_id": "free_translation", "value": "不过，能和她在一起总是令人开心的，虽然中间我离开去了一次厕所，但这丝毫没有打扰到我们愉快的氛围。", "confidence": 0.90, "llm_used": true, "llm_name": "Gemini"}
  ]
}