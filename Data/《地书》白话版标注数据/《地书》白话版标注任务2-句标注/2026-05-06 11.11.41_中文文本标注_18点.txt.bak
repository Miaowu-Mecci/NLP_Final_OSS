  "source_text": {
    "text_id": "text_018",
    "title": "分配的章节01：18点",
    "source": "作业提供",
    "raw_text": "下午六点，我回到家，第一件事就是打开空调，让自己凉快下来。我从冰箱里拿出饮料，惬意地喝了一口。然后，我走进浴室冲了个澡，出来后开始精心挑选晚上约会要穿的衣服，试了好几套，终于找到了满意的搭配。我吹了吹头发，听着音乐，心情格外舒畅。与此同时，她也在家忙碌着。她戴上眼镜和帽子，仔细地挑选口红颜色，涂好口红后，又认真地化了妆，吹了头发。她也在听着音乐，准备出门。我选好了鞋子和配饰，准备出门。出门前，我给她发了条消息，确认了时间。然后关掉空调和手机，离开了家。刚出门不久，她的电话就打了过来，我有点紧张地接了电话。挂了电话后，我直奔花店，买了 12 朵漂亮的花。我拿着花，心里想着她，想象着她收到花时开心的样子。终于，我见到了她，把花递给了她。她开心地接过花，我们相视而笑。我们一起去了约定的酒吧。在酒吧里，她问我要不要回家，但我更想和她在这里多待一会儿。我们点了啤酒，聊着天。突然，我看到一些奇怪的东西，感到有些惊讶。不过，和她在一起的时光总是很愉快，虽然中途我去了趟洗手间，但这并不影响我们的好心情。",
    "notes": "全文本完整标注版本。"
  },
  "units": [
    {"unit_id": "sent_001", "unit_type": "sentence", "text": "下午六点，我回到家，第一件事就是打开空调，让自己凉快下来。", "sentence_index": 1},
    {"unit_id": "word_001", "unit_type": "word", "text": "下午六点", "sentence_id": "sent_001"},
    {"unit_id": "word_002", "unit_type": "word", "text": "凉快下来", "sentence_id": "sent_001"},
    
    {"unit_id": "sent_002", "unit_type": "sentence", "text": "我从冰箱里拿出饮料，惬意地喝了一口。", "sentence_index": 2},
    {"unit_id": "word_003", "unit_type": "word", "text": "拿出", "sentence_id": "sent_002"},
    {"unit_id": "word_004", "unit_type": "word", "text": "喝了一口", "sentence_id": "sent_002"},

    {"unit_id": "sent_003", "unit_type": "sentence", "text": "然后，我走进浴室冲了个澡，出来后开始精心挑选晚上约会要穿的衣服，试了好几套，终于找到了满意的搭配。", "sentence_index": 3},
    {"unit_id": "word_005", "unit_type": "word", "text": "冲了个澡", "sentence_id": "sent_003"},
    {"unit_id": "word_006", "unit_type": "word", "text": "搭配", "sentence_id": "sent_003"},

    {"unit_id": "sent_004", "unit_type": "sentence", "text": "我吹了吹头发，听着音乐，心情格外舒畅。", "sentence_index": 4},
    {"unit_id": "word_007", "unit_type": "word", "text": "吹了吹", "sentence_id": "sent_004"},
    {"unit_id": "word_008", "unit_type": "word", "text": "舒畅", "sentence_id": "sent_004"},

    {"unit_id": "sent_005", "unit_type": "sentence", "text": "与此同时，她也在家忙碌着。", "sentence_index": 5},
    {"unit_id": "word_009", "unit_type": "word", "text": "忙碌着", "sentence_id": "sent_005"},

    {"unit_id": "sent_006", "unit_type": "sentence", "text": "她戴上眼镜和帽子，仔细地挑选口红颜色，涂好口红后，又认真地化了妆，吹了头发。", "sentence_index": 6},
    {"unit_id": "word_010", "unit_type": "word", "text": "戴上", "sentence_id": "sent_006"},
    {"unit_id": "word_011", "unit_type": "word", "text": "涂好", "sentence_id": "sent_006"},

    {"unit_id": "sent_007", "unit_type": "sentence", "text": "她也在听着音乐，准备出门。", "sentence_index": 7},
    {"unit_id": "word_012", "unit_type": "word", "text": "准备", "sentence_id": "sent_007"},

    {"unit_id": "sent_008", "unit_type": "sentence", "text": "我选好了鞋子和配饰，准备出门。", "sentence_index": 8},
    {"unit_id": "word_013", "unit_type": "word", "text": "选好了", "sentence_id": "sent_008"},

    {"unit_id": "sent_009", "unit_type": "sentence", "text": "出门前，我给她发了条消息，确认了时间。", "sentence_index": 9},
    {"unit_id": "word_014", "unit_type": "word", "text": "发了条", "sentence_id": "sent_009"},

    {"unit_id": "sent_010", "unit_type": "sentence", "text": "然后关掉空调和手机，离开了家。", "sentence_index": 10},
    {"unit_id": "word_015", "unit_type": "word", "text": "关掉", "sentence_id": "sent_010"},

    {"unit_id": "sent_011", "unit_type": "sentence", "text": "刚出门不久，她的电话就打了过来，我有点紧张地接了电话。", "sentence_index": 11},
    {"unit_id": "word_016", "unit_type": "word", "text": "打了过来", "sentence_id": "sent_011"},

    {"unit_id": "sent_012", "unit_type": "sentence", "text": "挂了电话后，我直奔花店，买了 12 朵漂亮的花。", "sentence_index": 12},
    {"unit_id": "word_017", "unit_type": "word", "text": "12朵", "sentence_id": "sent_012"},

    {"unit_id": "sent_013", "unit_type": "sentence", "text": "我拿着花，心里想着她，想象着她收到花时开心的样子。", "sentence_index": 13},
    {"unit_id": "word_018", "unit_type": "word", "text": "想着", "sentence_id": "sent_013"},

    {"unit_id": "sent_014", "unit_type": "sentence", "text": "终于，我见到了她，把花递给了她。", "sentence_index": 14},
    {"unit_id": "word_019", "unit_type": "word", "text": "递给了", "sentence_id": "sent_014"},

    {"unit_id": "sent_015", "unit_type": "sentence", "text": "她开心地接过花，我们相视而笑。", "sentence_index": 15},
    {"unit_id": "word_020", "unit_type": "word", "text": "相视而笑", "sentence_id": "sent_015"},

    {"unit_id": "sent_016", "unit_type": "sentence", "text": "我们一起去了约定的酒吧。", "sentence_index": 16},
    {"unit_id": "word_021", "unit_type": "word", "text": "约定的", "sentence_id": "sent_016"},

    {"unit_id": "sent_017", "unit_type": "sentence", "text": "在酒吧里，她问我要不要回家，但我更想和她在这里多待一会儿。", "sentence_index": 17},
    {"unit_id": "word_022", "unit_type": "word", "text": "多待一会儿", "sentence_id": "sent_017"},

    {"unit_id": "sent_018", "unit_type": "sentence", "text": "我们点了啤酒，聊着天。", "sentence_index": 18},
    {"unit_id": "word_023", "unit_type": "word", "text": "聊着天", "sentence_id": "sent_018"},

    {"unit_id": "sent_019", "unit_type": "sentence", "text": "突然，我看到一些奇怪的东西，感到有些惊讶。", "sentence_index": 19},
    {"unit_id": "word_024", "unit_type": "word", "text": "奇怪的", "sentence_id": "sent_019"},

    {"unit_id": "sent_020", "unit_type": "sentence", "text": "不过，和她在一起的时光总是很愉快，虽然中途我去了趟洗手间，但这并不影响我们的好心情。", "sentence_index": 20},
    {"unit_id": "word_025", "unit_type": "word", "text": "去了趟", "sentence_id": "sent_020"}
  ],
