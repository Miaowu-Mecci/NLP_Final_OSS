  "source_text": {
    "text_id": "text_004",
    "title": "与蚊子的战斗",
    "source": "用户提供",
    "raw_text": "凌晨三点，我被蚊子的嗡嗡声吵醒了。我听到外面有人在吵架，感到非常烦躁。我开始用手拍蚊子，并用杀虫剂喷它们，但蚊子总是飞来飞去，很难打到。\n我关掉电视和灯，准备睡觉，但蚊子还是不停地骚扰我。我打开台灯，继续用杀虫剂和苍蝇拍消灭蚊子。我追着蚊子跑，上下挥舞着杀虫剂，累得满头大汗。\n最后，我终于打死了一只蚊子，手上沾满了血。我关掉台灯，终于可以安心睡觉了。",
    "notes": "描述半夜被蚊子骚扰及消灭过程"
  },
  "units": [
    {
      "unit_id": "sent_001",
      "unit_type": "sentence",
      "text": "凌晨三点，我被蚊子的嗡嗡声吵醒了。",
      "sentence_index": 1,
      "children": ["word_001", "word_002", "word_003", "word_004", "word_005", "word_006", "word_007", "word_008", "word_009"]
    },
    {
      "unit_id": "sent_002",
      "unit_type": "sentence",
      "text": "我听到外面有人在吵架，感到非常烦躁。",
      "sentence_index": 2,
      "children": ["word_010", "word_011", "word_012", "word_013", "word_014", "word_015", "word_016", "word_017", "word_018", "word_019"]
    },
    {
      "unit_id": "sent_003",
      "unit_type": "sentence",
      "text": "我开始用手拍蚊子，并用杀虫剂喷它们，但蚊子总是飞来飞去，很难打到。",
      "sentence_index": 3,
      "children": ["word_020", "word_021", "word_022", "word_023", "word_024", "word_025", "word_026", "word_027", "word_028", "word_029", "word_030", "word_031", "word_032", "word_033", "word_034", "word_035", "word_036", "word_037"]
    },
    {
      "unit_id": "sent_004",
      "unit_type": "sentence",
      "text": "我关掉电视和灯，准备睡觉，但蚊子还是不停地骚扰我。",
      "sentence_index": 4,
      "children": ["word_038", "word_039", "word_040", "word_041", "word_042", "word_043", "word_044", "word_045", "word_046", "word_047", "word_048", "word_049", "word_050", "word_051"]
    },
    {
      "unit_id": "sent_005",
      "unit_type": "sentence",
      "text": "我打开台灯，继续用杀虫剂和苍蝇拍消灭蚊子。",
      "sentence_index": 5,
      "children": ["word_052", "word_053", "word_054", "word_055", "word_056", "word_057", "word_058", "word_059", "word_060", "word_061", "word_062"]
    },
    {
      "unit_id": "sent_006",
      "unit_type": "sentence",
      "text": "我追着蚊子跑，上下挥舞着杀虫剂，累得满头大汗。",
      "sentence_index": 6,
      "children": ["word_063", "word_064", "word_065", "word_066", "word_067", "word_068", "word_069", "word_070", "word_071", "word_072", "word_073"]
    },
    {
      "unit_id": "sent_007",
      "unit_type": "sentence",
      "text": "最后，我终于打死了一只蚊子，手上沾满了血。",
      "sentence_index": 7,
      "children": ["word_074", "word_075", "word_076", "word_077", "word_078", "word_079", "word_080", "word_081", "word_082", "word_083", "word_084", "word_085"]
    },
    {
      "unit_id": "sent_008",
      "unit_type": "sentence",
      "text": "我关掉台灯，终于可以安心睡觉了。",
      "sentence_index": 8,
