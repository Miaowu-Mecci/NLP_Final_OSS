  ],
  "annotations": [
    {
      "annotation_id": "ann_001",
      "target_id": "sent_001",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "凌晨三点钟，我被蚊子的嗡嗡声给闹醒了。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "将‘吵醒’改为‘闹醒’，更口语化。"
    },
    {
      "annotation_id": "ann_002",
      "target_id": "sent_002",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我听见屋外有人争吵，心里烦得要命。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "‘感到非常烦躁’简化为‘烦得要命’。"
    },
    {
      "annotation_id": "ann_003",
      "target_id": "sent_003",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我于是用手拍蚊子，又拿起杀虫剂喷它们，可蚊子总是飞来飞去，怎么都打不着。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "将‘很难打到’改为‘怎么都打不着’。"
    },
    {
      "annotation_id": "ann_004",
      "target_id": "sent_004",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我关掉电视和灯准备睡觉，但蚊子还是不停来叮我。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "‘骚扰我’换成‘叮我’，更贴切。"
    },
    {
      "annotation_id": "ann_005",
      "target_id": "sent_005",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我打开台灯，继续用杀虫剂和苍蝇拍来灭蚊子。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "‘消灭’换成‘灭’，更简洁。"
    },
    {
      "annotation_id": "ann_006",
      "target_id": "sent_006",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我追着蚊子到处跑，上下挥舞杀虫剂，累得满头是汗。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "‘满头大汗’改为‘满头是汗’。"
    },
    {
      "annotation_id": "ann_007",
      "target_id": "sent_007",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "最后我终于拍死了一只蚊子，手上沾满了血。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "‘打死’改为‘拍死’，与手拍动作一致。"
    },
    {
      "annotation_id": "ann_008",
      "target_id": "sent_008",
      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我关掉台灯，终于能安心睡觉了。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": "‘可以’换成‘能’，更简洁。"
    }
  ]
