      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "之后，我们一起去了事先约好的酒吧。",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "在保留原句核心信息和事件顺序的基础上，用更自然、完整、通顺的中文重述句意。"
    },
    {
