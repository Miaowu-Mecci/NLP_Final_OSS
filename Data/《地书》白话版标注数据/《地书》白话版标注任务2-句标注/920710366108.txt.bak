      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我手里拿着花，心里想着她，并想象她收到花时会露出开心的表情。",
      "confidence": 0.92,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "在保留原句核心信息和事件顺序的基础上，用更自然、完整、通顺的中文重述句意。"
    },
    {
