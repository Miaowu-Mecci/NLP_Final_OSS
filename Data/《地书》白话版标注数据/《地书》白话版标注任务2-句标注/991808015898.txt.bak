      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我关掉电视和灯，准备睡觉，但蚊子还是不停地骚扰我。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "根据提供的白话文材料与图形语句边界整理为自然中文。"
