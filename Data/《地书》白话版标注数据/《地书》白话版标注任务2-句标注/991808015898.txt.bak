      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我们在雨中等待公交车，他去了趟卫生间。",
      "confidence": 0.9,
      "llm_used": true,
      "llm_name": "ChatGPT",
      "annotator_note": "根据提供的白话文材料与图形语句边界整理为自然中文。"
