{
  "project": "《地书》图形语言 vs 自然语言：计算语言学与自然语言处理多层标注配置",
  "config_snapshot": {
    "project": "《地书》图形语言 vs 自然语言：计算语言学与自然语言处理多层标注配置",
    "version": "dishu_cl_nlp_full_v2",
    "tasks": [
      {
        "task_id": "literal_gloss",
        "task_name": "[Text] 字面对应词 / Literal Gloss",
        "mode": "text",
        "applies_to": "both",
        "placeholder": "输入该图形或图形组最直接、最字面的自然语言对应词或短语",
        "help_text": "记录你一眼看上去最直接想到的词或短语，不必追求上下文最准确，只写“字面上像什么”。例如一个奔跑小人可写“跑步”“逃跑”。这相当于把图形先译成最表层的词。"
      },
      {
        "task_id": "free_translation",
        "task_name": "[Text] 自由翻译 / Free Translation",
        "mode": "text",
        "applies_to": "group",
        "placeholder": "输入该图形组在自然语言中的通顺表达",
        "help_text": "把整个图形组用自然、通顺的话表达出来，不必逐个对应。重点是“整组想说什么”。例如多个图形组合后，可直接写成“他因为害怕而逃走了”。"
      },
      {
        "task_id": "pragmatic_meaning",
        "task_name": "[Text] 语境实际含义 / Pragmatic Meaning",
        "mode": "text",
        "applies_to": "both",
        "placeholder": "输入该图形在当前上下文中的实际表达意图",
        "help_text": "有些图形字面意思和实际想表达的不一样，这里记录“在当前上下文中真正想说什么”。例如笑脸在某处可能不是“开心”，而是“礼貌”或“缓和气氛”。"
      },
      {
        "task_id": "event_description",
        "task_name": "[Text] 事件描述 / Event Description",
        "mode": "text",
        "applies_to": "group",
        "placeholder": "输入该图形组描述的事件或场景",
        "help_text": "把这个图形组当作一个事件或场景来概括：谁在做什么、发生了什么、结果怎样。适合较完整的组合，不要求逐字翻译，而是写成简洁事件描述。"
      },
      {
        "task_id": "context_note",
        "task_name": "[Text] 研究备注 / Annotation Note",
        "mode": "text",
        "applies_to": "both",
        "placeholder": "记录任何难点、歧义、判断依据或特殊现象",
        "help_text": "这里不是正式标注结果，而是补充说明。可记录你为什么这样判断、哪里不确定、是否依赖上下文、是否像某种固定符号等，方便后续复核。"
      },
      {
        "task_id": "semantic_role_core",
        "task_name": "[Single] 核心语义角色 / Core Semantic Role",
        "mode": "single",
        "applies_to": "both",
        "options": [
          "施事 / Agent",
          "受事 / Patient",
          "体验者 / Experiencer",
          "工具 / Instrument",
          "处所 / Location",
          "时间 / Time",
          "方式 / Manner",
          "结果 / Result",
          "核心谓词 / Predicate",
          "无明显语义角色 / None"
        ],
        "help_text": "判断该对象在一个事件里主要扮演什么角色。比如“人”可能是施事，“被打的人”是受事，“跑”本身可看作核心谓词。若它不像事件成分，就选“无明显语义角色”。"
      },
      {
        "task_id": "dependency_head_relation",
        "task_name": "[Single] 对中心成分关系 / Dependency to Head",
        "mode": "single",
        "applies_to": "both",
        "options": [
          "主语关系 / Subject-like",
          "宾语关系 / Object-like",
          "定语关系 / Modifier",
          "状语关系 / Adverbial",
          "补语关系 / Complement",
          "并列关系 / Coordination",
          "独立成分 / Independent",
          "中心成分 / Head",
          "附加说明 / Apposition-like",
          "无法判断 / Undetermined"
        ],
        "help_text": "把它看作一个结构中的成分，判断它和“中心部分”是什么关系。比如修饰人的图形可算定语，表示方式或地点的可算状语。若它本身就是核心，就选“中心成分”。"
      },
      {
        "task_id": "discourse_relation",
        "task_name": "[Single] 与前一组的篇章关系 / Discourse Relation",
        "mode": "single",
        "applies_to": "group",
        "options": [
          "时间先后 / Temporal",
          "因果 / Causal",
          "条件 / Conditional",
          "转折对比 / Contrast",
          "并列递进 / Expansion",
          "解释说明 / Elaboration",
          "举例 / Example",
          "总结 / Summary",
          "无明显关系 / None",
          "无法判断 / Undetermined"
        ],
        "help_text": "判断当前组与前一组之间是什么逻辑关系。比如前一组写“下雨”，后一组写“打伞”，可能是时间先后，也可能带因果。若只是继续补充内容，可选“解释说明”或“并列递进”。"
      },
      {
        "task_id": "speech_act_primary",
        "task_name": "[Single] 主要言语行为 / Primary Speech Act",
        "mode": "single",
        "applies_to": "group",
        "options": [
          "陈述 / Assertive",
          "请求或命令 / Directive",
          "承诺 / Commissive",
          "表达情感 / Expressive",
          "宣告 / Declarative",
          "提问 / Interrogative",
          "感叹 / Exclamative",
          "呼唤 / Vocative-like",
          "无明显交际功能 / None",
          "无法判断 / Undetermined"
        ],
        "help_text": "判断这组图形主要是在“做什么话语动作”。是在陈述事实、提问、命令、表达情绪，还是呼唤别人？例如“快走！”更像命令，“真可怕！”更像表达情感。"
      },
      {
        "task_id": "reference_type",
        "task_name": "[Single] 指称类型 / Reference Type",
        "mode": "single",
        "applies_to": "both",
        "options": [
          "具体实体 / Concrete Entity",
          "动作事件 / Event",
          "情感状态 / Emotion",
          "关系 / Relation",
          "抽象概念 / Abstract Concept",
          "场景 / Scene",
          "人物角色 / Person Role",
          "空间路径 / Spatial Path",
          "纯形式符号 / Formal Symbol",
          "无法判断 / Undetermined"
        ],
        "help_text": "判断它主要指向哪一类意义对象。是某个东西、某个动作、某种情绪、一个场景，还是更抽象的概念？这有助于区分《地书》更偏“画物”还是更偏“表达关系”。"
      },
      {
        "task_id": "pos_like_category",
        "task_name": "[Multi] 词性/符号性质 / POS-like Category",
        "mode": "multi",
        "applies_to": "both",
        "options": [
          "名词性 / Entity-like",
          "动词性 / Action-like",
          "形容词性 / State-like",
