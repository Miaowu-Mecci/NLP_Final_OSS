  "annotations": [
    {
      "target_id": "seg_001663",
      "task_id": "literal_gloss",
      "value": "步行",
      "updated_at": "2026-05-06T07:35:32.558Z"
    },
    {
      "target_id": "seg_001664",
      "task_id": "literal_gloss",
      "value": "斑马线",
      "updated_at": "2026-05-06T07:35:47.413Z"
    },
    {
      "target_id": "grp_961092_29",
      "task_id": "literal_gloss",
      "value": "地图、GPS定位点",
      "updated_at": "2026-05-06T07:47:46.531Z"
    },
    {
      "target_id": "seg_001668",
      "task_id": "literal_gloss",
      "value": "从W(西)指向E(东)",
      "updated_at": "2026-05-06T07:48:03.004Z"
    },
    {
      "target_id": "seg_001669",
      "task_id": "literal_gloss",
      "value": "脑子里在想公交与地铁",
      "updated_at": "2026-05-06T07:48:28.402Z"
    },
    {
      "target_id": "grp_979791_92",
      "task_id": "literal_gloss",
      "value": "我看了眼手机信号，",
      "updated_at": "2026-05-06T07:48:40.332Z"
    },
    {
      "target_id": "grp_994488_73",
      "task_id": "literal_gloss",
      "value": "路过限速280的路牌，",
      "updated_at": "2026-05-06T07:48:52.575Z"
    },
    {
      "target_id": "grp_997183_49",
      "task_id": "literal_gloss",
      "value": "前方有警示标识，",
      "updated_at": "2026-05-06T07:49:03.283Z"
    },
    {
      "target_id": "grp_006226_70",
      "task_id": "literal_gloss",
      "value": "公交无法通行",
      "updated_at": "2026-05-06T07:49:15.947Z"
    },
    {
      "target_id": "grp_162782_62",
      "task_id": "literal_gloss",
      "value": "我选择地铁",
      "updated_at": "2026-05-06T07:49:41.339Z"
    },
    {
      "target_id": "grp_166142_35",
      "task_id": "literal_gloss",
      "value": "下楼进站，",
      "updated_at": "2026-05-06T07:49:49.976Z"
    },
    {
      "target_id": "grp_169720_1",
      "task_id": "literal_gloss",
      "value": "看着前方长长的队伍。",
      "updated_at": "2026-05-06T07:49:57.120Z"
    },
    {
      "target_id": "grp_189005_2",
      "task_id": "literal_gloss",
      "value": "我排进队伍，打卡进站，",
      "updated_at": "2026-05-06T07:50:04.728Z"
    },
    {
      "target_id": "grp_196870_14",
      "task_id": "literal_gloss",
      "value": "看着时钟，额头冒汗。",
      "updated_at": "2026-05-06T07:50:07.238Z"
    },
    {
      "target_id": "grp_200434_49",
      "task_id": "literal_gloss",
      "value": "时间将近，",
      "updated_at": "2026-05-06T07:50:21.472Z"
    },
    {
      "target_id": "grp_211225_79",
      "task_id": "literal_gloss",
      "value": "队伍仍长，",
      "updated_at": "2026-05-06T07:50:26.863Z"
    },
    {
      "target_id": "grp_219393_87",
      "task_id": "literal_gloss",
      "value": "我攥紧拳头，",
      "updated_at": "2026-05-06T07:50:32.937Z"
    },
    {
      "target_id": "grp_223030_43",
      "task_id": "literal_gloss",
      "value": "前方有领导，不能迟到！",
      "updated_at": "2026-05-06T07:50:38.018Z"
    },
    {
      "target_id": "grp_231445_58",
      "task_id": "literal_gloss",
      "value": "打印文件、整理资料、处理报表，这些事在等着我，",
      "updated_at": "2026-05-06T07:50:46.930Z"
    },
    {
      "target_id": "grp_235607_18",
      "task_id": "literal_gloss",
      "value": "看着队伍，再看时钟，我面露惊讶，额头冒汗。",
      "updated_at": "2026-05-06T07:50:50.382Z"
    },
    {
      "target_id": "grp_246715_37",
      "task_id": "literal_gloss",
      "value": "队伍缓慢前移，时钟转动，队伍仍长",
      "updated_at": "2026-05-06T07:51:18.428Z"
    },
    {
      "target_id": "grp_252085_50",
      "task_id": "literal_gloss",
      "value": "时钟再走，我满头大汗，",
      "updated_at": "2026-05-06T07:51:30.388Z"
    },
    {
      "target_id": "grp_256585_42",
      "task_id": "literal_gloss",
      "value": "雨势渐大。终于轮到我，",
      "updated_at": "2026-05-06T07:51:40.350Z"
    },
    {
      "target_id": "grp_261535_70",
      "task_id": "literal_gloss",
      "value": "打卡进站，",
      "updated_at": "2026-05-06T07:51:48.411Z"
    },
    {
      "target_id": "grp_267130_11",
      "task_id": "literal_gloss",
      "value": "顺利通过，我露出微笑，",
      "updated_at": "2026-05-06T07:51:52.122Z"
    },
    {
      "target_id": "grp_050492_52",
      "task_id": "free_translation",
      "value": "我走过斑马线，看着城市定位，从西向东走。我在公交与地铁之间犹豫。",
      "updated_at": "2026-05-06T07:54:43.909Z"
    },
    {
      "target_id": "grp_065237_38",
      "task_id": "free_translation",
      "value": "我看了眼手机信号，路过限速280的路牌，前方有警示标识，路上严重拥堵，公交无法通行。",
      "updated_at": "2026-05-06T07:54:57.996Z"
    },
    {
      "target_id": "grp_162782_62",
      "task_id": "free_translation",
      "value": "我选择地铁，下楼进站，看着前方长长的队伍。",
      "updated_at": "2026-05-06T07:55:17.666Z"
    }
  ]
}