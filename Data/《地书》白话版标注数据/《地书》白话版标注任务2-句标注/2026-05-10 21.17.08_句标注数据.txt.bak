        "word_334",
        "word_335"
      ]
    },
    {
      "unit_id": "sent_035",
      "unit_type": "sentence",
      "text": "他喝醉了吐了一地，我帮他收拾干净，找到了他的钱包、手机和钥匙。",
      "sentence_index": 35,
      "char_start": 733,
      "char_end": 764,
      "children": [
