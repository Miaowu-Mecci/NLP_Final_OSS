        "word_390"
      ]
    },
    {
      "unit_id": "sent_040",
      "unit_type": "sentence",
      "text": "最后，我在他家门口喝了一杯酒，看着天上的月亮，心里想着他什么时候才能好起来。",
      "sentence_index": 40,
      "char_start": 834,
