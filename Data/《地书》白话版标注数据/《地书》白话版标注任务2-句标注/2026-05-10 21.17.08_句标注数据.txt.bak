        "word_352",
        "word_353"
      ]
    },
    {
      "unit_id": "sent_036",
      "unit_type": "sentence",
      "text": "他的狗看到我们回来了，非常兴奋。",
      "sentence_index": 36,
      "char_start": 765,
      "char_end": 781,
      "children": [
        "word_354",
        "word_355",
        "word_356",
