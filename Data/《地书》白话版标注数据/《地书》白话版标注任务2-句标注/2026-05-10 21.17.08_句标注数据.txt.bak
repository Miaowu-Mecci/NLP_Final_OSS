        "word_368",
        "word_369"
      ]
    },
    {
      "unit_id": "sent_038",
      "unit_type": "sentence",
      "text": "我照顾了他很久，他又吐了一次。",
      "sentence_index": 38,
      "char_start": 798,
      "char_end": 813,
      "children": [
        "word_370",
