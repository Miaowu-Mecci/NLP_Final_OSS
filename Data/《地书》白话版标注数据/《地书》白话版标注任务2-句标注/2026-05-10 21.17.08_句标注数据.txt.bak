        "word_358",
        "word_359",
        "word_360",
        "word_361"
      ]
    },
    {
      "unit_id": "sent_037",
      "unit_type": "sentence",
      "text": "我把他扶到床上，他还在说胡话。",
      "sentence_index": 37,
      "char_start": 782,
      "char_end": 797,
      "children": [
        "word_362",
        "word_363",
        "word_364",
        "word_365",
