        "word_378",
        "word_379"
      ]
    },
    {
      "unit_id": "sent_039",
      "unit_type": "sentence",
      "text": "看着他熟睡的样子，我感到既无奈又心疼。",
      "sentence_index": 39,
      "char_start": 814,
      "char_end": 833,
      "children": [
