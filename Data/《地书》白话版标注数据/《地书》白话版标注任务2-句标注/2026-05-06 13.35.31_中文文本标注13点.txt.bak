      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "刷工牌走进电梯时看到快递牌子，有点惊讶。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
      "annotation_id": "ann_027",
