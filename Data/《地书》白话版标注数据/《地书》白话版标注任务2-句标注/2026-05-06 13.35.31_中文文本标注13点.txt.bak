      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "结完账走出书店，看了一眼时间，然后回公司。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "DeepSeek",
      "annotator_note": ""
    },
    {
