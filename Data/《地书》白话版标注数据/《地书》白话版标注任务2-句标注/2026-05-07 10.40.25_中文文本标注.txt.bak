  "source_text": {
    "text_id": "text_002",
    "title": "24点步行回家",
    "source": "教师提供",
    "raw_text": "午夜十二点，我没有开车，而是选择步行回家。我看着地图，沿着脚下的脚印，一步步向前走。路上很安静，只有我一个人的脚步声。\n我经过了一个门口，又经过了一个警察局门口。走着走着，我看到一个女人，抬头看了看天空，然后继续往前走。\n沿着长长的脚印，我终于走到了家。",
    "notes": "24:00时间段文本 - 任务2：语句划分及篇章关系标注"
  },
  "units": [
    {
      "unit_id": "sent_001",
      "unit_type": "sentence",
      "text": "午夜十二点，",
      "sentence_index": 1,
      "char_start": 0,
      "char_end": 6,
      "children": []
    },
    {
      "unit_id": "sent_002",
      "unit_type": "sentence",
      "text": "我没有开车，",
      "sentence_index": 2,
      "char_start": 6,
      "char_end": 12,
      "children": []
    },
    {
      "unit_id": "sent_003",
      "unit_type": "sentence",
      "text": "而是选择步行回家。",
      "sentence_index": 3,
      "char_start": 12,
      "char_end": 22,
      "children": []
    },
    {
      "unit_id": "sent_004",
      "unit_type": "sentence",
      "text": "我看着地图，",
      "sentence_index": 4,
      "char_start": 22,
      "char_end": 28,
      "children": []
    },
    {
      "unit_id": "sent_005",
      "unit_type": "sentence",
      "text": "沿着脚下的脚印，",
      "sentence_index": 5,
      "char_start": 28,
      "char_end": 37,
      "children": []
    },
    {
      "unit_id": "sent_006",
      "unit_type": "sentence",
      "text": "一步步向前走。",
      "sentence_index": 6,
      "char_start": 37,
      "char_end": 45,
      "children": []
    },
    {
      "unit_id": "sent_007",
      "unit_type": "sentence",
      "text": "路上很安静，",
      "sentence_index": 7,
      "char_start": 45,
      "char_end": 51,
      "children": []
    },
    {
      "unit_id": "sent_008",
      "unit_type": "sentence",
      "text": "只有我一个人的脚步声。",
      "sentence_index": 8,
      "char_start": 51,
      "char_end": 64,
      "children": []
    },
    {
      "unit_id": "sent_009",
      "unit_type": "sentence",
      "text": "我经过了一个门口，",
      "sentence_index": 9,
      "char_start": 60,
      "char_end": 69,
      "children": []
    },
    {
      "unit_id": "sent_010",
      "unit_type": "sentence",
      "text": "又经过了一个警察局门口。",
      "sentence_index": 10,
      "char_start": 69,
      "char_end": 83,
      "children": []
    },
    {
      "unit_id": "sent_011",
      "unit_type": "sentence",
      "text": "走着走着，",
      "sentence_index": 11,
      "char_start": 83,
      "char_end": 88,
      "children": []
    },
    {
      "unit_id": "sent_012",
      "unit_type": "sentence",
      "text": "我看到一个女人，",
      "sentence_index": 12,
      "char_start": 88,
      "char_end": 96,
      "children": []
    },
    {
      "unit_id": "sent_013",
      "unit_type": "sentence",
      "text": "抬头看了看天空，",
      "sentence_index": 13,
      "char_start": 96,
      "char_end": 105,
      "children": []
    },
    {
      "unit_id": "sent_014",
      "unit_type": "sentence",
      "text": "然后继续往前走。",
      "sentence_index": 14,
      "char_start": 105,
      "char_end": 113,
      "children": []
    },
    {
      "unit_id": "sent_015",
      "unit_type": "sentence",
      "text": "沿着长长的脚印，我终于走到了家。",
      "sentence_index": 15,
      "char_start": 111,
      "char_end": 128,
      "children": []
    }
  ],
