      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "警察也向我了解事情经过，我配合调查并出示手机和电脑记录，说明自己与事故无关。",
      "confidence": 0.94,
      "llm_used": true,
