      "target_type": "sentence",
      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "我非常惊讶，于是停下脚步观看现场情况。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "ChatGPT5.5",
