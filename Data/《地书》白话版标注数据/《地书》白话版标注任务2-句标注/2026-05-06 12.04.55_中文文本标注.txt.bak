    {
      "unit_id": "sent_002",
      "unit_type": "sentence",
      "text": "我拿出手机，翻看了一下社交软件，看到有人在 Twitter 上为我点赞，还有人在 Facebook 上给我发了大笑的表情，更有人在 MSN 上约我晚上一起喝酒。",
      "sentence_index": 2,
      "children": ["word_007", "word_008", "word_009", "word_010", "word_011", "word_012", "word_013", "word_014", "word_015", "word_016", "word_017", "word_018", "word_019", "word_020", "word_021", "word_022", "word_023", "word_024", "word_025", "word_026"]
    },
    {
      "unit_id": "sent_003",
      "unit_type": "sentence",
      "text": "我心情愉快地在 MSN 上和一位女士聊了起来。",
      "sentence_index": 3,
      "children": ["word_027", "word_028", "word_029", "word_030", "word_031", "word_032", "word_033", "word_034"]
    },
    {
      "unit_id": "sent_004",
      "unit_type": "sentence",
      "text": "很快就到了下班时间，我打印完最后一点文件，准备离开公司。",
      "sentence_index": 4,
      "children": ["word_035", "word_036", "word_037", "word_038", "word_039", "word_040", "word_041", "word_042"]
    },
    {
      "unit_id": "sent_005",
      "unit_type": "sentence",
      "text": "走出公司大楼，我拿出手机，找到那位女士的电话号码，拨了过去。",
      "sentence_index": 5,
      "children": ["word_043", "word_044", "word_045", "word_046", "word_047", "word_048", "word_049"]
    },
    {
      "unit_id": "sent_006",
      "unit_type": "sentence",
      "text": "电话接通后，她笑着问是谁。",
      "sentence_index": 6,
      "children": ["word_050", "word_051", "word_052", "word_053", "word_054"]
    },
    {
      "unit_id": "sent_007",
      "unit_type": "sentence",
      "text": "我笑着告诉她是我，并邀请她晚上一起见面。",
      "sentence_index": 7,
      "children": ["word_055", "word_056", "word_057", "word_058", "word_059", "word_060", "word_061", "word_062", "word_063"]
    },
    {
      "unit_id": "sent_008",
      "unit_type": "sentence",
      "text": "她在电话那头确认了时间，我高兴地答应了。",
      "sentence_index": 8,
      "children": ["word_064", "word_065", "word_066", "word_067", "word_068", "word_069", "word_070"]
    },
    {
      "unit_id": "sent_009",
      "unit_type": "sentence",
      "text": "最后，她在电话里比了个 OK 手势，开心地说：“好的，没问题！”",
      "sentence_index": 9,
      "children": ["word_071", "word_072", "word_073", "word_074", "word_075", "word_076", "word_077", "word_078", "word_079", "word_080"]
    },
    {
      "unit_id": "sent_010",
      "unit_type": "sentence",
      "text": "晚上十一点，我在回家的路上，看到前面发生了一起车祸。",
      "sentence_index": 10,
      "children": ["word_081", "word_082", "word_083", "word_084", "word_085", "word_086", "word_087"]
    },
    {
      "unit_id": "sent_011",
      "unit_type": "sentence",
      "text": "两辆车撞在了一起，车主们正在激烈地争吵，互相指责对方的过错。",
      "sentence_index": 11,
      "children": ["word_088", "word_089", "word_090", "word_091", "word_092", "word_093", "word_094", "word_095", "word_096"]
    },
    {
      "unit_id": "sent_012",
      "unit_type": "sentence",
      "text": "我感到非常惊讶，停下脚步观看。",
      "sentence_index": 12,
      "children": ["word_097", "word_098", "word_099", "word_100", "word_101"]
    },
    {
      "unit_id": "sent_013",
      "unit_type": "sentence",
      "text": "很快，警察赶到了现场。",
      "sentence_index": 13,
      "children": ["word_102", "word_103", "word_104", "word_105"]
    },
    {
      "unit_id": "sent_014",
      "unit_type": "sentence",
      "text": "他们介入调查，询问了两位车主的情况。",
      "sentence_index": 14,
      "children": ["word_106", "word_107", "word_108", "word_109", "word_110"]
    },
    {
      "unit_id": "sent_015",
      "unit_type": "sentence",
      "text": "警察也向我询问了事情的经过，我笑着配合调查，给他们看了我的手机和电脑记录，证明我与此事无关。",
      "sentence_index": 15,
      "children": ["word_111", "word_112", "word_113", "word_114", "word_115", "word_116", "word_117", "word_118", "word_119", "word_120", "word_121", "word_122", "word_123", "word_124", "word_125", "word_126"]
    },
    {
      "unit_id": "sent_016",
      "unit_type": "sentence",
      "text": "警察对我的说法感到有些疑惑，我紧张得流了汗。",
      "sentence_index": 16,
      "children": ["word_127", "word_128", "word_129", "word_130", "word_131", "word_132", "word_133"]
    },
    {
      "unit_id": "sent_017",
      "unit_type": "sentence",
      "text": "他们查看了我的手机记录后，让我先在一旁等待，然后继续调查另一位车主。",
      "sentence_index": 17,
      "children": ["word_134", "word_135", "word_136", "word_137", "word_138", "word_139", "word_140", "word_141", "word_142", "word_143", "word_144"]
    },
    {
      "unit_id": "sent_018",
      "unit_type": "sentence",
      "text": "我站在那里，看着警察忙碌的身影，心里想着这场车祸到底是谁的责任。",
      "sentence_index": 18,
      "children": ["word_145", "word_146", "word_147", "word_148", "word_149", "word_150", "word_151", "word_152", "word_153", "word_154"]
    },
    {
      "unit_id": "sent_019",
      "unit_type": "sentence",
      "text": "午夜十二点，我没有开车，而是选择步行回家。",
      "sentence_index": 19,
      "children": ["word_155", "word_156", "word_157", "word_158", "word_159", "word_160"]
    },
    {
      "unit_id": "sent_020",
      "unit_type": "sentence",
      "text": "我看着地图，沿着脚下的脚印，一步步向前走。",
      "sentence_index": 20,
      "children": ["word_161", "word_162", "word_163", "word_164", "word_165", "word_166"]
    },
    {
      "unit_id": "sent_021",
      "unit_type": "sentence",
      "text": "路上很安静，只有我一个人的脚步声。",
      "sentence_index": 21,
      "children": ["word_167", "word_168", "word_169", "word_170", "word_171"]
    },
    {
      "unit_id": "sent_022",
      "unit_type": "sentence",
      "text": "我经过了一个门口，又经过了一个警察局门口。",
      "sentence_index": 22,
      "children": ["word_172", "word_173", "word_174", "word_175", "word_176", "word_177", "word_178"]
    },
    {
      "unit_id": "sent_023",
      "unit_type": "sentence",
      "text": "走着走着，我看到一个女人，抬头看了看天空，然后继续往前走。",
      "sentence_index": 23,
      "children": ["word_179", "word_180", "word_181", "word_182", "word_183", "word_184", "word_185", "word_186"]
    },
    {
      "unit_id": "sent_024",
      "unit_type": "sentence",
      "text": "沿着长长的脚印，我终于走到了家。",
      "sentence_index": 24,
      "children": ["word_187", "word_188", "word_189", "word_190", "word_191"]
    },
    {
      "unit_id": "sent_025",
      "unit_type": "sentence",
      "text": "凌晨两点，我躺在床上，很快就进入了梦乡。",
      "sentence_index": 25,
      "children": ["word_192", "word_193", "word_194", "word_195", "word_196", "word_197"]
    },
    {
      "unit_id": "sent_026",
      "unit_type": "sentence",
      "text": "在梦里，我看到两个人在激烈地争吵。",
      "sentence_index": 26,
      "children": ["word_198", "word_199", "word_200", "word_201", "word_202", "word_203"]
    },
    {
      "unit_id": "sent_027",
      "unit_type": "sentence",
      "text": "接着，我梦见了 2012 年世界末日的场景，巨大的海浪淹没了地球，人们纷纷逃到山上避难。",
      "sentence_index": 27,
