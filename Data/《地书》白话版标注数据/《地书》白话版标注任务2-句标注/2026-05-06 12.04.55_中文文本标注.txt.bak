      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "两辆车撞到一起后，车主们激烈争吵，互相指责对方有错。",
      "confidence": 0.95,
      "llm_used": true,
      "llm_name": "ChatGPT5.5",
      "annotator_note": ""
    },
    {
      "annotation_id": "ann_038",
