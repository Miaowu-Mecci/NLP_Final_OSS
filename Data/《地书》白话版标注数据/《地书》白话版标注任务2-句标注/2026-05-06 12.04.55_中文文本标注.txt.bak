      "task_id": "free_translation",
      "task_label_zh": "自由翻译",
      "task_label_en": "Free Translation",
      "value": "晚上十一点，我在回家途中看到前方发生了一起车祸。",
      "confidence": 0.96,
      "llm_used": true,
      "llm_name": "ChatGPT5.5",
      "annotator_note": ""
    },
    {
