      "char_end": 207
    },
    {
      "unit_id": "sent_006",
      "unit_type": "sentence",
      "text": "电话接通后，她笑着问是谁。",
      "sentence_index": 6,
      "char_start": 208,
      "char_end": 223
    },
    {
      "unit_id": "sent_007",
      "unit_type": "sentence",
