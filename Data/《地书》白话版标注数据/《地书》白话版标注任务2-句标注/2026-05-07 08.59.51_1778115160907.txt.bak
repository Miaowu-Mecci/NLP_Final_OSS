  "annotations": [
    {
      "target_id": "seg_010773",
      "task_id": "free_translation",
      "value": "到了深夜的时间。",
      "updated_at": "2026-05-07T00:42:00.943Z"
    },
    {
      "target_id": "grp_394263_46",
      "task_id": "free_translation",
      "value": "夜幕低垂，猫咪独自呆在家里。",
      "updated_at": "2026-05-07T00:48:36.086Z"
    },
    {
      "target_id": "grp_396604_79",
      "task_id": "free_translation",
      "value": "看到主人回来，猫咪马上走上前迎接，",
      "updated_at": "2026-05-07T00:48:43.635Z"
    },
    {
      "target_id": "grp_399437_49",
      "task_id": "free_translation",
      "value": "主人走进了家门。",
      "updated_at": "2026-05-07T00:48:57.968Z"
    },
    {
      "target_id": "grp_404571_56",
      "task_id": "free_translation",
      "value": "他蹲下来，充满爱意地抚摸着猫咪，",
      "updated_at": "2026-05-07T00:49:07.086Z"
    },
    {
      "target_id": "grp_406954_84",
      "task_id": "free_translation",
      "value": "猫咪舒服得露出了开心的表情，",
      "updated_at": "2026-05-07T00:49:13.062Z"
    },
    {
      "target_id": "grp_408937_54",
      "task_id": "free_translation",
      "value": "接着他给猫咪倒上了猫粮喂食。",
      "updated_at": "2026-05-07T00:49:20.318Z"
    },
    {
      "target_id": "grp_416437_11",
      "task_id": "free_translation",
      "value": "他看着猫咪，心情也变得很好。",
      "updated_at": "2026-05-07T00:49:26.893Z"
    },
    {
      "target_id": "grp_420003_85",
      "task_id": "free_translation",
      "value": "猫咪吃饱后走回了自己的小窝，很快就趴着睡着了。",
      "updated_at": "2026-05-07T00:49:37.790Z"
    },
    {
      "target_id": "grp_427141_49",
      "task_id": "free_translation",
      "value": "他走回卧室的床边，",
      "updated_at": "2026-05-07T00:49:45.210Z"
    },
    {
      "target_id": "grp_430166_24",
      "task_id": "free_translation",
      "value": "靠坐在床上，拿起遥控器按下了电源键打开电视。",
      "updated_at": "2026-05-07T00:49:52.425Z"
    },
    {
      "target_id": "grp_435958_13",
      "task_id": "free_translation",
      "value": "他从坐着变成舒服地躺下，眼睛一直盯着屏幕，正在看一个英文频道",
      "updated_at": "2026-05-07T00:49:59.925Z"
    },
    {
      "target_id": "seg_010850",
      "task_id": "free_translation",
      "value": "却觉得节目十分无聊。",
      "updated_at": "2026-05-07T00:50:06.409Z"
    },
    {
      "target_id": "grp_440383_88",
      "task_id": "free_translation",
      "value": "电视里播放着坦克开火的战争新闻，",
      "updated_at": "2026-05-07T00:50:13.100Z"
    },
    {
      "target_id": "seg_010860",
      "task_id": "free_translation",
      "value": "但他对这些新闻感到麻木无趣。",
      "updated_at": "2026-05-07T00:50:18.183Z"
    },
    {
      "target_id": "grp_447982_65",
      "task_id": "free_translation",
      "value": "他觉得没劲，用遥控器换了个台，",
      "updated_at": "2026-05-07T00:50:25.952Z"
    },
    {
      "target_id": "grp_450090_14",
      "task_id": "free_translation",
      "value": "换到了CCTV1，正在播报庄严的阅兵新闻。",
      "updated_at": "2026-05-07T00:50:32.321Z"
    },
    {
      "target_id": "grp_456057_21",
      "task_id": "free_translation",
      "value": "接着电视里播放了熊猫打滚卖萌的趣味画面，",
      "updated_at": "2026-05-07T00:50:39.477Z"
    },
    {
      "target_id": "seg_010878",
      "task_id": "free_translation",
      "value": "他看着觉得很有趣，开心地笑了。",
      "updated_at": "2026-05-07T00:50:45.334Z"
    },
    {
      "target_id": "grp_459345_91",
      "task_id": "free_translation",
      "value": "看完后他又继续按遥控器换台，",
      "updated_at": "2026-05-07T00:50:53.326Z"
    },
    {
      "target_id": "grp_462057_62",
      "task_id": "free_translation",
      "value": "这次换到了BBC频道。",
      "updated_at": "2026-05-07T00:50:59.294Z"
    },
    {
      "target_id": "grp_467907_52",
      "task_id": "free_translation",
      "value": "新闻里正报道着关于多元化婚姻、同性伴侣在教堂结婚和领养小孩的事情，",
      "updated_at": "2026-05-07T00:51:06.525Z"
    },
    {
      "target_id": "seg_010910",
      "task_id": "free_translation",
      "value": "但他对此毫无兴趣，面无表情。",
      "updated_at": "2026-05-07T00:51:12.205Z"
    },
    {
      "target_id": "grp_471915_87",
      "task_id": "free_translation",
      "value": "于是他再次换台，",
      "updated_at": "2026-05-07T00:51:22.623Z"
    },
    {
      "target_id": "grp_474924_13",
      "task_id": "free_translation",
      "value": "换到了NBC频道，正播放着一档野外自然探索节目，",
      "updated_at": "2026-05-07T00:51:31.652Z"
    },
    {
      "target_id": "grp_479407_12",
      "task_id": "free_translation",
      "value": "画面中一名猎人正举枪瞄准大象，",
      "updated_at": "2026-05-07T00:51:38.617Z"
    },
    {
      "target_id": "grp_482270_56",
      "task_id": "free_translation",
      "value": "随后警察赶到逮捕了多名偷猎者，",
      "updated_at": "2026-05-07T00:51:44.025Z"
    },
    {
      "target_id": "seg_010939",
      "task_id": "free_translation",
      "value": "他看到残忍猎杀动物的场景感到很揪心。",
      "updated_at": "2026-05-07T00:51:50.133Z"
    },
    {
      "target_id": "grp_488394_52",
      "task_id": "free_translation",
      "value": "心情受到影响，他又换了一个台，",
      "updated_at": "2026-05-07T00:51:57.674Z"
    },
    {
      "target_id": "grp_490245_13",
      "task_id": "free_translation",
      "value": "CNN频道正在播报一条突发航空新闻。",
      "updated_at": "2026-05-07T00:52:06.902Z"
    },
    {
      "target_id": "grp_493894_46",
      "task_id": "free_translation",
      "value": "新闻画面显示一架客机不幸发生坠海空难，造成上百人遇难！",
      "updated_at": "2026-05-07T00:52:12.259Z"
    },
    {
      "target_id": "seg_010964",
      "task_id": "free_translation",
      "value": "他看后感到无比震惊和恐慌",
      "updated_at": "2026-05-07T00:52:18.115Z"
    },
    {
      "target_id": "grp_499252_33",
      "task_id": "free_translation",
      "value": "他受不了这些接连不断的负面新闻，开始疯狂按遥控器换台，无数杂乱的频道一闪而过。",
      "updated_at": "2026-05-07T00:52:26.343Z"
    },
    {
      "target_id": "seg_010980",
      "task_id": "free_translation",
      "value": "经过这一番折腾，他感到极其困倦，",
      "updated_at": "2026-05-07T00:52:33.006Z"
    },
    {
      "target_id": "grp_507069_14",
      "task_id": "free_translation",
      "value": "眼皮越来越重，最终彻底合上双眼沉沉睡去，留下电视机还在深夜里闪烁着微光。",
      "updated_at": "2026-05-07T00:52:38.657Z"
    }
  ]
}